<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <submitter>Utilization_Submitters</submitter>
        <type>group</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>leaseworks__Aircraft__c</field>
        <field>leaseworks__Month_Ending__c</field>
        <field>leaseworks__Type__c</field>
        <field>leaseworks__TSN__c</field>
        <field>leaseworks__CSN__c</field>
        <field>leaseworks__TSN_At_Month_End__c</field>
        <field>leaseworks__CSN_At_Month_End__c</field>
        <field>leaseworks__Was_data_verified__c</field>
        <field>leaseworks__Date_of_Submission__c</field>
        <field>leaseworks__Total_Maintenance_Reserve__c</field>
        <field>leaseworks__Date_UR_Due__c</field>
        <field>leaseworks__Comments__c</field>
        <field>CreatedBy</field>
        <field>leaseworks__Warning__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>LW_Utilization_Report_Processing_Queue</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Approval of Utilization Report</label>
        <name>Approval_of_Utilization_Report</name>
    </approvalStep>
    <emailTemplate>leaseworks__LeaseWorksTemplates/leaseworks__Approval_with_Assembly</emailTemplate>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 OR 2</booleanFilter>
        <criteriaItems>
            <field>leaseworks__Utilization_Report__c.leaseworks__Status__c</field>
            <operation>equals</operation>
            <value>Open</value>
        </criteriaItems>
        <criteriaItems>
            <field>leaseworks__Utilization_Report__c.leaseworks__Status__c</field>
            <operation>equals</operation>
            <value>Rejected By Lessor</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>SetUtilizationApprovedDate</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Update_UR_status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Update_UR_status_Declined</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Utilisation_Report_Decline_Email_Alert</name>
            <type>Alert</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Update_Submitted_By_Id</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Update_UR_status_Pending</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Approval of Utilization Report</label>
    <processOrder>1</processOrder>
    <recallActions>
        <action>
            <name>Update_UR_status_Open</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
