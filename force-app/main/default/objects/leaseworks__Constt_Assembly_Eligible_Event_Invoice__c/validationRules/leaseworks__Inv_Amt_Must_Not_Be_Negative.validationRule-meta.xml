<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Inv_Amt_Must_Not_Be_Negative</fullName>
    <active>true</active>
    <description>Invoice amount should not be above zero.</description>
    <errorConditionFormula>AND(
!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c
, 
BLANKVALUE(leaseworks__Invoice_Amount__c,0)&lt;=0
)</errorConditionFormula>
    <errorDisplayField>leaseworks__Assembly_Amount__c</errorDisplayField>
    <errorMessage>Invoice amount must be greater than zero.</errorMessage>
</ValidationRule>
