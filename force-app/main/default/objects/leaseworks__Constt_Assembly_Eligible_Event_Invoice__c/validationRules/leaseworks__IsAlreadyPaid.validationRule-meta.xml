<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__IsAlreadyPaid</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
 !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c 
,TEXT(PRIORVALUE(leaseworks__Status__c )) ==&apos;Paid&apos;
)</errorConditionFormula>
    <errorMessage>You cannot modify an Invoice that is already paid.</errorMessage>
</ValidationRule>
