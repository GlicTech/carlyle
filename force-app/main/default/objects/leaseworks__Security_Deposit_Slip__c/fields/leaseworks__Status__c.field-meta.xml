<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Status__c</fullName>
    <deprecated>false</deprecated>
    <description>Auto set by the system. Open indicates that no invoice has been generated for this security deposit slip. Invoiced indicates that an invoice has been raised for the full amount.</description>
    <externalId>false</externalId>
    <formula>IF(
    ISBLANK(TEXT(leaseworks__Link_To_Invoice__r.leaseworks__Status__c)),
    &quot;Open&quot;,
    IF(
        OR(
            ISPICKVAL(leaseworks__Link_To_Invoice__r.leaseworks__Status__c, &quot;Pending&quot;),
            ISPICKVAL(leaseworks__Link_To_Invoice__r.leaseworks__Status__c, &quot;Approved&quot;),
            ISPICKVAL(leaseworks__Link_To_Invoice__r.leaseworks__Status__c, &quot;Cancelled-Pending&quot;),
            ISPICKVAL(leaseworks__Link_To_Invoice__r.leaseworks__Status__c, &quot;Submitted&quot;)
        ),
        &quot;Invoiced&quot;,
        IF(
            OR(
                ISPICKVAL(leaseworks__Link_To_Invoice__r.leaseworks__Status__c, &quot;Cancelled&quot;),
                ISPICKVAL(leaseworks__Link_To_Invoice__r.leaseworks__Status__c, &quot;Declined&quot;)
            ),
            &quot;Open&quot;,
            &quot;Open&quot;
        )
    )
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Open indicates that no invoice has been generated for this security deposit slip. Invoiced indicates that an invoice (Pending/Approved/Cancelled-Pending) has been raised for the full amount.</inlineHelpText>
    <label>Status</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
