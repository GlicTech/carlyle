<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Event_End_Date</fullName>
    <active>false</active>
    <description>Event end date field contains a date within year of holiday schedule</description>
    <errorConditionFormula>YEAR( leaseworks__Event_End_Date__c) &lt;&gt;  VALUE(leaseworks__Holiday_Schedule__r.leaseworks__Year_New__c)</errorConditionFormula>
    <errorDisplayField>leaseworks__Event_End_Date__c</errorDisplayField>
    <errorMessage>Please choose date within the Holiday Schedule year.</errorMessage>
</ValidationRule>
