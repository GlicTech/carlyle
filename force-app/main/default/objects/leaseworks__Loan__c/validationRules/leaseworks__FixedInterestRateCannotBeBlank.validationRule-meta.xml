<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__FixedInterestRateCannotBeBlank</fullName>
    <active>true</active>
    <description>Fixed Interest Rate Cannot be blank if Loan Type is &quot;Fixed&quot;</description>
    <errorConditionFormula>AND(Text(leaseworks__Loan_Type__c)==&apos;Fixed&apos;, ISBLANK( leaseworks__Fixed_Interest_Rate__c ))</errorConditionFormula>
    <errorDisplayField>leaseworks__Fixed_Interest_Rate__c</errorDisplayField>
    <errorMessage>Please enter the Fixed Interest Rate.</errorMessage>
</ValidationRule>
