<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__PayoutAmountGreaterThanZero</fullName>
    <active>true</active>
    <description>Payout Amount must be greater than zero</description>
    <errorConditionFormula>leaseworks__Payout_Amount__c  &lt;= 0</errorConditionFormula>
    <errorDisplayField>leaseworks__Payout_Amount__c</errorDisplayField>
    <errorMessage>The amount to be paid out cannot be less than or equal to zero.</errorMessage>
</ValidationRule>
