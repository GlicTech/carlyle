<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Deposit_Return_Date_F__c</fullName>
    <deprecated>false</deprecated>
    <description>Date when the Security Deposit was returned</description>
    <externalId>false</externalId>
    <formula>if( AND(leaseworks__Security_Depo_Cash__c == 0.0,
								NOT(OR (ISBLANK(leaseworks__Last_Deposit_Return_Date__c),  ISNULL(leaseworks__Last_Deposit_Return_Date__c)))),
leaseworks__Last_Deposit_Return_Date__c,null	)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Date of the payout that brought total cash on hand down to zero indicating that the deposit is fully returned.</inlineHelpText>
    <label>Deposit Returned Date</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Date</type>
</CustomField>
