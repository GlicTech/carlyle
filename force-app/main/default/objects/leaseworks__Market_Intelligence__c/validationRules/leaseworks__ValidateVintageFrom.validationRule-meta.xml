<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ValidateVintageFrom</fullName>
    <active>true</active>
    <errorConditionFormula>AND( !ISBLANK(leaseworks__Vintage_From__c),
OR(LEN(leaseworks__Vintage_From__c)!=4 , !ISNUMBER(leaseworks__Vintage_From__c) ,  VALUE(leaseworks__Vintage_From__c) &lt;1970 )
 )</errorConditionFormula>
    <errorDisplayField>leaseworks__Vintage_From__c</errorDisplayField>
    <errorMessage>Either enter a valid format of Year (YYYY) or it should be greater than 1970.</errorMessage>
</ValidationRule>
