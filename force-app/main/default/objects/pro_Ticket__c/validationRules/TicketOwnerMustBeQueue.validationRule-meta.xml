<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TicketOwnerMustBeQueue</fullName>
    <active>false</active>
    <errorConditionFormula>NOT(ISBLANK(Owner:User.Id))</errorConditionFormula>
    <errorDisplayField>OwnerId</errorDisplayField>
    <errorMessage>Tickets can only be owned by queues, not by users.</errorMessage>
</ValidationRule>
