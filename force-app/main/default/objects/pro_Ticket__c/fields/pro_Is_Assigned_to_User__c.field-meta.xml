<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Is_Assigned_to_User__c</fullName>
    <description>Checks if current running users name is in the Assignees list</description>
    <externalId>false</externalId>
    <formula>CONTAINS(pro_Assignees__c  ,  $User.FirstName + &#39; &#39; +  $User.LastName )</formula>
    <label>Is Assigned to User?</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
