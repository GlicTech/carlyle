<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Due_Tomorrow__c</fullName>
    <description>Evaluates as true if the due date for the ticket it tomorrow and status is not closed</description>
    <externalId>false</externalId>
    <formula>AND(
    pro_Expected_Due_Date__c = TODAY() + 1,
    NOT(ISPICKVAL( pro_Status__c , &#39;Closed&#39;))
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Due Tomorrow</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
