<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Ticket_Overdue__c</fullName>
    <description>Evaluates as true if the due date is before today and ticket had not been closed. Used as entry criteria for a scheduled flow.</description>
    <externalId>false</externalId>
    <formula>AND(
    pro_Expected_Due_Date__c &lt; TODAY(),
    NOT(ISPICKVAL(pro_Status__c, &#39;Closed&#39;))
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Ticket Overdue?</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
