<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Actual_Days__c</fullName>
    <description>Calculates the actual number of business days taken to complete an event.</description>
    <externalId>false</externalId>
    <formula>IF(
   pro_Variance_Working_Days__c &lt; 0, (pro_Variance_Working_Days__c * -1) + pro_Projected_Business_Days_Num__c,          pro_Projected_Business_Days_Num__c + pro_Variance_Working_Days__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Actual Business Days</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
