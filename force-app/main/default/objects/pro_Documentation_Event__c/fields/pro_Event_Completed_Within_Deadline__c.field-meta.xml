    <externalId>false</externalId>
    <formula>IF(  pro_Projected_Date__c &gt;=  pro_Actual_Date__c , &apos;Hit&apos;, &apos;Miss&apos;)</formula>
    <label>Event Completed Within Deadline?</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
