<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Documentation_Event_Open__c</fullName>
    <description>Evaluates as true if a documentation event record has an open deadline</description>
    <formula>AND(
    NOT(ISBLANK( pro_Projected_Date__c )), 
    ISBLANK( pro_Actual_Date__c )
)</formula>
    <label>Documentation Event Open?</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
