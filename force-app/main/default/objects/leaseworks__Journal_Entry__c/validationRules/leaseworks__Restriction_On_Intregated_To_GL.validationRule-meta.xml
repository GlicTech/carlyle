<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Restriction_On_Intregated_To_GL</fullName>
    <active>true</active>
    <description>Users can only move the status from Sent to Integrated on the &apos;Integrated to GL&apos; picklist value</description>
    <errorConditionFormula>false/*AND(
				ISCHANGED(Integrated_to_GL__c),
				ISPICKVAL(Integrated_to_GL__c, &apos;Pending&apos;),
				OR(
								ISPICKVAL(PRIORVALUE(Integrated_to_GL__c), &apos;Sent&apos;),
								ISPICKVAL(PRIORVALUE(Integrated_to_GL__c), &apos;Integrated&apos;)
				)
)*/</errorConditionFormula>
    <errorMessage>You can not move the status back to Pending</errorMessage>
</ValidationRule>
