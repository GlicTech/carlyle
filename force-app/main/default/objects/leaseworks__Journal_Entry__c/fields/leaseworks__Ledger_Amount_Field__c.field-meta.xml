<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Ledger_Amount_Field__c</fullName>
    <deprecated>false</deprecated>
    <description>Amount posted in ledger currency.</description>
    <externalId>false</externalId>
    <formula>IF(
    NOT(leaseworks__Multicurrency_Enabled__c), leaseworks__Amount__c,
    IF(
    ISBLANK(leaseworks__Exchange_Rate__c ),NULL,
    IF(leaseworks__Exchange_Rate__c = 0,0,leaseworks__Amount__c* leaseworks__Exchange_Rate__c )
    ))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Amount posted in ledger currency.</inlineHelpText>
    <label>Ledger Amount</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
