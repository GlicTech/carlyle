<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Month_Ending_Has_To_Be_Less_Than_Today</fullName>
    <active>true</active>
    <errorConditionFormula>AND(  
Value(Text(Year(leaseworks__Month_Ending__c))+lpad(Text(Month(leaseworks__Month_Ending__c)),2,&apos;0&apos;)+lpad(Text(Day(leaseworks__Month_Ending__c)),2,&apos;0&apos;) ) &gt; 
Value(Text(Year(Today()))+lpad(Text(Month(Today())+1),2,&apos;0&apos;)+&apos;01&apos; )
, ! leaseworks__Assumed_Estimated__c 
)</errorConditionFormula>
    <errorDisplayField>leaseworks__Month_Ending__c</errorDisplayField>
    <errorMessage>Utilization report cannot be filed for future periods.</errorMessage>
</ValidationRule>
