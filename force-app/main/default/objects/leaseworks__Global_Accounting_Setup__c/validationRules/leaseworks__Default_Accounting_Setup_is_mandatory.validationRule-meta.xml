<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Default_Accounting_Setup_is_mandatory</fullName>
    <active>true</active>
