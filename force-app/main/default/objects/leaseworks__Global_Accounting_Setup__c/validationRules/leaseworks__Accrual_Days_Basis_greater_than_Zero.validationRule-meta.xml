<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Accrual_Days_Basis_greater_than_Zero</fullName>
    <active>true</active>
    <description>Accrual Days Basis should accept value greater than 0</description>
    <errorConditionFormula>AND(
ISPICKVAL(leaseworks__Accrual_Method__c,&apos;Set Number of Days&apos;),
OR(leaseworks__Accrual_Days_Basis__c &lt; 30,leaseworks__Accrual_Days_Basis__c &gt; 31)
)</errorConditionFormula>
    <errorDisplayField>leaseworks__Accrual_Days_Basis__c</errorDisplayField>
    <errorMessage>Deferred Basis should be between 30.0 and 31.0</errorMessage>
</ValidationRule>
