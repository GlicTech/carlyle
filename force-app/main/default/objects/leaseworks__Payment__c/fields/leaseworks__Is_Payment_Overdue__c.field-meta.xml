<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Is_Payment_Overdue__c</fullName>
    <deprecated>false</deprecated>
    <description>Set to true if payment is made after due date on Invoice</description>
    <externalId>false</externalId>
    <formula>IF(ISBLANK(leaseworks__Invoice__r.leaseworks__Date_of_MR_Payment_Due__c),false,leaseworks__Payment_Date__c &gt; leaseworks__Invoice__r.leaseworks__Date_of_MR_Payment_Due__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>_Is Payment Overdue?</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
