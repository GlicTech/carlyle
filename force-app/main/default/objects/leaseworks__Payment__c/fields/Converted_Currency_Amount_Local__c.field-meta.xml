<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Converted_Currency_Amount_Local__c</fullName>
    <description>This field will be calculated only when the exchange rate information is available.</description>
    <externalId>false</externalId>
    <formula>IF(AND( leaseworks__Invoice__r.leaseworks__Exchange_Rate__c  != 0, NOT(ISPICKVAL( leaseworks__Invoice__r.leaseworks__Transaction_Currency__c , &#39;&#39;))),leaseworks__Amount__c * leaseworks__Invoice__r.leaseworks__Exchange_Rate__c,null)</formula>
    <label>Converted Currency Amount</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
