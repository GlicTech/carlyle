<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__CreatePyOnlyForApprovedInv</fullName>
    <active>true</active>
    <description>Payments can only be created on approved unpaid invoices.</description>
    <errorConditionFormula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c,ISNEW(),
				OR(leaseworks__Status__c=&apos;Pending&apos;,AND(leaseworks__Status__c = &apos;Approved&apos; , leaseworks__Y_Hidden_Invoice_Payment_Status__c =&apos;Credited&apos;),leaseworks__Status__c=&apos;Submitted&apos;,leaseworks__Status__c=&apos;Declined&apos;,leaseworks__Status__c=&apos;Cancelled-Pending&apos;,leaseworks__Status__c=&apos;Cancelled&apos;))</errorConditionFormula>
    <errorMessage>Payments can only be created on approved unpaid invoices.</errorMessage>
</ValidationRule>
