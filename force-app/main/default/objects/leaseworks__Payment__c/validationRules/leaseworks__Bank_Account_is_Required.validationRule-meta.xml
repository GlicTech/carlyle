<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Bank_Account_is_Required</fullName>
    <active>true</active>
    <description>Bank Account is a required field.</description>
    <errorConditionFormula>!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c &amp;&amp; ISBLANK( leaseworks__Lessor_Bank__c )&amp;&amp;  (ISPICKVAL(leaseworks__Payment_Status__c, &apos;Pending&apos;)  || ISPICKVAL(leaseworks__Payment_Status__c, &apos;Submitted&apos;))</errorConditionFormula>
    <errorDisplayField>leaseworks__Lessor_Bank__c</errorDisplayField>
    <errorMessage>Bank Account is a required field.</errorMessage>
</ValidationRule>
