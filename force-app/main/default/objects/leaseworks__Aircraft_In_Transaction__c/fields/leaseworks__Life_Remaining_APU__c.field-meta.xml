<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Life_Remaining_APU__c</fullName>
    <deprecated>false</deprecated>
    <externalId>false</externalId>
    <formula>IF( leaseworks__Performance_Limit_Hours_APU__c  = 0 , 0, 1-((((( leaseworks__Lease_End_Date__c - leaseworks__Data_as_of_Eng_1__c + 1)/(366/12))*  leaseworks__Average_Monthly_Hours_APU__c  )+  leaseworks__APU_TSN__c  )/  leaseworks__Performance_Limit_Hours_APU__c ))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>% Life Remaining - (Hours) APU</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
