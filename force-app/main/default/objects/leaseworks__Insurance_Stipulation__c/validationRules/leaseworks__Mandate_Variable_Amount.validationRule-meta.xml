<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Mandate_Variable_Amount</fullName>
    <active>true</active>
    <description>Mandate &quot;Variability Amount&quot; if Variability is &quot;Variable Amount&quot;</description>
    <errorConditionFormula>AND(ISPICKVAL(leaseworks__Variability__c, &quot;Variable Amount&quot;) , ISBLANK( leaseworks__Variability_Amount__c ))</errorConditionFormula>
    <errorDisplayField>leaseworks__Variability_Amount__c</errorDisplayField>
    <errorMessage>Please enter the Variability Amount</errorMessage>
</ValidationRule>
