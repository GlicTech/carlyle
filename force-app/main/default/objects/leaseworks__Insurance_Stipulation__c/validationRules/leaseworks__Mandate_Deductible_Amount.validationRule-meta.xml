<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Mandate_Deductible_Amount</fullName>
    <active>true</active>
    <description>Mandate &quot;Deductible Amount&quot; if Variability is &quot;Variable&quot;</description>
    <errorConditionFormula>IF(ISPICKVAL(leaseworks__Variability__c, &quot;Variable&quot;) &amp;&amp;  ISBLANK(leaseworks__Deductible_Amount__c) , true, false)</errorConditionFormula>
    <errorDisplayField>leaseworks__Deductible_Amount__c</errorDisplayField>
    <errorMessage>Please enter the Deductible Amount in case of Variable Variability.</errorMessage>
</ValidationRule>
