<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Mandate_Variability_Percent</fullName>
    <active>true</active>
    <description>Mandate &quot;Variability Percent&quot; if Variability is &quot;Variable Percent&quot;</description>
    <errorConditionFormula>AND( ISPICKVAL(leaseworks__Variability__c, &quot;Variable Percent&quot;), ISBLANK(leaseworks__Variability_Percent__c))</errorConditionFormula>
    <errorDisplayField>leaseworks__Variability_Percent__c</errorDisplayField>
    <errorMessage>Please enter the Variability Percent</errorMessage>
</ValidationRule>
