<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__FirstRenewalDtWhenVarNotFixed</fullName>
    <active>true</active>
    <description>This field should be entered only if the Variability is not Fixed</description>
    <errorConditionFormula>AND(ISPICKVAL(leaseworks__Variability__c, &quot;Fixed&quot;),!ISBLANK(  leaseworks__First_Renewal_Date__c ))</errorConditionFormula>
    <errorDisplayField>leaseworks__First_Renewal_Date__c</errorDisplayField>
    <errorMessage>This field should be entered only if the Variability is not Fixed</errorMessage>
</ValidationRule>
