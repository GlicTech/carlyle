<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Prospect_Must_Be_Entered</fullName>
    <active>true</active>
    <description>Choose or enter a prospect based on the prospect type.</description>
    <errorConditionFormula>AND( RecordType.Name==&#39;Disposal&#39;, OR(ISBLANK(TEXT(leaseworks__Prospect_Type__c)),
    AND(TEXT(leaseworks__Prospect_Type__c)==&#39;Lessor&#39;, ISBLANK(leaseworks__Lessor__c)),
  AND(TEXT(leaseworks__Prospect_Type__c)==&#39;Other&#39;, ISBLANK(leaseworks__Other_Party__c))
 )
)</errorConditionFormula>
    <errorDisplayField>leaseworks__Prospect_Type__c</errorDisplayField>
    <errorMessage>Please choose a Prospect Type and select the appropriate prospect for the selected Type.</errorMessage>
</ValidationRule>
