    <externalId>false</externalId>
    <formula>if((AND( CONTAINS(leaseworks__New_Used_List__c, &apos;New&apos;),CONTAINS(leaseworks__New_Used_List__c, &apos;Used&apos;) )),&apos;New/Used&apos;,
