    <fullName>leaseworks__Files_Config_on_Revision_Popup__c</fullName>
    <deprecated>false</deprecated>
    <description>Use this field to configure the New Revision popup by assigning a default value to this list (if no value is set, the code defaults to &#39;Copy&#39;). OFF hides the panel to copy/move/none the files in the Deal, so use this on clients that won&#39;t store files in the system. The other options initialize each file in the panel to that value.</description>
    <externalId>false</externalId>
    <label>Files Config on Revision Popup</label>
    <required>false</required>
    <trackFeedHistory>false</trackFeedHistory>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>OFF</fullName>
                <default>false</default>
                <label>OFF</label>
            </value>
            <value>
                <fullName>Copy</fullName>
                <default>true</default>
                <label>Copy</label>
            </value>
            <value>
                <fullName>Move</fullName>
                <default>false</default>
                <label>Move</label>
            </value>
            <value>
                <fullName>None</fullName>
                <default>false</default>
                <label>None</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
