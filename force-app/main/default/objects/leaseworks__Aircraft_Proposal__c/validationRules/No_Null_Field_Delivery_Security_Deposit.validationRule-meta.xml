<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>No_Null_Field_Delivery_Security_Deposit</fullName>
    <active>true</active>
    <description>Prodigy - RB - 22/11/2024</description>
    <errorConditionFormula>ISBLANK(TEXT(pro_Delivery_Security_Deposit__c)) &amp;&amp;
(TEXT(PRIORVALUE(pro_Delivery_Security_Deposit__c)) = &quot;Yes&quot; || TEXT(PRIORVALUE(pro_Delivery_Security_Deposit__c)) = &quot;No&quot;)</errorConditionFormula>
    <errorDisplayField>pro_Delivery_Security_Deposit__c</errorDisplayField>
    <errorMessage>You cannot change the Delivery Security Deposit field from &quot;Yes&quot; or &quot;No&quot; back to blank.</errorMessage>
</ValidationRule>
