<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Active__c</fullName>
    <description>Displays a green circle when the AiD is active. Displays a red circle when the AiD is inactive.</description>
    <externalId>false</externalId>
    <formula>IF(
  leaseworks__Inactive_AT__c = TRUE,
  IMAGE(&quot;/resource/1747144606000/red_circle?&quot;, &quot;Inactive&quot;, 19, 19),
  IMAGE(&quot;/resource/1730193892000/green_circle?&quot;, &quot;Active&quot;, 19, 19)
)</formula>
    <label>Active</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
