<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Company_Board_Approval_Date_Formula__c</fullName>
    <externalId>false</externalId>
    <formula>IF(
    ISPICKVAL(pro_Company_Board_Approval__c, &quot;No&quot;),
    &quot;NA&quot;,
    IF(
        NOT(ISBLANK(pro_Company_Board_Approval_Date__c)),
        TEXT(DAY(pro_Company_Board_Approval_Date__c)) &amp; &quot; &quot; &amp;
        CASE(MONTH(pro_Company_Board_Approval_Date__c),
            1, &quot;Jan&quot;,
            2, &quot;Feb&quot;,
            3, &quot;Mar&quot;,
            4, &quot;Apr&quot;,
            5, &quot;May&quot;,
            6, &quot;Jun&quot;,
            7, &quot;Jul&quot;,
            8, &quot;Aug&quot;,
            9, &quot;Sep&quot;,
            10, &quot;Oct&quot;,
            11, &quot;Nov&quot;,
            12, &quot;Dec&quot;,
            &quot;&quot;
        ) &amp; &quot; &quot; &amp;
        TEXT(YEAR(pro_Company_Board_Approval_Date__c)),
        &quot;&quot;
    )
)</formula>
    <label>Company Board Approval Date</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
