<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Lease_Documentation_Approval_per__c</fullName>
    <description>The percentage of approvers who have approved the lease documentation</description>
    <externalId>false</externalId>
    <formula>IF(
  pro_Lease_Documentation_Approver_Count__c = 0,
  1,
  pro_Lease_Documentation_Approval_Count__c / pro_Lease_Documentation_Approver_Count__c
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Lease Documentation Approval %</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
