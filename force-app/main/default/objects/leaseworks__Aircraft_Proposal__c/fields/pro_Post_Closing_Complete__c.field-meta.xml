<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Post_Closing_Complete__c</fullName>
    <description>AB 09/03/2026 - Percentage of post-closing items completed. Handles division by zero.</description>
    <formula>IF(pro_Post_Closing_Items_Total__c &gt; 0, pro_Post_Closing_Items_Completed__c / pro_Post_Closing_Items_Total__c, 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Post-Closing % Complete</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
