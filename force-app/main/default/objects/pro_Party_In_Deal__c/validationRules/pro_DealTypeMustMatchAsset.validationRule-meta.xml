<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_DealTypeMustMatchAsset</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(TEXT(pro_Deal_Type__c))),
  NOT(ISBLANK(TEXT(pro_Asset_in_Deal__r.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c))),
  TEXT(pro_Deal_Type__c) &lt;&gt; TEXT(pro_Asset_in_Deal__r.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c)
)</errorConditionFormula>
    <errorMessage>Deal Type must match the Deal Type on the parent Asset in Deal.</errorMessage>
</ValidationRule>
