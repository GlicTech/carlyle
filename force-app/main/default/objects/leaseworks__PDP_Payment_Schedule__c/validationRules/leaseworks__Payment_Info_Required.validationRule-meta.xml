<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Payment_Info_Required</fullName>
    <active>true</active>
    <description>Please enter the Percentage of PDPRP or Payment</description>
    <errorConditionFormula>AND( ISBLANK( leaseworks__Percentage_of_PDPRP__c ), ISBLANK( leaseworks__Total_Payment_Due_mm__c ))</errorConditionFormula>
    <errorDisplayField>leaseworks__Percentage_of_PDPRP__c</errorDisplayField>
    <errorMessage>Please enter the Percentage of PDPRP or Payment</errorMessage>
</ValidationRule>
