<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__FH_FC_Ratio__c</fullName>
    <deprecated>false</deprecated>
    <description>Flight Hours to Flight Cycles ratio during the utilization period</description>
    <externalId>false</externalId>
    <formula>IF(leaseworks__Cycles_During_Month__c &gt;0, leaseworks__Running_Hours_During_Month__c / leaseworks__Cycles_During_Month__c , null)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Flight Hours to Flight Cycles ratio during the utilization period</inlineHelpText>
    <label>Calculated FH:FC Ratio</label>
    <precision>18</precision>
    <required>false</required>
    <scale>4</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
