<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Rate_Less_Than_Zero</fullName>
    <active>true</active>
    <description>The currency rate must always be a positive value.</description>
    <errorConditionFormula>AND($Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c = false,leaseworks__Rate_New__c &lt;= 0)</errorConditionFormula>
    <errorDisplayField>leaseworks__Rate_New__c</errorDisplayField>
    <errorMessage>Rate should be greater than zero.</errorMessage>
</ValidationRule>
