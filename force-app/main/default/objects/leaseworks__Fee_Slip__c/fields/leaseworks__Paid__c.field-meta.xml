<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Paid__c</fullName>
    <deprecated>false</deprecated>
    <description>Auto checked if the associated invoice is paid.</description>
    <formula>OR(
    ISPICKVAL(leaseworks__Link_to_Invoice__r.leaseworks__Payment_Status__c, &quot;Credited&quot;),
    ISPICKVAL(leaseworks__Link_to_Invoice__r.leaseworks__Payment_Status__c, &quot;Paid&quot;)
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Auto checked if the associated invoice is paid.</inlineHelpText>
    <label>Paid</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
