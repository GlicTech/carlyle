<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ValidateDueDateForManualSlips</fullName>
    <active>true</active>
    <errorConditionFormula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c, leaseworks__Fee_Schedule__r.leaseworks__Manual_Fee_Slip_Entry__c = True,  ISBLANK( leaseworks__Date_Due__c ) )</errorConditionFormula>
    <errorDisplayField>leaseworks__Date_Due__c</errorDisplayField>
    <errorMessage>Due Date is required</errorMessage>
</ValidationRule>
