<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Completion__c</fullName>
    <deprecated>false</deprecated>
    <formula>If((leaseworks__Project_Tasks_Total__c==0),0,1- leaseworks__Project_Tasks_Open__c / leaseworks__Project_Tasks_Total__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>This is the percent of the technical checklist which is completed.</inlineHelpText>
    <label>Completion %</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
