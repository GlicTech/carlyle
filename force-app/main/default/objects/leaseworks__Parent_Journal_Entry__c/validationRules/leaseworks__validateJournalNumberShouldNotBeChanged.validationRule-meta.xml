<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__validateJournalNumberShouldNotBeChanged</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c, 
  NOT(ISBLANK(Name)),
  ISCHANGED(Name)
)</errorConditionFormula>
    <errorDisplayField>Name</errorDisplayField>
    <errorMessage>You cannot modify a system-generated sequence.</errorMessage>
</ValidationRule>
