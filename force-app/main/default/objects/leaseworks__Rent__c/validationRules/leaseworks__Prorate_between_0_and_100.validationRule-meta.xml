<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Prorate_between_0_and_100</fullName>
    <active>true</active>
    <errorConditionFormula>OR(leaseworks__Prorate__c  &lt; 0 , leaseworks__Prorate__c &gt;1)</errorConditionFormula>
