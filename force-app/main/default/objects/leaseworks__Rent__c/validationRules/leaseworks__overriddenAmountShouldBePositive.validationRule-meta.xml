<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__overriddenAmountShouldBePositive</fullName>
    <active>true</active>
    <description>Overridden Average SLR Amount should be greater than zero.</description>
    <errorConditionFormula>AND(  leaseworks__Overridden_Average_SLR_Amount__c &lt;= 0, leaseworks__Override_SLR_Amount__c == true)</errorConditionFormula>
    <errorDisplayField>leaseworks__Overridden_Average_SLR_Amount__c</errorDisplayField>
    <errorMessage>Overridden Average SLR Amount should be greater than zero.</errorMessage>
</ValidationRule>
