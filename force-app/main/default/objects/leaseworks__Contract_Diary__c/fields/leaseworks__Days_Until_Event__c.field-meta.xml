<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Days_Until_Event__c</fullName>
    <deprecated>false</deprecated>
    <description>The number of days remaining until this Event is due.</description>
    <externalId>false</externalId>
    <formula>IF(ISPICKVAL(leaseworks__Event_Status__c,&apos;Closed&apos;),NULL,leaseworks__Due_Date__c - TODAY())</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>The number of days remaining until this Event is due.</inlineHelpText>
    <label>Days Until Event</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
