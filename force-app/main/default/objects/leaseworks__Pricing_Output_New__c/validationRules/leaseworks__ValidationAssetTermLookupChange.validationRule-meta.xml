<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ValidationAssetTermLookupChange</fullName>
    <active>true</active>
    <description>Asset Term Cannot be Changed on Economic Analysis.</description>
    <errorConditionFormula>AND( 
NOT(ISBLANK(PRIORVALUE((leaseworks__Asset_Term__c)))), 
ISCHANGED((leaseworks__Asset_Term__c)), 
NOT(ISNEW()) 
)</errorConditionFormula>
    <errorMessage>Cannot change Asset term on Economic Analysis.</errorMessage>
</ValidationRule>
