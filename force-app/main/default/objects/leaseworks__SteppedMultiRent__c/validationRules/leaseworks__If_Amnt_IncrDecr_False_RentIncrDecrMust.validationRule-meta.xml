<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__If_Amnt_IncrDecr_False_RentIncrDecrMust</fullName>
    <active>true</active>
    <description>If Amount increase/decrease? is False , %Increase/Decrease is mandatory</description>
    <errorConditionFormula>AND( leaseworks__Amount_Incr_Decr__c =FALSE,OR(ISNULL( leaseworks__Rent_Percent__c ),ISBLANK(leaseworks__Rent_Percent__c)) )</errorConditionFormula>
    <errorDisplayField>leaseworks__Rent_Percent__c</errorDisplayField>
    <errorMessage>Please Enter Rent % (Increase/Decrease)</errorMessage>
</ValidationRule>
