<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Step_Start_Cannot_be_Before_Rent_Start</fullName>
    <active>true</active>
    <errorConditionFormula>OR( leaseworks__Multi_Rent_Schedule__r.leaseworks__Start_Date__c  &gt;  leaseworks__Stepped_Rent_Start_Date__c ,
leaseworks__Stepped_Rent_Start_Date__c &gt; leaseworks__Multi_Rent_Schedule__r.leaseworks__Rent_End_Date__c
)</errorConditionFormula>
    <errorMessage>Stepped Rent Start Date Must Be Between Rent Start Date And Rent End Date.</errorMessage>
</ValidationRule>
