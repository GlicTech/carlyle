                <fullName>Open for Payment Studio</fullName>
                <default>false</default>
                <label>Cash Received</label>
            </value>
            <value>
                <fullName>Closed with Invoice</fullName>
                <default>false</default>
                <label>Cash Applied</label>
            </value>
            <value>
                <fullName>Discard</fullName>
                <default>false</default>
                <label>Discard</label>
            </value>
            <value>
                <fullName>Complete</fullName>
                <default>false</default>
                <label>Complete</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
