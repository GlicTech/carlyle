<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Field_value_cannot_exceed_100</fullName>
    <active>true</active>
    <errorConditionFormula>IF( AND( ISPICKVAL( leaseworks__Type__c , &#39;Percentage&#39;), leaseworks__Percentage__c  &gt; 1) , true, false)</errorConditionFormula>
    <errorDisplayField>leaseworks__Percentage__c</errorDisplayField>
    <errorMessage>Percentage value cannot exceed 100%.</errorMessage>
</ValidationRule>
