<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Multicurrency_Enabled__c</fullName>
    <deprecated>false</deprecated>
    <description>This hidden checkbox controls the conditional display of fields on the layout when multicurrency is enabled.</description>
    <externalId>false</externalId>
    <formula>IF(NOT(ISBLANK(leaseworks__Invoice_Adjustment__r.leaseworks__Transaction_Currency__c)),
      IF(leaseworks__Invoice_Adjustment__r.leaseworks__Transaction_Currency__c = &quot;USD&quot;,false,true), false)</formula>
    <label>_Multicurrency Enabled</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
