<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__No_Manual_Update_to_Pending</fullName>
    <active>true</active>
    <description>Manual update to pending status is not permitted</description>
    <errorConditionFormula>AND(ISCHANGED(leaseworks__Status__c), 
				OR(isPickVal(PRIORVALUE(leaseworks__Status__c),&apos;Active&apos;),
							isPickVal(PRIORVALUE(leaseworks__Status__c),&apos;Inactive&apos;)),
				isPickVal(leaseworks__Status__c,&apos;Pending&apos;)
)</errorConditionFormula>
    <errorMessage>Letter of Credit status cannot be manually updated to Pending.</errorMessage>
</ValidationRule>
