<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__validationLifeLimitCycGreaterThanZero</fullName>
    <active>true</active>
    <errorConditionFormula>leaseworks__Life_Limit_Cycles__c &lt;= 0 || (REGEX(TEXT(leaseworks__Life_Limit_Cycles__c), &quot;[0-9]+[.]{1}[0-9]{2}&quot;))</errorConditionFormula>
    <errorDisplayField>leaseworks__Life_Limit_Cycles__c</errorDisplayField>
    <errorMessage>Life Limit(Cycles) should be always greater than Zero and whole number.</errorMessage>
</ValidationRule>
