<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__PrspectCreationRule</fullName>
    <active>true</active>
    <description>You cannot add prospects to an inactive marketing campaign.</description>
    <errorConditionFormula>and(
 !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c 
, ISNEW() 
, !leaseworks__Deal__r.leaseworks__Campaign_Active__c
)</errorConditionFormula>
    <errorMessage>You cannot add prospects to an inactive marketing campaign.</errorMessage>
</ValidationRule>
