<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__UR_Required_for_UR_Type_Invoice</fullName>
    <active>true</active>
    <errorConditionFormula>IF(OR($Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c, $Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c), FALSE, ( AND(RecordType.DeveloperName =&#39;Monthly_Utilization&#39;,
				ISBLANK( leaseworks__Utilization_Report__c ),
				Not(OR(Text(leaseworks__Payment_Status__c) = &#39;Credited&#39; ,Text(leaseworks__Status__c) = &#39;Cancelled&#39;, Text(leaseworks__Status__c) = &#39;Declined&#39;)))))</errorConditionFormula>
    <errorDisplayField>leaseworks__Utilization_Report__c</errorDisplayField>
    <errorMessage>Please select a Utilization.</errorMessage>
</ValidationRule>
