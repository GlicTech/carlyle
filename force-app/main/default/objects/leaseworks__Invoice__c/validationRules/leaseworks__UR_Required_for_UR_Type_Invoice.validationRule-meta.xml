<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__UR_Required_for_UR_Type_Invoice</fullName>
    <active>false</active>
    <errorConditionFormula>IF(OR($Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c, $Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c), FALSE, ( AND(RecordType.DeveloperName =&apos;Monthly_Utilization&apos;,
				ISBLANK( leaseworks__Utilization_Report__c ),
				Not(OR(Text(leaseworks__Payment_Status__c) = &apos;Credited&apos; ,Text(leaseworks__Status__c) = &apos;Cancelled&apos;, Text(leaseworks__Status__c) = &apos;Declined&apos;)))))</errorConditionFormula>
    <errorDisplayField>leaseworks__Utilization_Report__c</errorDisplayField>
    <errorMessage>Please select a Utilization.</errorMessage>
</ValidationRule>
