<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Restrict_On_Hold_Without_Approval</fullName>
    <active>true</active>
    <description>Makes sure Status is Approved and Payment Status is Open when the On Hold checkbox is checked.</description>
    <errorConditionFormula>AND(
    !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,
    leaseworks__On_Hold__c = TRUE,
    OR(
        NOT(ISPICKVAL(leaseworks__Status__c, &quot;Approved&quot;)),
        NOT(ISPICKVAL(leaseworks__Payment_Status__c, &quot;Open&quot;))
    )
)</errorConditionFormula>
    <errorDisplayField>leaseworks__On_Hold__c</errorDisplayField>
    <errorMessage>Only approved unpaid invoices are eligible for hold.</errorMessage>
</ValidationRule>
