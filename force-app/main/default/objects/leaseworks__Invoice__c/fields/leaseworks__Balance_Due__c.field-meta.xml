<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Balance_Due__c</fullName>
    <deprecated>false</deprecated>
    <description>Indicates the Balance Due on the associated invoice.</description>
    <formula>IF( OR(ISPICKVAL(leaseworks__Status__c,&apos;Declined&apos;),ISPICKVAL(leaseworks__Status__c,&apos;Cancelled&apos;)),0,  leaseworks__Total_Amount_Due__c  - (leaseworks__Amount_Paid_Remaining__c + leaseworks__Availed_Credit_Amount_Cm__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Indicates the Balance Due on the associated invoice</inlineHelpText>
    <label>Balance Due($)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
