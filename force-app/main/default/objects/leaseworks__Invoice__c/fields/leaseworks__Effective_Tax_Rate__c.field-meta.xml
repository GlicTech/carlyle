<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Effective_Tax_Rate__c</fullName>
    <deprecated>false</deprecated>
    <description>System calculated tax  rate that accounts all the updates on the Tax lines.</description>
    <formula>if(leaseworks__Invoiced_Amount_Formula__c == 0,0,leaseworks__Tax_Amount_Rollup__c / (leaseworks__Invoiced_Amount_Formula__c + leaseworks__Gross_Up_Amount__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>System calculated tax  rate that accounts all the updates on the Tax lines.</inlineHelpText>
    <label>Effective Tax Rate</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
