<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ReconScheduleMandatoryForUtilPayables</fullName>
    <active>true</active>
    <errorConditionFormula>AND(isPickVal(leaseworks__Payable_Type__c,&#39;MR Reconciliation Refund&#39;),
