<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__InvoiceShouldBeApproved</fullName>
    <active>true</active>
    <description>Rebate Payables can only be applied to Approved Invoices</description>
    <errorConditionFormula>AND(
ISNEW(),
ISPICKVAL(leaseworks__Payable_Type__c, &apos;Rebate&apos;),
!(ISPICKVAL(leaseworks__Related_Invoice__r.leaseworks__Status__c , &apos;Approved&apos;))
)</errorConditionFormula>
    <errorMessage>Rebates can only be applied to Approved Invoices</errorMessage>
</ValidationRule>
