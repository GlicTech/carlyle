<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ClaimShouldBeApproved</fullName>
    <active>true</active>
    <description>To create an event payable, the related claim status should be approved</description>
    <errorConditionFormula>AND(
ISNEW(),
ISPICKVAL(leaseworks__Payable_Type__c, &apos;MR Claim Event&apos;),
!(ISPICKVAL( leaseworks__Claim__r.leaseworks__Claim_Status__c, &apos;Approved&apos;))
)</errorConditionFormula>
    <errorMessage>The Claim must be Approved to create Payable Invoice/s</errorMessage>
</ValidationRule>
