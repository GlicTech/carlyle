<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Balance_Due__c</fullName>
    <deprecated>false</deprecated>
    <description>Balance due on invoice line item after Payment creation and updation. Amount Due- Sum of all pyament line item for that Invoice Line item</description>
    <formula>IF( OR(leaseworks__Invoice_Status__c ==&apos;Declined&apos;,leaseworks__Invoice_Status__c ==&apos;Cancelled&apos;),0,  leaseworks__Total_Line_Amount__c  -  (leaseworks__Total_Amount_Paid__c + leaseworks__Total_Amount_Credited__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Displays Total Line Amount less any approved Payments/Credits</inlineHelpText>
    <label>Line Amount Balance Due($)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
