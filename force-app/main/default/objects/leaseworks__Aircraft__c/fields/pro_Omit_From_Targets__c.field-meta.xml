<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Omit_From_Targets__c</fullName>
    <description>Evaluates as true if Impact Type = &apos;Russian&apos;, Status = &apos;Sold&apos;, or Likely Outcome = &apos;Sale&apos;</description>
    <formula>ISPICKVAL( pro_Impact_Type__c , &apos;Russia&apos;) ||  ISPICKVAL(leaseworks__Status__c , &apos;Sold&apos;)||   ISPICKVAL(Likely_Outcome__c , &apos;Sale&apos;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Omit From Targets</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
