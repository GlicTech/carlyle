<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Months__c</fullName>
    <deprecated>false</deprecated>
    <description>Period in months calculated by the system based on the dates in this schedule.</description>
    <externalId>false</externalId>
    <formula>(
( (YEAR(leaseworks__To_Date__c) - YEAR(leaseworks__From_Date__c) - 1) *12 )
+ (12 - MONTH(leaseworks__From_Date__c) +1)
+ MONTH(leaseworks__To_Date__c)
- 1
+ IF(DAY(leaseworks__To_Date__c) &gt; DAY(leaseworks__From_Date__c),1,0)
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Period in months calculated by the system based on the dates in this schedule.</inlineHelpText>
    <label>Reconciliation Period</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
