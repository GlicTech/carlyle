<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Date_cannot_be_futureDt</fullName>
    <active>true</active>
    <errorConditionFormula>AND($Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c == FALSE, $Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c == FALSE,leaseworks__Status_Change_Date__c &gt; TODAY(),  OR(ISPICKVAL(leaseworks__Status__c , &#39;Installation&#39;), ISPICKVAL(leaseworks__Status__c , &#39;Removal&#39;) ))</errorConditionFormula>
    <errorMessage>Last Installation / Last Removal Date can not be a future date</errorMessage>
</ValidationRule>
