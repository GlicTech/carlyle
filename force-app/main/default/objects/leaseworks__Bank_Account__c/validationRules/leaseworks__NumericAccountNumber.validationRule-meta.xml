<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__NumericAccountNumber</fullName>
    <active>true</active>
    <description>Account Number for US should be numeric only.</description>
    <errorConditionFormula>AND(leaseworks__Country__r.Name=&quot;United States&quot;, NOT(ISNUMBER( leaseworks__Account_Number__c)))</errorConditionFormula>
    <errorMessage>Account Number should be numeric for United States.</errorMessage>
</ValidationRule>
