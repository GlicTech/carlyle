<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Stop_Std_Dimension_field_modify</fullName>
    <active>true</active>
    <description>Not allow to modify the Standard Dimension fields</description>
    <errorConditionFormula>/*!$Setup.LeaseWorksSettings__c.Disable_All_Triggers__c &amp;&amp;   (Is_Standard_Dimension__c ||(ISCHANGED(Dimension__c) &amp;&amp;  PRIORVALUE(Is_Standard_Dimension__c)))*/false</errorConditionFormula>
    <errorMessage>Standard dimensions cannot be manually created or modified or deleted.</errorMessage>
</ValidationRule>
