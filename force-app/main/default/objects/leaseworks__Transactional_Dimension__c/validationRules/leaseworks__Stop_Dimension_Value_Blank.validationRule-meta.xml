<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Stop_Dimension_Value_Blank</fullName>
    <active>true</active>
    <description>#DimensionStory - If Default value is required &#39;Yes&#39; then Dimension Value cannot be blank</description>
    <errorConditionFormula>false 
    /*!$Setup.LeaseWorksSettings__c.Disable_All_Triggers__c &amp;&amp; ISPICKVAL(Default_Value_Required__c,&#39;Yes&#39;) &amp;&amp; ISBLANK(Dimension_Value__c)&amp;&amp; AccEnabled__c &amp;&amp; !Is_Standard_Dimension__c*/</errorConditionFormula>
    <errorDisplayField>leaseworks__Dimension_Value__c</errorDisplayField>
    <errorMessage>A default dimension value is required if &#39;Default Value Required&#39; is marked as Yes.</errorMessage>
</ValidationRule>
