<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Transaction_Currency__c</fullName>
    <deprecated>false</deprecated>
    <description>Currency of the transaction. Populated from Invoice/Payment; defaults to USD for other types.</description>
    <externalId>false</externalId>
    <formula>IF(
    NOT(ISBLANK(leaseworks__Invoice__c)),
    TEXT(leaseworks__Invoice__r.leaseworks__Transaction_Currency__c),
    IF(
        NOT(ISBLANK(leaseworks__Payments_Credits__c)),
        leaseworks__Payments_Credits__r.leaseworks__Transaction_Currency__c,
        &quot;USD&quot;
    )
)</formula>
    <inlineHelpText>Currency of the transaction. Populated from Invoice/Payment; defaults to USD for other types.</inlineHelpText>
    <label>Transaction Currency</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
