IF(!ISBLANK(leaseworks__Payments_Credits__c),&apos;Payable&apos;,
IF(!ISBLANK(leaseworks__Prepayment__c),&apos;Payable&apos;,
IF(!ISBLANK(leaseworks__Payables__c),&apos;Receivable&apos;,
IF(!ISBLANK(leaseworks__Payouts__c),&apos;Receivable&apos;,
IF(!ISBLANK(leaseworks__Credit_Memo__c),&apos;Payable&apos;,
