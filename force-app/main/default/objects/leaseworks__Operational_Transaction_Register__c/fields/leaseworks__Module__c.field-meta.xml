    <externalId>false</externalId>
    <formula>IF($Setup.leaseworks__LeaseWorksSettings__c.leaseworks__CustType__c ==&apos;LESSOR&apos;,
(IF(!ISBLANK(leaseworks__Invoice__c),&apos;Receivable&apos;,
IF(!ISBLANK(leaseworks__Payments_Credits__c),&apos;Receivable&apos;,
IF(!ISBLANK(leaseworks__Prepayment__c),&apos;Receivable&apos;,
IF(!ISBLANK(leaseworks__Payables__c),&apos;Payable&apos;,
IF(!ISBLANK(leaseworks__Payouts__c),&apos;Payable&apos;,
