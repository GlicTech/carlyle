<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Transaction_Source__c</fullName>
    <deprecated>false</deprecated>
    <description>Indicates the source of the transaction. For Manual Invoices display Invoice Category along with the Invoice Type. Prepayment functionality is already deprecated. Keeping the lookup to track historical prepayments</description>
    <externalId>false</externalId>
    <formula>IF(!ISBLANK(leaseworks__Invoice__c),(IF(ISPICKVAL(leaseworks__Invoice__r.leaseworks__Invoice_Type__c,&#39;Other&#39;),TEXT(leaseworks__Invoice__r.leaseworks__Invoice_Type__c)+&#39;-&#39;+TEXT(leaseworks__Invoice__r.leaseworks__Invoice_Category__c),TEXT(leaseworks__Invoice__r.leaseworks__Invoice_Type__c))),
IF(!ISBLANK(leaseworks__Payments_Credits__c),(IF(ISPICKVAL(leaseworks__Payments_Credits__r.leaseworks__Payment_Type__c,&#39;CN_Payment&#39;),TEXT(leaseworks__Payments_Credits__r.leaseworks__Invoice__r.leaseworks__Invoice_Type__c)+&#39;-&#39;+&#39;Credit&#39;,TEXT(leaseworks__Payments_Credits__r.leaseworks__Invoice__r.leaseworks__Invoice_Type__c))),
IF(!ISBLANK(leaseworks__Prepayment__c),&#39;Payment&#39;,
IF(!ISBLANK(leaseworks__Payables__c),IF(ISPICKVAL(leaseworks__Payables__r.leaseworks__Payable_Type__c,&#39;Rebate&#39;),TEXT(leaseworks__Payables__r.leaseworks__Payable_Type__c) + &#39; - &#39; + TEXT(leaseworks__Payables__r.leaseworks__Related_Invoice__r.leaseworks__Invoice_Type__c),TEXT(leaseworks__Payables__r.leaseworks__Payable_Type__c)),
IF(!ISBLANK(leaseworks__Payouts__c),IF(leaseworks__Payouts__r.leaseworks__Payables_Type__c == &#39;Rebate&#39;,leaseworks__Payouts__r.leaseworks__Payables_Type__c + &#39; - &#39; + TEXT(leaseworks__Payouts__r.leaseworks__Related_Invoice__r.leaseworks__Invoice_Type__c),leaseworks__Payouts__r.leaseworks__Payables_Type__c),
IF(!ISBLANK(leaseworks__Credit_Memo__c),&#39;Credit Memo&#39;,
IF(!ISBLANK( leaseworks__Payment_on_Account__c ),&#39;Payment on Account&#39;,&#39;&#39;)))))))</formula>
    <inlineHelpText>Indicates the source of the transaction. Eg : Invoice/Payment etc.</inlineHelpText>
    <label>Transaction Source</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
