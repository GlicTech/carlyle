<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Balance_Due_Ledger__c</fullName>
    <deprecated>false</deprecated>
    <description>Balance amount in USD, converted using the exchange rate. Same if already in USD.</description>
    <externalId>false</externalId>
    <formula>IF(
    NOT(ISBLANK(leaseworks__Invoice__c)),
    leaseworks__Invoice__r.leaseworks__Balance_Due_Ledger__c,
    IF(
        NOT(ISBLANK(leaseworks__Payments_Credits__c)),
        NULL,
        leaseworks__Balance_Due_New__c
    )
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Balance amount in USD, converted using the exchange rate. Same if already in USD.</inlineHelpText>
    <label>Balance Due (Ledger)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
