<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Transaction_Date__c</fullName>
    <deprecated>false</deprecated>
    <description>Indicates the Transaction Date.Prepayment functionality is already deprecated. Keeping the lookup to track historical prepayments</description>
    <formula>IF(!ISBLANK(leaseworks__Invoice__c),leaseworks__Invoice__r.leaseworks__Invoice_Date__c,
IF(!ISBLANK(leaseworks__Payments_Credits__c),leaseworks__Payments_Credits__r.leaseworks__Payment_Date__c,
IF(!ISBLANK(leaseworks__Prepayment__c),leaseworks__Prepayment__r.leaseworks__Payment_Date__c,
IF(!ISBLANK(leaseworks__Payables__c),leaseworks__Payables__r.leaseworks__Payable_Date__c,
IF(!ISBLANK(leaseworks__Payouts__c),leaseworks__Payouts__r.leaseworks__Payout_Date__c,
IF(!ISBLANK(leaseworks__Credit_Memo__c),leaseworks__Credit_Memo__r.leaseworks__Credit_Memo_Date__c,
IF(!ISBLANK( leaseworks__Payment_on_Account__c ), leaseworks__Payment_on_Account__r.leaseworks__Date_Received__c ,
null)))))))</formula>
    <inlineHelpText>Indicates the Transaction Date</inlineHelpText>
    <label>Transaction Date</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Date</type>
</CustomField>
