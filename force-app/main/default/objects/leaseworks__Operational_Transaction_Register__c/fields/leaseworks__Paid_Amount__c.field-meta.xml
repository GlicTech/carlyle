<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Paid_Amount__c</fullName>
    <deprecated>false</deprecated>
    <description>Prepayment functionality is already deprecated. Keeping the lookup to track historical prepayments</description>
    <externalId>false</externalId>
    <formula>IF(!ISBLANK(leaseworks__Invoice__c),leaseworks__Invoice__r.leaseworks__Amount_Paid_Remaining__c,
IF(!ISBLANK(leaseworks__Payments_Credits__c),null,
IF(!ISBLANK(leaseworks__Prepayment__c),leaseworks__Prepayment__r.leaseworks__Amount_Paid__c,
IF(!ISBLANK(leaseworks__Payables__c),leaseworks__Payables__r.leaseworks__Total_Payout_Amount__c,
IF(!ISBLANK(leaseworks__Payouts__c),null,
IF(!ISBLANK(leaseworks__Credit_Memo__c),leaseworks__Credit_Memo__r.leaseworks__Allocated_Amount__c,
IF(!ISBLANK( leaseworks__Payment_on_Account__c ), leaseworks__Payment_on_Account__r.leaseworks__Amount_Applied__c ,null)))))))</formula>
    <label>Paid Amount</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
