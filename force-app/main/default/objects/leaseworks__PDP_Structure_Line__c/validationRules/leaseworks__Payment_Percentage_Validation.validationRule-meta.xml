<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Payment_Percentage_Validation</fullName>
    <active>true</active>
    <description>Validates that the Percent Payment is greater than 0.</description>
    <errorConditionFormula>leaseworks__Payment__c &lt;= 0</errorConditionFormula>
    <errorDisplayField>leaseworks__Payment__c</errorDisplayField>
    <errorMessage>The Payment Percentage must be greater than 0</errorMessage>
</ValidationRule>
