<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Duplicate_Name_not_Allowed</fullName>
    <active>true</active>
    <errorConditionFormula>AND(LOWER(VLOOKUP(($ObjectType.leaseworks__Engine_Thrust__c.Fields.Name), ($ObjectType.leaseworks__Engine_Thrust__c.Fields.Name), (Name))) = LOWER(Name), OR(ISNEW(), ISCHANGED(Name)))</errorConditionFormula>
    <errorMessage>Duplicate Engine Thrust Names are not allowed.</errorMessage>
</ValidationRule>
