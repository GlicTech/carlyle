<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__AssemblyTypeRequired</fullName>
    <active>true</active>
    <description>Associated Assembly is Required</description>
    <errorConditionFormula>IF(OR($Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,
        $Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c), FALSE,
        ISBLANK(TEXT(leaseworks__Assembly_Lkp__r.leaseworks__Type__c)))</errorConditionFormula>
    <errorDisplayField>leaseworks__Assembly_Lkp__c</errorDisplayField>
    <errorMessage>Please choose an Assembly.</errorMessage>
</ValidationRule>
