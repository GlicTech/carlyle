<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__GracePeriodVal_NoDecimalWithinRange</fullName>
    <active>true</active>
    <description>The grace period should be with the range of 1 to 365 (no decimals should be allowed)</description>
    <errorConditionFormula>AND(NOT(ISNULL( leaseworks__Grace_Period_After_Due_Date__c )), OR((FLOOR(leaseworks__Grace_Period_After_Due_Date__c) != leaseworks__Grace_Period_After_Due_Date__c) , leaseworks__Grace_Period_After_Due_Date__c &lt; 1 ,leaseworks__Grace_Period_After_Due_Date__c &gt; 365) )</errorConditionFormula>
    <errorDisplayField>leaseworks__Grace_Period_After_Due_Date__c</errorDisplayField>
    <errorMessage>The value must be between 1 and 365.</errorMessage>
</ValidationRule>
