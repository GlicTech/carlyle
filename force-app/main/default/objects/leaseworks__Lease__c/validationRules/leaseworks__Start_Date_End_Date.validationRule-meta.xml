<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Start_Date_End_Date</fullName>
    <active>true</active>
    <description>Lease start date should be earlier than end dates</description>
    <errorConditionFormula>leaseworks__Lease_End_Date_New__c &lt; leaseworks__Lease_Start_Date_New__c</errorConditionFormula>
    <errorDisplayField>leaseworks__Lease_Start_Date_New__c</errorDisplayField>
    <errorMessage>Lease end date cannot be earlier than lease start date</errorMessage>
</ValidationRule>
