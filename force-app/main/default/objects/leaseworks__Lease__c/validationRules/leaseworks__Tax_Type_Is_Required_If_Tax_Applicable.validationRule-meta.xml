<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Tax_Type_Is_Required_If_Tax_Applicable</fullName>
    <active>true</active>
    <description>Select a tax record here if Tax Applicable is checked.</description>
    <errorConditionFormula>AND( !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c,  leaseworks__Tax_Applicable__c , OR( ISNULL(leaseworks__Tax__c),  ISBLANK(leaseworks__Tax__c) ))</errorConditionFormula>
    <errorDisplayField>leaseworks__Tax__c</errorDisplayField>
    <errorMessage>Please select a tax record here if Tax Applicable is checked.</errorMessage>
</ValidationRule>
