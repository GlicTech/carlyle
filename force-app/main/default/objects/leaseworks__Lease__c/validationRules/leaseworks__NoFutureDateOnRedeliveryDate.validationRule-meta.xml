<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__NoFutureDateOnRedeliveryDate</fullName>
    <active>true</active>
    <errorConditionFormula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,  leaseworks__Redelivery_Date__c &gt; TODAY() )</errorConditionFormula>
    <errorDisplayField>leaseworks__Redelivery_Date__c</errorDisplayField>
    <errorMessage>Future Dates Not Allowed for Redelivery Date. Use &apos;Estimated Redelivery&apos; for future date entries.</errorMessage>
</ValidationRule>
