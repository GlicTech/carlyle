<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__MC_ContractCurrencyCantBeManuallyUpdated</fullName>
    <active>true</active>
    <description>Contract currency cannot be updated manually on contract.</description>
    <errorConditionFormula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,ISCHANGED( leaseworks__Loan_Currency__c ))</errorConditionFormula>
    <errorMessage>Contract currency cannot be updated manually on contract.</errorMessage>
</ValidationRule>
