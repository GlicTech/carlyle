<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__NoFuturedateOnDeliveryDate</fullName>
    <active>true</active>
    <errorConditionFormula>AND( leaseworks__Delivery_Date__c &gt; TODAY() , !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c )</errorConditionFormula>
    <errorDisplayField>leaseworks__Delivery_Date__c</errorDisplayField>
    <errorMessage>Future Dates Not Allowed for Delivery Date. Use &#39;Estimated Delivery&#39; for future date entries.</errorMessage>
</ValidationRule>
