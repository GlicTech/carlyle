<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Adjustment_Amount_Validation</fullName>
    <active>true</active>
    <description>It should restict entry of Zero Amount</description>
    <errorConditionFormula>AND( 
   !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,
   NOT( 
       ISNULL(leaseworks__Adjustment_Amount__c)
   ),
   leaseworks__Adjustment_Amount__c= 0
)</errorConditionFormula>
    <errorDisplayField>leaseworks__Adjustment_Amount__c</errorDisplayField>
    <errorMessage>Adjustment Flat Amount cannot be zero, please enter different amount.</errorMessage>
</ValidationRule>
