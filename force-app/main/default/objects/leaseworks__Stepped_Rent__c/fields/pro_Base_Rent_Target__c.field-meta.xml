<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Base_Rent_Target__c</fullName>
    <description>Used as the foundational currency conversion formula for the Base Rent.</description>
    <externalId>false</externalId>
    <formula>IF( ISPICKVAL(leaseworks__Billing_Currency__c,&#39;USD&#39;),
			pro_Rent_Slip_Current__c, (pro_Rent_Slip_Current__c *  pro_Currency_Rates__r.leaseworks__Rate_New__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Rent (Current)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
