<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Business_Days_Prior</fullName>
    <active>true</active>
    <description>If Rent Type is &#39;Floating&#39;, Business Days Prior cannot be beyond 31</description>
    <errorConditionFormula>and (
						contains(text(leaseworks__Rent_Type__c),&#39;Floating Rent&#39;),
						(leaseworks__Business_Days_Prior__c &gt; 31)
)</errorConditionFormula>
    <errorDisplayField>leaseworks__Business_Days_Prior__c</errorDisplayField>
    <errorMessage>Only numbers from 0 to 31 are allowed, please check your entry.</errorMessage>
</ValidationRule>
