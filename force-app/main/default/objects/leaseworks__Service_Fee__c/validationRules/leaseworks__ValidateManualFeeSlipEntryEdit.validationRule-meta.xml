<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ValidateManualFeeSlipEntryEdit</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
   !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,
   NOT(ISNEW()),
   ISCHANGED( leaseworks__Manual_Fee_Slip_Entry__c )  
)</errorConditionFormula>
    <errorDisplayField>leaseworks__Manual_Fee_Slip_Entry__c</errorDisplayField>
    <errorMessage>The Manual Fee Slip Entry setting cannot be changed after the fee schedule has been saved. Please create a new fee schedule if you need to change this setting.</errorMessage>
</ValidationRule>
