<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__RentScheduleRequiredIfIntercompany</fullName>
    <active>true</active>
    <description>Validates that a Rent Schedule is selected on the Fee Schedule if Intercompany is set to Yes</description>
    <errorConditionFormula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,
 ISPICKVAL(leaseworks__Fee_Type__c,&#39;Service Fee&#39;), ISPICKVAL(leaseworks__Intercompany_Service_Fee__c,&#39;Yes&#39;),ISBLANK( leaseworks__Rent_Schedule__c ), leaseworks__Lease__r.RecordType.DeveloperName != &#39;Non_Lease_Agreement&#39;)</errorConditionFormula>
    <errorMessage>Rent Schedule is required for intercompany service fee. Please select a rent schedule.</errorMessage>
</ValidationRule>
