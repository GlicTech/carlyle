<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ValidateFeeDueDayForFixdDueType</fullName>
    <active>true</active>
    <errorConditionFormula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c,
CONTAINS(text( leaseworks__Fee_Due_Type__c ),&#39;Fixed&#39;),
OR( leaseworks__Fee_Due_Day__c &lt; 1, leaseworks__Fee_Due_Day__c &gt; 31)
)</errorConditionFormula>
    <errorMessage>Since Fee Due Type &#39;Fixed&#39; has been selected, please enter a value between 1 and 31 (days in the calendar month) on Fee Due Day field.</errorMessage>
</ValidationRule>
