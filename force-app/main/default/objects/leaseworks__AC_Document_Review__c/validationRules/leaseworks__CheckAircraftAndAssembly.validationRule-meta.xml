<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__CheckAircraftAndAssembly</fullName>
    <active>true</active>
    <errorConditionFormula>AND (  
!ISBLANK(leaseworks__Aircraft__c ) ,!ISBLANK(leaseworks__Assembly__c)
,leaseworks__Assembly__r.leaseworks__Attached_Aircraft__c != leaseworks__Aircraft__c 
)</errorConditionFormula>
    <errorMessage>Aircraft and Assembly information are not matching.</errorMessage>
</ValidationRule>
