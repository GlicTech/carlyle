<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__CheckAircraftAndLease</fullName>
    <active>true</active>
    <errorConditionFormula>AND ( 
   !ISBLANK(leaseworks__Lease__c )
,  !ISBLANK(leaseworks__Aircraft__c )
,leaseworks__Lease__r.leaseworks__Aircraft__c != leaseworks__Aircraft__c )</errorConditionFormula>
    <errorMessage>Aircraft and Lease information are not matching.</errorMessage>
</ValidationRule>
