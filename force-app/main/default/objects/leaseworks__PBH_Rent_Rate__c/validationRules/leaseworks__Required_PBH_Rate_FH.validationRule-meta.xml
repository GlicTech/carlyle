<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Required_PBH_Rate_FH</fullName>
    <active>true</active>
    <description>RBH Rate (FH) value is required if rate basis is set to Hourly</description>
    <errorConditionFormula>AND(
        OR(leaseworks__Rate_Basis_F__c == &apos;Hourly&apos;, leaseworks__Rate_Basis_F__c == &apos;FH Matrix&apos;),
        ISNULL(leaseworks__PBH_Rate__c )
        )</errorConditionFormula>
    <errorDisplayField>leaseworks__PBH_Rate__c</errorDisplayField>
    <errorMessage>PBH Rate (FH) value is required when the rate basis is set to Hourly</errorMessage>
</ValidationRule>
