<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__StartDate_NotAfter_EndDate</fullName>
    <active>true</active>
    <description>Start date should not be after the Lease End date</description>
    <errorConditionFormula>leaseworks__Start_Date__c &gt;= leaseworks__Lease__r.leaseworks__Lease_End_Date_New__c</errorConditionFormula>
    <errorDisplayField>leaseworks__Start_Date__c</errorDisplayField>
    <errorMessage>The Start date cannot be after the lease end date.</errorMessage>
</ValidationRule>
