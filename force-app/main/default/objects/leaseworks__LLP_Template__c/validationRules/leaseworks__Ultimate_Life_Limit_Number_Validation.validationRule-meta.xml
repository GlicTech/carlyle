<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Ultimate_Life_Limit_Number_Validation</fullName>
    <active>true</active>
    <description>Validation for showing error message when a negative value is given for the field Ultimate Life Limit(Cycles).</description>
    <errorConditionFormula>leaseworks__Ultimate_Life_Limit_Cycles__c &lt; 0</errorConditionFormula>
    <errorDisplayField>leaseworks__Ultimate_Life_Limit_Cycles__c</errorDisplayField>
    <errorMessage>Please enter valid number</errorMessage>
</ValidationRule>
