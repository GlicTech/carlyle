<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Update_Rate_Basis</fullName>
    <active>true</active>
    <errorConditionFormula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c, leaseworks__NoOfInterpolationrecords__c &gt;0, ISCHANGED( leaseworks__Rate_Basis__c ) )</errorConditionFormula>
    <errorMessage>Rate Basis cannot be changed after child records have been created. To modify the Rate Basis, please delete the existing child records first.</errorMessage>
</ValidationRule>
