<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__StatusNewRule1</fullName>
    <active>true</active>
    <errorConditionFormula>AND (  !$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c  ,
 OR(  ISNEW() &amp;&amp;  text(leaseworks__Status__c) ==&apos;Active&apos; ,
  !ISNEW() &amp;&amp; text(PRIORVALUE(leaseworks__Status__c))==&apos;Active&apos; &amp;&amp; text(leaseworks__Status__c) ==&apos;Active&apos;
   )
)</errorConditionFormula>
    <errorMessage>You cannot create/modify Depreciation Schedule in Active Status.</errorMessage>
</ValidationRule>
