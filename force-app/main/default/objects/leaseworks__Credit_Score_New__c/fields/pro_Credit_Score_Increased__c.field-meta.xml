<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pro_Credit_Score_Increased__c</fullName>
    <description>Evaluates as true if the current credit score is higher than the previous credit score.</description>
    <formula>IF(  pro_Credit_Score_Strength__c  &gt;  pro_Previous_Credit_Score_Strength__c , True, False)</formula>
    <label>Credit Score Increased</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
