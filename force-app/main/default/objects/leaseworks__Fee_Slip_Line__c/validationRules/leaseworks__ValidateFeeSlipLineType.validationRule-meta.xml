<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__ValidateFeeSlipLineType</fullName>
    <active>true</active>
    <description>If the Line Type is empty we are showing the validation</description>
    <errorConditionFormula>!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c &amp;&amp;  ISBLANK( TEXT( leaseworks__Line_Type__c ) )</errorConditionFormula>
    <errorDisplayField>leaseworks__Line_Type__c</errorDisplayField>
    <errorMessage>Please select line type for the adjustment.</errorMessage>
</ValidationRule>
