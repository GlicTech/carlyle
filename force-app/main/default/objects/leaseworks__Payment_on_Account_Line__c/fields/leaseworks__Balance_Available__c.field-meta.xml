<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>leaseworks__Balance_Available__c</fullName>
    <deprecated>false</deprecated>
    <externalId>false</externalId>
    <formula>IF( OR(ISPICKVAL(leaseworks__Status__c,&#39;Declined&#39;),ISPICKVAL(leaseworks__Status__c,&#39;Cancelled&#39;)),0, leaseworks__Payment_on_Account_Amount__c  -  leaseworks__Amount_Applied__c -  leaseworks__Amount_Refunded__c )</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Remaining balance available on this Payment on Account after offsets and refunds.</inlineHelpText>
    <label>Balance Available</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
