    <formulas>
        <description>This field shortens the Name to 80 characters</description>
        <name>UpdMRShareName</name>
        <dataType>String</dataType>
        <expression>IF(
  LEN({!$Record.leaseworks__Assembly_MR_Info__r.Name} +  &apos; - &apos;  + {!$Record.leaseworks__Assembly__c} + &apos; - &apos; + {!$Record.leaseworks__Maintenance_Event_Name__c}) &gt; 80,
  LEFT({!$Record.leaseworks__Assembly_MR_Info__r.Name} + &apos; - &apos; + {!$Record.leaseworks__Assembly__c} + &apos; - &apos; + {!$Record.leaseworks__Maintenance_Event_Name__c}, 77) + &apos;...&apos;,
  {!$Record.leaseworks__Assembly_MR_Info__r.Name} + &apos; - &apos; + {!$Record.leaseworks__Assembly__c} + &apos; - &apos; + {!$Record.leaseworks__Maintenance_Event_Name__c}
)</expression>
    </formulas>
