    <decisions>
        <name>Add_Or_Remove_User_From_Partial_Permission_Set</name>
        <label>Add Or Remove User From Partial Permission Set</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Add_To_Partial_Permission_Set</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_User_Already_Assigned_Partial_Permission_Set</targetReference>
            </connector>
            <label>Add To Partial Permission Set</label>
        </rules>
        <rules>
            <name>Remove_From_Partial_Permission_Set</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_User_Assigned_To_Partial_Permission_Set</targetReference>
            </connector>
            <label>Remove From Partial Permission Set</label>
        </rules>
    </decisions>
    <decisions>
        <description>For users who are active and on the profile Technical Admin, Technical User: Add to permission set. 

All other users: Remove from permission set.</description>
        <name>Add_or_Remove_User_From_Permission_Set</name>
        <label>Add or Remove User From Permission Set?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Add_To_Permission_Set</name>
            <conditionLogic>1 AND (2 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical User</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical Admin</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_User_Already_Assigned_To_Permission_Set</targetReference>
            </connector>
            <label>Add To Permission Set</label>
        </rules>
        <rules>
            <name>Remove_From_Permission_Set</name>
            <conditionLogic>1 OR (2 AND 3)</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Technical User</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_User_Assigned_To_Permission_Set</targetReference>
            </connector>
            <label>Remove From Permission Set</label>
        </rules>
    </decisions>
    <decisions>
        <description>Choose which (if any) permission set to assign/deassign based on the user&#39;s profile</description>
        <name>Assign_Full_Access_or_Partial_Access</name>
        <label>Assign Full Access or Partial Access?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Full_Access</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical User</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical Admin</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Project_Consultant_Full_Access_Permission_Set</targetReference>
            </connector>
            <label>Full Access</label>
        </rules>
        <rules>
            <name>Partial_Access</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical Consultant</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical Senior Consultant</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical Senior Consultant (Access Persons)</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Project_Consultant_Partial_Access_Permission_Set</targetReference>
            </connector>
            <label>Partial Access</label>
        </rules>
    </decisions>
    <decisions>
        <description>If running user&#39;s email ends with &#39;invalid&#39; then skip sending an email as this would throw an error</description>
        <name>Is_Running_User_s_Email_Valid</name>
        <label>Is Running User&#39;s Email Valid?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Email_Running_User</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Email_Valid</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$User.Email</leftValueReference>
                <operator>EndsWith</operator>
                <rightValue>
                    <stringValue>invalid</stringValue>
                </rightValue>
            </conditions>
            <label>Yes - Email Valid</label>
        </rules>
    </decisions>
