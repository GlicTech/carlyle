<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>To check for the Disable triggers/Disable Flows flag on the custom setting.</description>
        <name>Check_Custom_Setting</name>
        <label>Check Custom Setting</label>
        <locationX>380</locationX>
        <locationY>287</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Check_Trigger_and_WFs</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>CheckTriggers</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>CheckWFs</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Interest_Calculator_Parameter</targetReference>
            </connector>
            <label>Check Trigger and WFs</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_records</name>
        <label>Check records</label>
        <locationX>182</locationX>
        <locationY>503</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Check_Record_is_null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Interest_Calculator_Parameter.Compound_Interest__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Interest_Calculator_Parameter.Grace_Period__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Interest_Calculator_Parameter.Interest_Base__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Interest_Calculator_Parameter.Interest_Calculation_Method__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Lease_from_Interest_Calculator_Parameter</targetReference>
            </connector>
            <label>Check Record is null</label>
        </rules>
    </decisions>
    <description>When a new lease creates, update Interest Base, Interest Calculator Parameter Name, Grace Period &amp; Compound Interest values from Interest Calculator Parameter</description>
    <environments>Default</environments>
    <formulas>
        <name>CheckTriggers</name>
        <dataType>Boolean</dataType>
        <expression>{!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}</expression>
    </formulas>
    <formulas>
        <name>CheckWFs</name>
        <dataType>Boolean</dataType>
        <expression>{!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}</expression>
    </formulas>
    <interviewLabel>Update Lease from Interest Calculator Parameter {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Lease from Interest Calculator Parameter</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Interest_Calculator_Parameter</name>
        <label>Get Interest Calculator Parameter</label>
        <locationX>182</locationX>
        <locationY>395</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Check_records</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>MasterLabel</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Setup</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Interest_Calculator_Parameter__mdt</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Lease_from_Interest_Calculator_Parameter</name>
        <label>Update Lease from Interest Calculator Parameter</label>
        <locationX>50</locationX>
        <locationY>611</locationY>
        <inputAssignments>
            <field>leaseworks__Compound_Interest__c</field>
            <value>
                <elementReference>Get_Interest_Calculator_Parameter.Compound_Interest__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Grace_Period_After_Due_Date__c</field>
            <value>
                <elementReference>Get_Interest_Calculator_Parameter.Grace_Period__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Interest_Base__c</field>
            <value>
                <elementReference>Get_Interest_Calculator_Parameter.Interest_Base__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Interest_Calculation_Method__c</field>
            <value>
                <elementReference>Get_Interest_Calculator_Parameter.Interest_Calculation_Method__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Custom_Setting</targetReference>
        </connector>
        <object>leaseworks__Lease__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
