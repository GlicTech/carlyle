<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <description>Before save flow, sets the Claim Name field to: Account Name + Assembly Name + Assembly Event Type + Induction Date</description>
    <environments>Default</environments>
    <formulas>
        <description>Concatenation of the following fields: Account Name, Assembly Type, Event Type, Induction Date</description>
        <name>f_ConcatenatedName</name>
        <dataType>String</dataType>
        <expression>{!$Record.leaseworks__Supplemental_Rent__r.leaseworks__Lease__r.leaseworks__Operator_New__r.Name}+ &#39; - &#39; +{!$Record.leaseworks__Assembly__r.Name} + &#39; - &#39; + TEXT({!$Record.leaseworks__Event__r.leaseworks__Event_Type__c})</expression>
    </formulas>
    <interviewLabel>Prodigy - Claim - Set Concatenated Name {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - Claim - Set Concatenated Name</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Disable_Triggers</name>
        <label>Disable Triggers</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Concatenated_Name</targetReference>
        </connector>
        <inputAssignments>
            <field>leaseworks__Disable_All_Triggers__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <object>leaseworks__LeaseWorksSettings__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Enable_Triggers</name>
        <label>Enable Triggers</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>leaseworks__Disable_All_Triggers__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <object>leaseworks__LeaseWorksSettings__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Set_Concatenated_Name</name>
        <label>Set Concatenated Name</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Enable_Triggers</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Error_While_updating_flow</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>f_ConcatenatedName</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Disable_Triggers</targetReference>
        </connector>
        <filterFormula>AND(
  NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}),
  NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c})
)</filterFormula>
        <object>leaseworks__Claims__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
