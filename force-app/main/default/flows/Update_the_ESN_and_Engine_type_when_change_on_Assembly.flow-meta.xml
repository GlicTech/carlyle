        ISCHANGED({!$Record.leaseworks__Engine_Type_GP__c}) &amp;&amp; 
        (ISPICKVAL({!$Record.leaseworks__Type__c}, &#39;Engine 1&#39;) || ISPICKVAL({!$Record.leaseworks__Type__c}, &#39;Engine 2&#39;)),
        ISCHANGED({!$Record.leaseworks__Asset__r.Id}) &amp;&amp; 
        (ISPICKVAL({!$Record.leaseworks__Type__c}, &#39;Engine 1&#39;) || ISPICKVAL({!$Record.leaseworks__Type__c}, &#39;Engine 2&#39;))
    ),
    NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}),
    NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c})
)</filterFormula>
