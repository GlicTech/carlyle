        <filterFormula>AND(
    OR(
        ISPICKVAL({!$Record__Prior.leaseworks__Type__c}, &#39;Engine 1&#39;) || ISPICKVAL({!$Record__Prior.leaseworks__Type__c}, &#39;Engine 2&#39;),
