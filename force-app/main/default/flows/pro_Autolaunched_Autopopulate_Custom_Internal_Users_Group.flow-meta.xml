    <decisions>
        <description>If a Group Member record exists for the running user, it should be deleted.</description>
        <name>Was_A_Group_Member_Record_Found_For_The_Triggering_User</name>
        <label>Was A Group Member Record Found For The Triggering User?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Group_Member_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Search_For_Current_Assignment_To_Group.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Group_Member_Record</targetReference>
            </connector>
            <label>Yes - Group Member Found</label>
        </rules>
    </decisions>
    <description>Whenever a user is created or updated, and is on one of the listed profile, this flow automatically adds the user to the public group Custom Internal Users. If user is on any other profile, the flow searches for membership to the group and, if found, removes that membership. 

Carlyle Commercial, Compliance, Contracts, Credit, Executive, Finance, Investment &amp; Strategy, Lease Management, Legal, Portfolio &amp; Fund, Sys Admin, Tech Admin, Tech Consultant, Tech Senior Consultant, Tech User</description>
    <environments>Default</environments>
    <interviewLabel>Autolaunched - Autopopulate Custom Internal Users Group {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunched - Autopopulate Custom Internal Users Group</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Group_Member_Record_For_Triggering_User</name>
        <label>Create Group Member Record For Triggering User</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>GroupId</field>
            <value>
                <elementReference>Get_Custom_All_Internal_Users_Group.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>UserOrGroupId</field>
            <value>
                <elementReference>varTriggeringUser.Id</elementReference>
            </value>
        </inputAssignments>
        <object>GroupMember</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordDeletes>
        <name>Delete_Group_Member_Record</name>
        <label>Delete Group Member Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>Search_For_Current_Assignment_To_Group</inputReference>
    </recordDeletes>
    <recordLookups>
        <name>Get_Custom_All_Internal_Users_Group</name>
        <label>Get Custom All Internal Users Group</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Search_For_Current_Assignment_To_Group</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>pro_Custom_Internal_Users</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Group</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Search for Group Member records linking triggering user to Custom Internal Users Group</description>
        <name>Search_For_Current_Assignment_To_Group</name>
        <label>Search For Current Assignment To Group</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Include_User_In_Custom_All_Internal_Users_Group</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>GroupId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Custom_All_Internal_Users_Group.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>UserOrGroupId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTriggeringUser.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>GroupMember</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Custom_All_Internal_Users_Group</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <description>The users record from whose trigger this flow was called.</description>
        <name>varTriggeringUser</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>User</objectType>
    </variables>
</Flow>
