<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <decisions>
        <name>Was_Open_Target_Found</name>
        <label>Was Open Target Found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Clear_Target_Information_From_Asset</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Open Target</defaultConnectorLabel>
        <rules>
            <name>Yes_Open_Target_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Open_Target_Related_To_The_Asset.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Target_Information_On_Asset</targetReference>
            </connector>
            <label>Yes - Open Target Found</label>
        </rules>
    </decisions>
    <description>Whenever a Target is updated with changes to either the Progress or Target End Date, this flow runs and maps these changes to corresponding fields on the related Asset</description>
    <environments>Default</environments>
    <interviewLabel>Autolaunched - Update Target Information On Asset {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunched - Update Target Information On Asset</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Open_Target_Related_To_The_Asset</name>
        <label>Get Open Target Related To The Asset</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Was_Open_Target_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Asset__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Triggering_Target.pro_Asset__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_Progress__c</field>
            <operator>Contains</operator>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>pro_Asset_Target_Audit__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
