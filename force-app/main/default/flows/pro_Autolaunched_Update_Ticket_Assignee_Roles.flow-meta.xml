<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <assignments>
        <name>Set_Clear_Contract_Manager_Variable_To_True</name>
        <label>Set Clear Contract Manager Variable To True</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varClearContractManager</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Does_Deleted_Assignee_Match_Current_RA</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Clear_RA_Variable_To_True</name>
        <label>Set Clear RA Variable To True</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varClearRA</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Deleted_Assignees</targetReference>
        </connector>
    </assignments>
    <collectionProcessors>
        <name>Filter_To_RA_and_Contract_Manager_Assignees</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter To RA and Contract Manager Assignees</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Filter_To_RA_and_Contract_Manager_Assignees</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>varAssigneesToDelete</collectionReference>
        <conditionLogic>or</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_To_RA_and_Contract_Manager_Assignees.pro_Assignee_Roles__c</leftValueReference>
            <operator>Contains</operator>
            <rightValue>
                <stringValue>RA</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_To_RA_and_Contract_Manager_Assignees.pro_Assignee_Roles__c</leftValueReference>
            <operator>Contains</operator>
            <rightValue>
                <stringValue>Contract Manager</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>RA_Or_Contract_Manager_Deleted</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Create_Assignee_or_Delete_Assignees</name>
        <label>Create Assignee or Delete Assignees?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Filter_To_RA_and_Contract_Manager_Assignees</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Delete Assignees</defaultConnectorLabel>
        <rules>
            <name>Create_an_Assignee</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>varAssigneesToDelete</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varAssigneesToDelete</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Assignee_Role_Lookups_On_Ticket</targetReference>
            </connector>
            <label>Create an Assignee</label>
        </rules>
    </decisions>
    <decisions>
        <name>Does_Deleted_Assignee_Match_Current_Contract_Manager</name>
        <label>Does Deleted Assignee Match Current Contract Manager</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Does_Deleted_Assignee_Match_Current_RA</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Contract_Manager_Match</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Deleted_Assignees.pro_Assigned_To__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_Deleted_Assignees.pro_Ticket__r.pro_Contract_Manager__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Clear_Contract_Manager_Variable_To_True</targetReference>
            </connector>
            <label>Yes - Contract Manager Match</label>
        </rules>
    </decisions>
    <decisions>
        <name>Does_Deleted_Assignee_Match_Current_RA</name>
        <label>Does Deleted Assignee Match Current RA?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Deleted_Assignees</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_RA_Match</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Deleted_Assignees.pro_Assigned_To__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_Deleted_Assignees.pro_Ticket__r.pro_RA__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Clear_RA_Variable_To_True</targetReference>
            </connector>
            <label>Yes - RA Match</label>
        </rules>
    </decisions>
    <decisions>
        <name>RA_Or_Contract_Manager_Deleted</name>
        <label>RA Or Contract Manager Deleted?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_RA_or_Contract_Manager_Deleted</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Filter_To_RA_and_Contract_Manager_Assignees</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Filter_To_RA_and_Contract_Manager_Assignees</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Deleted_Assignees</targetReference>
            </connector>
            <label>Yes - RA or Contract Manager Deleted</label>
        </rules>
    </decisions>
    <decisions>
        <name>Were_Current_Contract_Manager_Or_RA_Deleted</name>
        <label>Were Current Contract Manager Or RA Deleted?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Contract_Manager_Or_RA_Deleted</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>varClearContractManager</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varClearRA</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Contract_Manager_And_RA_Field_Values</targetReference>
            </connector>
            <label>Yes - Contract Manager Or RA Deleted</label>
        </rules>
    </decisions>
    <description>Whenever a Ticket Assignee record is created or deleted with an Assignee Role populated, this flow runs to update roles on other Assignees and populate lookups to Assignees on the Ticket record.</description>
    <environments>Default</environments>
    <formulas>
        <description>If the triggering Ticket Assignee&apos;s role is Contract Manager, this returnes the id of the related user. Otherwise, returns the existing value in the Ticket&apos;s Contract Manager field.</description>
        <name>f_ContractManagerNewAssigneeOrExistingTicketAssignee</name>
        <dataType>String</dataType>
        <expression>IF(INCLUDES({!varTicketAssigneeToCreate.pro_Assignee_Roles__c},  &apos;Contract Manager&apos;) , {!varTicketAssigneeToCreate.pro_Assigned_To__c}, {!varTicketAssigneeToCreate.pro_Ticket__r.pro_Contract_Manager__c})</expression>
    </formulas>
    <formulas>
        <name>f_CurrentContractManagerOrNull</name>
        <dataType>String</dataType>
        <expression>IF({!varClearContractManager} = True, null, {!varTriggeringTicket.pro_Contract_Manager__c})</expression>
    </formulas>
    <formulas>
        <name>f_CurrentRaOrNull</name>
        <dataType>String</dataType>
        <expression>IF({!varClearRA} = True, null, {!varTriggeringTicket.pro_RA__c})</expression>
    </formulas>
    <formulas>
        <description>If the triggering Ticket Assignee&apos;s role is RA, this returned the id of the related user. Otherwise, returns the existing value in the Ticket&apos;s RA field.</description>
        <name>f_RaNewAssigneeOrExistingTicketAssignee</name>
        <dataType>String</dataType>
        <expression>IF(INCLUDES({!varTicketAssigneeToCreate.pro_Assignee_Roles__c}, &apos;RA&apos;), {!varTicketAssigneeToCreate.pro_Assigned_To__c}, {!varTicketAssigneeToCreate.pro_Ticket__r.pro_RA__c})</expression>
    </formulas>
    <interviewLabel>Autolaunched - Update Ticket Assignee Roles {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunched - Update Ticket Assignee Roles</label>
    <loops>
        <name>Loop_Deleted_Assignees</name>
        <label>Loop Deleted Assignees</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Filter_To_RA_and_Contract_Manager_Assignees</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Does_Deleted_Assignee_Match_Current_Contract_Manager</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Were_Current_Contract_Manager_Or_RA_Deleted</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Contract_Manager_And_RA_Field_Values</name>
        <label>Set Contract Manager And RA Field Values</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTriggeringTicket.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>pro_Contract_Manager__c</field>
            <value>
                <elementReference>f_CurrentContractManagerOrNull</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>pro_RA__c</field>
            <value>
                <elementReference>f_CurrentRaOrNull</elementReference>
            </value>
        </inputAssignments>
        <object>pro_Ticket__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Assignee_Role_Lookups_On_Ticket</name>
        <label>Update Assignee Role Lookups On Ticket</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTicketAssigneeToCreate.pro_Ticket__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>pro_Contract_Manager__c</field>
            <value>
                <elementReference>f_ContractManagerNewAssigneeOrExistingTicketAssignee</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>pro_RA__c</field>
            <value>
                <elementReference>f_RaNewAssigneeOrExistingTicketAssignee</elementReference>
            </value>
        </inputAssignments>
        <object>pro_Ticket__c</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_Assignee_or_Delete_Assignees</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <name>currentItem_Filter_To_RA_and_Contract_Manager_Assignees</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>pro_Ticket_Assignee__c</objectType>
    </variables>
    <variables>
        <name>varAssigneesToDelete</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>pro_Ticket_Assignee__c</objectType>
    </variables>
    <variables>
        <name>varClearContractManager</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <name>varClearRA</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <name>varTicketAssigneeToCreate</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>pro_Ticket_Assignee__c</objectType>
    </variables>
    <variables>
        <name>varTriggeringTicket</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>pro_Ticket__c</objectType>
    </variables>
</Flow>
