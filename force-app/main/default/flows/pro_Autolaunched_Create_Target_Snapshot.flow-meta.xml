        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Create the header object under which to group Asset Target Snapshot Items</description>
        <name>Create_Asset_Target_Snapshot</name>
        <label>Create Asset Target Snapshot</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
