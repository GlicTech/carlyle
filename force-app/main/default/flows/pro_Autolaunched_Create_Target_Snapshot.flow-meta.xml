    <decisions>
        <name>Has_A_Snapshot_Already_Been_Created_Today</name>
        <label>Has A Snapshot Already Been Created Today?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_Asset_Target_Snapshot</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Existing Target Snapshot For Today</defaultConnectorLabel>
        <rules>
            <name>Yes_Existing_Target_Snapshot_For_Today</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Search_For_Asset_Target_Snapshot_Already_Made_Today.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Existing_Asset_Target_Snapshot_To_Variable</targetReference>
            </connector>
            <label>Yes - Existing Target Snapshot For Today</label>
        </rules>
    </decisions>
    <description>Flow called inside Target Management Console flow when the Target Snapshot button is clicked. This flow takes the records from the Target datatable and creates a snapshot of these records.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_CurrentDateText</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Flow.CurrentDate})</expression>
    </formulas>
    <formulas>
        <name>f_TargetSnapshotName</name>
        <dataType>String</dataType>
        <expression>{!varTargetYear} + &#39; Target Snapshot:  &#39; + TEXT({!$Flow.CurrentDate})</expression>
    </formulas>
    <interviewLabel>Autolaunched - Create Target Snapshot {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunched - Create Target Snapshot</label>
    <loops>
        <name>Loop_Through_ATA_Records</name>
        <label>Loop Through ATA Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>varAssetTargetAudits</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Build_Up_Snapshot_Item_Variable</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Create_Asset_Target_Snapshot_Items</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
