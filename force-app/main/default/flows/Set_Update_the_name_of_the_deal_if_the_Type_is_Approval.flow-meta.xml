     TEXT(MONTH(DATEVALUE({!$Record.CreatedDate})))
  ) &amp; &quot;/&quot; &amp; TEXT(YEAR(DATEVALUE({!$Record.CreatedDate}))),
  
  TEXT({!$Record.Approval_Type__c}) &amp; &quot; - &quot; &amp; 
  {!$Record.leaseworks__Counter_Party__r.Name} &amp; &quot; - &quot; &amp;
  IF(MONTH(DATEVALUE({!$Record.CreatedDate})) &lt; 10, 
     &quot;0&quot; &amp; TEXT(MONTH(DATEVALUE({!$Record.CreatedDate}))), 
     TEXT(MONTH(DATEVALUE({!$Record.CreatedDate})))
  ) &amp; &quot;/&quot; &amp; TEXT(YEAR(DATEVALUE({!$Record.CreatedDate})))
)</expression>
