    <formulas>
        <name>NameForTheDeal</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK(TEXT({!$Record.Approval_Type__c})),
  {!$Record.leaseworks__Counter_Party__r.Name} &amp; &quot; - &quot; &amp;
  IF(MONTH(DATEVALUE({!$Record.CreatedDate})) &lt; 10, 
