    </assignments>
    <decisions>
        <name>Should_Role_Be_Brought_Over_From_Account_Team</name>
        <label>Should Role Be Brought Over From Account Team?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Deal_Team_Roles</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Role_To_Be_Brought_From_Account</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>f_AssigneeFromAccountTeam</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Invalid Role</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Build_Up_Deal_Team_Variables</targetReference>
            </connector>
            <label>Yes - Role To Be Brought From Account</label>
        </rules>
    </decisions>
    <description>When called, this flow looks up Deal Team Mapping records for Sale - Novation as a reference for Member Roles. Then, for each member role, creates as a Deal Team record assigned to the user who holds that role on the Account Team</description>
    <environments>Default</environments>
    <formulas>
        <name>f_AssigneeFromAccountTeam</name>
        <dataType>String</dataType>
        <expression>CASE(
    {!Loop_Deal_Team_Roles},
    &quot;Contracts&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Contracts__c},
    &quot;Credit&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Credit__c},
    &quot;Investment &amp; Strategy&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Investment_Strategy__c},
    &quot;Legal&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Legal__c},
    &quot;Marketing&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.OwnerId},
    &quot;Compliance&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Compliance__c},
    &quot;Portfolio Management&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Portfolio_Fund_Management__c},
    &quot;Powerplant&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Powerplant__c},
    &quot;Lease Management&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Receivables__c},
    &quot;Tax&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Tax__c},
    &quot;Technical&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Technical__c},
    &quot;Trading&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Trading__c},
    &quot;Invalid Role&quot;
)</expression>
    </formulas>
    <interviewLabel>Autolaunched - Create Deal Teams To Mirror Account Team {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunched - Create Deal Teams To Mirror Account Team</label>
    <loops>
        <name>Loop_Deal_Team_Roles</name>
