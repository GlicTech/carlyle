    <assignments>
        <name>Build_Up_Deal_Team_Variables</name>
        <label>Build Up Deal Team Variables</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varDealTeamToCreate.leaseworks__Marketing_Activity__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>varTriggeringDeal.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varDealTeamToCreate.pro_Member_Role__c</assignToReference>
