                <elementReference>Loop_Deal_Team_Roles</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varDealTeamToCreate.leaseworks__Assigned_To__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>f_AssigneeFromAccountTeam</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varDealTeamToCreate.Name</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Deal_Team_Roles</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varDealTeamsToCreate</assignToReference>
            <operator>Add</operator>
