    <decisions>
        <name>Is_current_user_different_from_task_creator</name>
        <label>Is current user different from task creator?</label>
        <locationX>336</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>The Same</defaultConnectorLabel>
        <rules>
            <name>Different</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$User.Id</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>f_TruncatedTaskCreatorId</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Entity_Definition_For_WhatId</targetReference>
            </connector>
            <label>Different</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_The_Task_Related_To_A_Deal</name>
        <label>Is The Task Related To A Deal?</label>
        <locationX>182</locationX>
        <locationY>539</locationY>
        <defaultConnector>
            <targetReference>Assign_Creator_Email_To_Collection</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Related_To_A_Deal</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Entity_Definition_For_WhatId.Label</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Deal</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Related_Deal</targetReference>
            </connector>
            <label>Yes- Related To A Deal</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>f_DealTitleAndNameOrBlank</name>
        <dataType>String</dataType>
        <expression>IF(
    NOT(ISBLANK({!Get_Related_Deal.Id})),
    &#39;Deal: &#39; &amp; {!Get_Related_Deal.Name} &amp; BR(),
    &#39;&#39;
)</expression>
    </formulas>
    <formulas>
        <name>f_KeyPrefix</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Record.WhatId}, 3)</expression>
    </formulas>
    <formulas>
        <name>f_RelatedToRecordNameOrPlaceholderText</name>
        <dataType>String</dataType>
        <expression>IF({!$Record.leaseworks__Related_Record_Name__c} != Null, {!$Record.leaseworks__Related_Record_Name__c} , &#39;No Related Record&#39;)</expression>
    </formulas>
    <formulas>
        <name>f_TruncatedTaskCreatorId</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Record.CreatedById}, LEN({!$Record.CreatedById}) - 3)</expression>
    </formulas>
    <interviewLabel>Prodigy - Task Completed Email Creator {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - Task Completed Email Creator</label>
    <processMetadataValues>
