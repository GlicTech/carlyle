    <apiVersion>63.0</apiVersion>
    <assignments>
        <name>Assign_Creator_Email_To_Collection</name>
        <label>Assign Creator Email To Collection</label>
        <locationX>182</locationX>
        <locationY>839</locationY>
        <assignmentItems>
            <assignToReference>varUserEmailCollection</assignToReference>
            <operator>Add</operator>
