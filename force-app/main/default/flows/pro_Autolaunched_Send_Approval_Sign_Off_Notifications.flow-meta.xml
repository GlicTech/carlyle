    <description>Flow gets called once full LOI or Documentation approval is achieved on a Deal. The flow retrieves LOI or Documentation sign off user from CMDT settings and emails these users prompting them to review the Deal.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_LoiOrDocumentation</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!varTriggeringDeal.leaseworks__Deal_Status__c} ) = &#39;LOI Signed&#39;, &#39;LOI&#39;, &#39;Documentation&#39;)</expression>
    </formulas>
    <formulas>
        <name>f_NotificationTitle</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!varTriggeringDeal.leaseworks__Deal_Status__c}) = &#39;LOI Signed&#39;, &#39;[&#39; + {!varTriggeringDeal.Name} + &#39;] LOI Approval Completed&#39; , &#39;[&#39; + {!varTriggeringDeal.Name} + &#39;] Documentation Approval Completed&#39; )</expression>
    </formulas>
