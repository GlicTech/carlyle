    <textTemplates>
        <name>tt_EmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Dear User,&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The Deal [{!varTriggeringDeal.Name}] has received full {!f_LoiOrDocumentation} approval.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Deal Details:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Deal Status:&lt;/strong&gt;{!varTriggeringDeal.leaseworks__Deal_Status__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Deal Type: &lt;/strong&gt;{!varTriggeringDeal.leaseworks__Deal_Type__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Asset Type &amp;amp; Quantity: &lt;/strong&gt;{!varTriggeringDeal.leaseworks__Aircraft_Type_Qty_List__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Deal Rep: &lt;/strong&gt;{!varTriggeringDeal.leaseworks__Marketing_Representative_User__r.FirstName} &lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;{!varTriggeringDeal.leaseworks__Marketing_Representative_User__r.LastName}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Description:&lt;/strong&gt; {!varTriggeringDeal.leaseworks__Description__c}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;You can view the full details and take action by clicking the link: &lt;a href=&quot;https://leaseworks-carlyle.my.salesforce-setup.com/{!varTriggeringDeal.Id}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;View Deal in Salesforce&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Kind regards,&lt;/p&gt;&lt;p&gt;Salesforce System Notification&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;em&gt;This message was generated automatically. For assistance, please contact your Salesforce administrator.&lt;/em&gt;&lt;/p&gt;</text>
    </textTemplates>
