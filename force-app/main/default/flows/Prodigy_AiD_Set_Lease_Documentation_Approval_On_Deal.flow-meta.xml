        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_100</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.pro_Lease_Documentation_Approval_per__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>100.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Related_AiDs</targetReference>
            </connector>
            <label>Yes - 100%</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Lease_Documentation_100_Approved_For_All_AiDs</name>
        <label>Is Lease Documentation 100% Approved For All AiDs?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_100_Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Filter_For_100_Lease_Documentation_Approval</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Full_Documentation_Approval_Complete_On_Deal</targetReference>
            </connector>
            <label>Yes - 100% Approved</label>
        </rules>
    </decisions>
    <description>Once Lease Documentation Approval percentage reaches 100% on an AiD, check all other AiDs under the deal. If they are all at 100%, check the flag Full Documentation Approval Achieved? on the Deal record.</description>
    <environments>Default</environments>
