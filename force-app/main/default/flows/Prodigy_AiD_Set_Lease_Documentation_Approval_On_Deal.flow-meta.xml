        <conditions>
            <leftValueReference>currentItem_Filter_For_100_Lease_Documentation_Approval.pro_Lease_Documentation_Approval_per__c</leftValueReference>
            <operator>NotEqualTo</operator>
            <rightValue>
                <numberValue>100.0</numberValue>
