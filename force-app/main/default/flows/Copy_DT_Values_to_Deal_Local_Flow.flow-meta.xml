    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_User</targetReference>
        </connector>
        <filterFormula>AND(
    NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}),
    NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}),
    NOT(ISBLANK({!$Record.leaseworks__Marketing_Activity__c})),
    OR({!$Record.Name}=&#39;Contracts&#39;,  {!$Record.Name}=&#39;Legal&#39;),
    OR(
        AND(
            ISNEW(),
            NOT(ISBLANK({!$Record.leaseworks__Assigned_To__c}))
        ),
        AND(
            ISCHANGED({!$Record.leaseworks__Assigned_To__c})
        )
    )
)</filterFormula>
