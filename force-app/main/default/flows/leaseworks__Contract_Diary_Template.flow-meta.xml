<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <decisions>
        <name>Contractual_Redelivery_date_based_on_Redelivery_Terms</name>
        <label>Contractual Redelivery date based on Redelivery Terms</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.leaseworks__Redelivery_Terms__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Lease Term Driven</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Delivery_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Contractual_Redelivery_date</targetReference>
            </connector>
            <label>True</label>
        </rules>
    </decisions>
    <description>A new flow can be created from this flow template and the following changes can be made:
1. Triggering object
2. Object API Name on Platform Event

- Rule to kick off when Contract: Redelivery Terms == Lease Term Driven AND Contract: Delivery Date != null</description>
    <environments>Default</environments>
    <formulas>
        <name>Contractual_Redelivery_Date_Formula</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL({!$Record.leaseworks__Lease_Term_in_Months__c}),{!$Record.leaseworks__Delivery_Date__c}, ADDMONTHS({!$Record.leaseworks__Delivery_Date__c},{!$Record.leaseworks__Lease_Term_in_Months__c})-1 )</expression>
    </formulas>
    <interviewLabel>Contract Diary Template {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Contract Diary Template</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Raise_Platform_Event</name>
        <label>Raise Platform Event</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Contractual_Redelivery_date_based_on_Redelivery_Terms</targetReference>
        </connector>
        <inputAssignments>
            <field>leaseworks__Contract_ID__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Object_API_Name__c</field>
            <value>
                <stringValue>leaseworks__Lease__c</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Record_ID__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <object>leaseworks__AsyncManageContractDiary__e</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordUpdates>
        <name>Update_Contractual_Redelivery_date</name>
        <label>Update Contractual Redelivery date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>leaseworks__Contractual_Redelivery_Date__c</field>
            <value>
                <elementReference>Contractual_Redelivery_Date_Formula</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Raise_Platform_Event</targetReference>
        </connector>
        <filterFormula>AND({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}==FALSE,{!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}==FALSE)</filterFormula>
        <object>leaseworks__Lease__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
