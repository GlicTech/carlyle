    <description>Flow flags &#39;In Fleet - Available&#39; Assets with associated Assembly Utilizations in the past three months showing as 0 for flight hours or flights cycles.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_TodayMinus2Months</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS({!$Flow.CurrentDate}, -2)</expression>
    </formulas>
    <formulas>
        <name>f_TodayMinusOneMonth</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS({!$Flow.CurrentDate}, -1)</expression>
    </formulas>
    <formulas>
        <name>f_TodayMinusThreeMonths</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS({!$Flow.CurrentDate}, -3)</expression>
    </formulas>
