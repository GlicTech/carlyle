<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_BAC_Approval_Complete</name>
        <label>Assign BAC Approval Complete</label>
        <locationX>50</locationX>
        <locationY>395</locationY>
        <assignmentItems>
            <assignToReference>$Record.BAC_Approval_Complete__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Assign_BAC_Approval_Date</name>
        <label>Assign BAC Approval Date</label>
        <locationX>314</locationX>
        <locationY>395</locationY>
        <assignmentItems>
            <assignToReference>$Record.BAC_Approval_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>pro_Which_Field_To_Update</name>
        <label>Which Field To Update</label>
        <locationX>314</locationX>
        <locationY>287</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>pro_Update_BAC_Complete_Checkbox</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.BAC_Approval_Complete__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.BAC_Approval_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_BAC_Approval_Complete</targetReference>
            </connector>
            <label>Update BAC Complete Checkbox</label>
        </rules>
        <rules>
            <name>pro_Update_BAC_Approval_Date</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.BAC_Approval_Complete__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.BAC_Approval_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_BAC_Approval_Date</targetReference>
            </connector>
            <label>Update BAC Approval Date</label>
        </rules>
    </decisions>
    <description>This record triggered flow runs in Before Save upon Update. It will run if one of the fields (BAC Approval Complete or BAC Approval Date) is Populated and the other isn&apos;t. The logic in the flow will ensure that the opposite field is automatically updated.</description>
    <environments>Default</environments>
    <interviewLabel>Asset In Deal - BAC Approval Checkpoint Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Asset In Deal - BAC Approval Checkpoint Flow (Before Save/Update)</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>188</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>pro_Which_Field_To_Update</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
OR(
ISBLANK({!$Record.BAC_Approval_Date__c}) &amp;&amp; {!$Record.BAC_Approval_Complete__c} = TRUE,
NOT(ISBLANK({!$Record.BAC_Approval_Date__c})) &amp;&amp; {!$Record.BAC_Approval_Complete__c} = FALSE
)
)</filterFormula>
        <object>leaseworks__Aircraft_Proposal__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
