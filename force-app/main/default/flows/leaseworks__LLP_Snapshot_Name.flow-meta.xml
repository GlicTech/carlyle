<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>This flow updates name field when LLP Utilization Snapshot record is created or updated.

Migrated from the: LLP Snapshot Name workflow rule</description>
    <environments>Default</environments>
    <formulas>
        <name>LLP_Util_Snapshot_NameFormula</name>
        <dataType>String</dataType>
        <expression>$Record.leaseworks__Assembly_Utilization_Snapshot_New__r.Name +&#39;_&#39;+  $Record.leaseworks__Component_Description__c</expression>
    </formulas>
    <interviewLabel>LLP Snapshot Name {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>LLP Snapshot Name</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Sets LLP Utilization Snapshot name as (&lt;Assembly Utilization Snapshot Name&gt;+&lt;Component Description&gt;)</description>
        <name>LLP_Util_Snapshot_Name</name>
        <label>LLP Util Snapshot Name</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>LLP_Util_Snapshot_NameFormula</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>LLP_Util_Snapshot_Name</targetReference>
        </connector>
        <filterFormula>!{!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}</filterFormula>
        <object>leaseworks__LLP_Utilization_Snapshot__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
