    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <filterFormula>AND(
NOT(ISBLANK({!$Record.leaseworks__Assigned_To__c})),
NOT(ISPICKVAL({!$Record.leaseworks__Marketing_Activity__r.leaseworks__Deal_Status__c}, &quot;Pipeline&quot;))
