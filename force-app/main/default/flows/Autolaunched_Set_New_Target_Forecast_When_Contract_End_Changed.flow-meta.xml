<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <environments>Default</environments>
    <interviewLabel>Autolaunched - Set New Target Forecast When Contract End Changed {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunched - Set New Target Forecast When Contract End Changed</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Latest_Asset_Target_Audit_Record</name>
        <label>Get Latest Asset Target Audit Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Update_Target_Information_On_Asset</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Contract__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTriggeringContract.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>pro_Asset_Target_Audit__c</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_New_Forecast_Target</name>
        <label>Get New Forecast Target</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Update_Forecast_Target</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Start_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>varTriggeringContract.leaseworks__Lease_End_Date_New__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_End_Date__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>varTriggeringContract.leaseworks__Lease_End_Date_New__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>pro_Target__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Forecast_Target</name>
        <label>Update Forecast Target</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Latest_Asset_Target_Audit_Record</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Contract__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTriggeringContract.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_Progress__c</field>
            <operator>Contains</operator>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>pro_Target_Forecast__c</field>
            <value>
                <elementReference>Get_New_Forecast_Target.Id</elementReference>
            </value>
        </inputAssignments>
        <object>pro_Asset_Target_Audit__c</object>
    </recordUpdates>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <start>
