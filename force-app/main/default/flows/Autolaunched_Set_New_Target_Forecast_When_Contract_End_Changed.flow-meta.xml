        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>pro_Autolaunched_Update_Target_Information_On_Asset</flowName>
        <inputAssignments>
            <name>varTriggeringTargetId</name>
            <value>
                <elementReference>Get_Latest_Asset_Target_Audit_Record.Id</elementReference>
            </value>
        </inputAssignments>
