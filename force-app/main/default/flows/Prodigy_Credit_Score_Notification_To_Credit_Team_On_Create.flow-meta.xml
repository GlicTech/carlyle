    <formulas>
        <name>f_HasCreditScoreChanged</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    AND(
        NOT(ISBLANK({!$Record.pro_Previous_Credit_Score_Record__c})),
        TEXT({!$Record.leaseworks__Internal_Credit_Score_Current_Year_New__c}) != 
        TEXT({!$Record.pro_Previous_Credit_Score_Record__r.leaseworks__Internal_Credit_Score_Current_Year_New__c})
    ),
    AND(
        NOT(ISBLANK({!$Record__Prior.Id})),
        TEXT({!$Record.leaseworks__Internal_Credit_Score_Current_Year_New__c}) != 
        TEXT({!$Record__Prior.leaseworks__Internal_Credit_Score_Current_Year_New__c})
    )
)</expression>
    </formulas>
    <formulas>
        <name>f_PriorCreditScoreORCreditScoreFromPreviousRecord</name>
        <dataType>String</dataType>
        <expression>IF({!$Record__Prior.Id} = Null, TEXT({!$Record.pro_Previous_Credit_Score_Record__r.leaseworks__Internal_Credit_Score_Current_Year_New__c}), TEXT({!$Record__Prior.leaseworks__Internal_Credit_Score_Current_Year_New__c}))</expression>
