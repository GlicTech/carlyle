    <description>Flow takes a list of Tickets, Assets and Assemblies as inputs, creates Asset on Ticket and Assembly on Ticket records and returns them in a collection.</description>
    <environments>Default</environments>
    <formulas>
        <description>Returns the Assembly Name with or without a leading comma. Used to create a comma-separated list of Assembly names.</description>
        <name>f_AssembliesToAttachNameFormat</name>
        <dataType>String</dataType>
        <expression>IF({!varAssembliesOnTicketNames} = Null,
     {!Loop_Assemblies.pro_Assembly_Name_And_Type__c},
     &apos;, &apos; + {!Loop_Assemblies.pro_Assembly_Name_And_Type__c}
)</expression>
    </formulas>
    <formulas>
        <description>Returns Asset Name with or without a comma to create a comma-separated list of Asset Names.</description>
        <name>f_AssetNameListFormat</name>
        <dataType>String</dataType>
        <expression>IF({!varAssetsToAttachNames} = Null,
     {!Loop_Assets.Name},
     &apos;, &apos; + {!Loop_Assets.Name}
)</expression>
    </formulas>
    <formulas>
        <description>Returns and Asset&apos;s serial number + transaction code with or without a comma to create a comma-separated list of Asset serial numbers and transaction codes</description>
        <name>f_AssetTransactionCodeListFormat</name>
        <dataType>String</dataType>
        <expression>IF({!varAssetTransactionCodes} = Null,
    {!Loop_Assets.leaseworks__MSN_Number__c} + &apos; - (&apos; + {!Loop_Assets.Transaction_Code__c}  + &apos;)&apos;,
     &apos;, &apos; +   {!Loop_Assets.leaseworks__MSN_Number__c} + &apos; - (&apos; + {!Loop_Assets.Transaction_Code__c}  + &apos;)&apos;
)</expression>
    </formulas>
    <formulas>
        <name>f_ContractsToAttachNameFormat</name>
        <dataType>String</dataType>
        <expression>IF({!varContractToAttachNames} = Null,
     {!Loop_Contracts.Name},
     &apos;, &apos; + {!Loop_Contracts.Name}
)</expression>
    </formulas>
