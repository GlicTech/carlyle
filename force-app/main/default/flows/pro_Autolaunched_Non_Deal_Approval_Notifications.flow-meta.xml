    <decisions>
        <name>Non_Deal_Approval_Submitted_Approved_Or_Rejected</name>
        <label>Non Deal Approval Submitted, Approved, Or Rejected?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Submitted</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringDeal.leaseworks__Deal_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Submitted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Main_Recipient_Users_Submitted</targetReference>
            </connector>
            <label>Submitted</label>
        </rules>
        <rules>
            <name>Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringDeal.leaseworks__Deal_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_CC_Recipient_Users_Approved</targetReference>
            </connector>
            <label>Approved</label>
        </rules>
        <rules>
            <name>Rejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringDeal.leaseworks__Deal_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Rejected</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Cc_Recipient_Users_Rejected</targetReference>
            </connector>
            <label>Rejected</label>
        </rules>
    </decisions>
    <description>Flow contains all logic for sending email notifications when a Non Deal Approval is submitted, rejected or approved. Sends a bell notification as a backup in case the email fails to send.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_EmailBodyBasedOnStatus</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!varTriggeringDeal.leaseworks__Deal_Status__c}) = &#39;Submitted&#39;, {!tt_ApprovalSubmittedEmailBody},
       IF(TEXT({!varTriggeringDeal.leaseworks__Deal_Status__c}) = &#39;Approved&#39;, {!tt_ApprovalGrantedEmailBody}, {!tt_ApprovalRejectedEmailBody}))</expression>
    </formulas>
    <formulas>
        <name>f_EmailSubject</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!varTriggeringDeal.leaseworks__Deal_Status__c}) = &#39;Submitted&#39;, &#39;[&#39; + {!varTriggeringDeal.Name} + &#39;] Submitted For Approval&#39;,
        IF(TEXT({!varTriggeringDeal.leaseworks__Deal_Status__c}) = &#39;Approved&#39;, &#39;[&#39; + {!varTriggeringDeal.Name} + &#39;] Approved&#39;, 
               &#39;[&#39; + {!varTriggeringDeal.Name} + &#39;] Approval Rejected&#39;))</expression>
    </formulas>
    <formulas>
        <name>f_NotificationTitle</name>
        <dataType>String</dataType>
        <expression>&#39;❗ [&#39; + {!varTriggeringDeal.Name} + &#39;] Notification Failed&#39;</expression>
    </formulas>
