<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <decisions>
        <name>Was_Extended_On_Date_Cleared</name>
        <label>Was Extended On Date Cleared?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_New_Target_Reached</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Extended On Populated</defaultConnectorLabel>
        <rules>
            <name>Yes_Extended_On_Date_Cleared</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringContract.leaseworks__Extended_On__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Open_Audit_Record</targetReference>
            </connector>
            <label>Yes - Extended On Date Cleared</label>
        </rules>
    </decisions>
    <description>When a Contract&#39;s Extended On date gets changed, this flow updates the &#39;Closed - Contract Extended&#39; Target record with a target based on the new Extended On date.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_ExtendedOnPlusAYear</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS( {!varTriggeringContract.leaseworks__Extended_On__c}, 12 )</expression>
    </formulas>
    <interviewLabel>Autolaunched - Contract Extended On Changed Update Target Reached {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunched - Contract Extended On Changed Update Target Reached</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordDeletes>
        <name>Delete_Open_Audit_Record</name>
        <label>Delete Open Audit Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Re_Open_Closed_Audit_Record</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Asset__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTriggeringContract.leaseworks__Aircraft__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_Progress__c</field>
            <operator>Contains</operator>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </filters>
        <object>pro_Asset_Target_Audit__c</object>
    </recordDeletes>
    <recordLookups>
        <name>Get_New_Target_Reached</name>
        <label>Get New Target Reached</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Update_Target_Audit_Record_s_Target_Reached_Forecast</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Start_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>f_ExtendedOnPlusAYear</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_End_Date__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>f_ExtendedOnPlusAYear</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>pro_Target__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Re_Open_Closed_Audit_Record</name>
        <label>Re-Open Closed Audit Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Asset__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTriggeringContract.leaseworks__Aircraft__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_Progress__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Achieved - Contract Extended</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>pro_Contract_Extended__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <object>pro_Asset_Target_Audit__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Target_Audit_Record_s_Target_Reached_Forecast</name>
        <label>Update Target Audit Record&#39;s Target Reached &amp; Forecast</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Contract__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varTriggeringContract.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_Progress__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Achieved - Contract Extended</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>pro_Target_Reached__c</field>
            <value>
                <elementReference>Get_New_Target_Reached.Id</elementReference>
            </value>
        </inputAssignments>
        <object>pro_Asset_Target_Audit__c</object>
    </recordUpdates>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Was_Extended_On_Date_Cleared</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <description>The Contract record whose trigger this flow was called from</description>
        <name>varTriggeringContract</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>leaseworks__Lease__c</objectType>
    </variables>
</Flow>
