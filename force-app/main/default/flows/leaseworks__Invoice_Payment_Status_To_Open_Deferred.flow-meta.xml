<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <decisions>
        <name>Check_Defered_Amount</name>
        <label>Check Defered Amount</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Open_Payment_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Open Status</defaultConnectorLabel>
        <rules>
            <name>Deferred</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.leaseworks__Deferred_Amount__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Total_Amount_Due__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Record.leaseworks__Deferred_Amount__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Payment_Status</targetReference>
            </connector>
            <label>Deferred Status</label>
        </rules>
    </decisions>
    <description>Update payment status after Cancellation</description>
    <environments>Default</environments>
    <interviewLabel>Invoice Payment Status To Open/Deferred {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Invoice Payment Status To Open/Deferred</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Open_Payment_Status</name>
        <label>Open Payment Status</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <inputAssignments>
            <field>leaseworks__Payment_Status__c</field>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Payment_Status</name>
        <label>Deferred Payment Status</label>
        <locationX>50</locationX>
        <locationY>431</locationY>
        <inputAssignments>
            <field>leaseworks__Payment_Status__c</field>
            <value>
                <stringValue>Deferred</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Defered_Amount</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
    NOT(
        OR(
            ISPICKVAL({!$Record.leaseworks__Status__c}, &quot;Declined&quot;),
            ISPICKVAL({!$Record.leaseworks__Status__c}, &quot;Cancelled-Pending&quot;),
            ISPICKVAL({!$Record.leaseworks__Status__c}, &quot;Cancelled&quot;)
        )
    ),
    {!$Record.leaseworks__Availed_Credit_Amount_Cm__c} = 0,
    {!$Record.leaseworks__Amount_Paid_Remaining__c} = 0,
    {!$Record.leaseworks__Total_Amount_Due__c} = {!$Record.leaseworks__Balance_Due__c}
)</filterFormula>
        <object>leaseworks__Invoice__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
