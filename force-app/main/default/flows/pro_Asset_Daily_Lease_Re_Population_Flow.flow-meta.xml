<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <description>This record triggered flow will re-populate an associated Lease record to the asset file after the LeaseWorks daily scheduled job has removed it due to the Status of the Lease record.</description>
    <environments>Default</environments>
    <interviewLabel>Asset - Daily Lease Re-Population Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Asset - Daily Lease Re-Population Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <filterFormula>AND(
ISPICKVAL({!$Record.leaseworks__Status__c}, &quot;Assigned&quot;),
ISBLANK({!$Record.leaseworks__Lease__c}),
NOT(ISBLANK({!$Record__Prior.leaseworks__Lease__c}))
)</filterFormula>
        <object>leaseworks__Aircraft__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>InvalidDraft</status>
</Flow>
