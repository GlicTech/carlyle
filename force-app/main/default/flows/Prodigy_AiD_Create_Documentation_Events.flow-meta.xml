    <decisions>
        <name>Are_Documentation_Events_Relevant_To_Deal_Type</name>
        <label>Are Documentation Events Relevant To Deal Type?</label>
        <locationX>688</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Documentation_Events_Relevant</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sale_Novation</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Lease</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Lease Amendment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sale_Off_Lease</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Engine Exchange</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_LOI_Populated</targetReference>
            </connector>
            <label>Documentation Events Relevant</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_LOI_Populated</name>
        <label>Is LOI Populated?</label>
        <locationX>446</locationX>
        <locationY>539</locationY>
        <defaultConnectorLabel>No LOI</defaultConnectorLabel>
        <rules>
            <name>Yes_LOI_Populated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LOI_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Existing_Documentation_Events</targetReference>
            </connector>
            <label>Yes - LOI Populated</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_LOI_Pre_September_2024</name>
        <label>Is LOI Pre September 2024?</label>
        <locationX>237</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Are_Documentation_Events_Relevant_To_Deal_Type</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Post September 2024</defaultConnectorLabel>
        <rules>
            <name>Yes_Pre_September_2024</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LOI_Date__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <dateValue>2024-09-01</dateValue>
                </rightValue>
            </conditions>
            <label>Yes - Pre September 2024</label>
        </rules>
    </decisions>
    <decisions>
        <name>Were_Documentation_Events_Found</name>
        <label>Were Documentation Events Found?</label>
        <locationX>226</locationX>
        <locationY>863</locationY>
        <defaultConnector>
            <targetReference>Assign_Documentation_Event_Names</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Found</defaultConnectorLabel>
        <rules>
            <name>Documentation_Events_Found</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Existing_Documentation_Events</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Existing_Documentation_Events</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_New_Projected_Date_On_Event</targetReference>
            </connector>
            <label>Documentation Events Found</label>
        </rules>
    </decisions>
    <description>Lease Documentation Timelines

When LOI Date field gets populated on AiD, this flow creates Documentation Event records and sets the Projected Date field.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_DocumentationType</name>
        <dataType>String</dataType>
        <expression>IF(CONTAINS({!varDocEventToCreate.Name}, &quot;Engage Law Firm&quot;), &quot;1 Engage Law Firm&quot;, 
             IF(CONTAINS({!varDocEventToCreate.Name}, &quot;Initial Draft&quot;), &quot;2 Initial Draft&quot;,
                    IF(CONTAINS({!varDocEventToCreate.Name}, &quot;Review &amp; Comment&quot;), &quot;3 Review &amp; Comment&quot;, &quot;4 Draft To Counterparty&quot;)))</expression>
    </formulas>
    <formulas>
        <name>f_DraftToCounterpartyDocEventName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} + &apos; -  Draft To Counterparty&apos;</expression>
    </formulas>
    <formulas>
        <name>f_EngageLawFirmDocEventName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} + &apos; - Engage Law Firm&apos;</expression>
    </formulas>
    <formulas>
        <name>f_InitialDraftDocEventName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} + &apos; -  Initial Draft&apos;</expression>
    </formulas>
    <formulas>
        <name>f_ReviewCommentDocEventName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} + &apos; -  Review &amp; Comment&apos;</expression>
    </formulas>
    <formulas>
        <name>f_TodayPlus1BdForEngageLawFirm</name>
        <dataType>Date</dataType>
        <expression>IF(CONTAINS({!Loop_Documentation_Event_Names} , &apos;Engage Law Firm&apos;) , {!Calculate_1_Working_Day.varTargetDate}, Null)</expression>
    </formulas>
    <interviewLabel>Prodigy - AiD - Create Documentation Events {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - AiD - Create Documentation Events</label>
    <loops>
