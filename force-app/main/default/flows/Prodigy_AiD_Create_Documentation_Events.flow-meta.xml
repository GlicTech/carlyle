    <recordUpdates>
        <description>Update the Projected Date on the Engage Law Firm documentation event</description>
        <name>Set_New_Projected_Date_On_Event</name>
        <label>Set New Projected Date On Event</label>
        <locationX>50</locationX>
        <locationY>971</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Asset_in_Deal__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>pro_Documentation_Event_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>1 Engage Law Firm</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>pro_Projected_Date__c</field>
            <value>
                <elementReference>Calculate_1_Working_Day.varTargetDate</elementReference>
            </value>
        </inputAssignments>
        <object>pro_Documentation_Event__c</object>
    </recordUpdates>
    <start>
        <locationX>111</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_LOI_Pre_September_2024</targetReference>
        </connector>
        <filterFormula>AND(
        OR(
              ISNEW(),
              ISCHANGED({!$Record.LOI_Date__c})
          ),
         NOT(ISBLANK({!$Record.LOI_Date__c}))
)</filterFormula>
        <object>leaseworks__Aircraft_Proposal__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
