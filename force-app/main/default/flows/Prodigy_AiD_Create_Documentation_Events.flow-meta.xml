        <expression>{!$Record.Name} + &#39; -  Initial Draft&#39;</expression>
    </formulas>
    <formulas>
        <name>f_ReviewCommentDocEventName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} + &#39; -  Review &amp; Comment&#39;</expression>
    </formulas>
    <formulas>
        <name>f_TodayPlus1BdForEngageLawFirm</name>
        <dataType>Date</dataType>
        <expression>IF({!Loop_Documentation_Event_Names} = &#39;1 Engage Law Firm&#39;, {!LOI_Signed_1.targetDate}, Null)</expression>
    </formulas>
