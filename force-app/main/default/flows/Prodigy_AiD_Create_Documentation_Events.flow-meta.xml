    <description>Lease Documentation Timelines

When LOI Date field gets populated on AiD, this flow creates Documentation Event records and sets the Projected Date field.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_DocumentationType</name>
        <dataType>String</dataType>
        <expression>IF(CONTAINS({!varDocEventToCreate.Name}, &quot;Engage Law Firm&quot;), &quot;1 Engage Law Firm&quot;, 
             IF(CONTAINS({!varDocEventToCreate.Name}, &quot;Initial Draft&quot;), &quot;2 Initial Draft&quot;,
                    IF(CONTAINS({!varDocEventToCreate.Name}, &quot;Review &amp; Comment&quot;), &quot;3 Review &amp; Comment&quot;, &quot;4 Draft To Counterparty&quot;)))</expression>
    </formulas>
    <formulas>
        <name>f_DraftToCounterpartyDocEventName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} + &#39; -  Draft To Counterparty&#39;</expression>
    </formulas>
    <formulas>
        <name>f_EngageLawFirmDocEventName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} + &#39; - Engage Law Firm&#39;</expression>
    </formulas>
    <formulas>
        <name>f_InitialDraftDocEventName</name>
