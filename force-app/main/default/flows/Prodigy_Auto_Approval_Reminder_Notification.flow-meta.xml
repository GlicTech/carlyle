    <description>This flow can be launched, for example, from a button on the Deal record page. When clicked, it will notify any outstanding LOI or Lease Documentation approvers based on the Deal Status.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_NotificationTitle</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!recordId.leaseworks__Deal_Status__c}) = &#39;LOI Signed&#39;, &#39;🔔 LOI Approval Required [&#39; + {!recordId.Name} + &#39;]&#39;, 
        IF(TEXT({!recordId.leaseworks__Deal_Status__c}) = &#39;Documentation&#39;, &#39;🔔 Lease Documentation Approval Required [&#39; +     {!recordId.Name} + &#39;]&#39;,  &#39;🔔 Non Deal Approval Required [&#39; +     {!recordId.Name} + &#39;]&#39;))</expression>
    </formulas>
