    <description>Triggered on creation of a Credit Score record, this flow finds the most recent Credit Score for the associated Account and links it to the newly created Credit Score.</description>
    <environments>Default</environments>
    <interviewLabel>Prodigy - Credit Score On Create Link To Previous Credit Score {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - Credit Score On Create Link To Previous Credit Score</label>
    <processMetadataValues>
