    <formulas>
        <name>InsuranceCertificateName</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!Policy_Expiry_Date}+&apos;&apos;+{!OperatorName}+&apos;&apos;+{!$Record.leaseworks__Aircraft__r.leaseworks__MSN_Number__c}) &gt;80 , 
 LEFT({!Policy_Expiry_Date}+&apos;&apos;+{!OperatorName}+&apos;&apos;+{!$Record.leaseworks__Aircraft__r.leaseworks__MSN_Number__c} ,77)+&apos;...&apos;,
{!Policy_Expiry_Date}+&apos; &apos;+{!OperatorName}+&apos;&apos;+{!$Record.leaseworks__Aircraft__r.leaseworks__MSN_Number__c}
)</expression>
    </formulas>
    <formulas>
        <name>OperatorName</name>
