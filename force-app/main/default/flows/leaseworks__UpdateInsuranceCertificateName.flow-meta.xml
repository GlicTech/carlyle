        <expression>IF( NOT( ISBLANK({!$Record.leaseworks__Lease__c})) &amp;&amp; NOT( ISBLANK({!$Record.leaseworks__Lease__r.leaseworks__Operator_New__c}))  &amp;&amp;  NOT( ISBLANK({!$Record.leaseworks__Lease__r.leaseworks__Operator_New__r.Name}))  , {!$Record.leaseworks__Lease__r.leaseworks__Operator_New__r.Name}+&apos; - &apos; , &apos;&apos; )</expression>
    </formulas>
    <formulas>
        <name>Policy_Expiry_Date</name>
        <dataType>String</dataType>
        <expression>IF(ISNULL({!$Record.leaseworks__Policy_Expiry_Date__c}), &apos;&apos; , &apos;Exp &apos;+TEXT({!$Record.leaseworks__Policy_Expiry_Date__c})+&apos; - &apos;)</expression>
