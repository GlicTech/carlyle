    <description>Flow takes a record Id variable as an input, searches for Status Updates related to the recordId and surfaces these updates in a screenflow.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_KeyPrefix</name>
        <dataType>String</dataType>
        <expression>LEFT({!recordId},3)</expression>
    </formulas>
    <formulas>
        <name>f_SelectedUpdates</name>
        <dataType>String</dataType>
        <expression>IF(
    {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;leaseworks__Technical_Project__c&quot;,
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Technical_Project__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

IF(
    {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;Account&quot;,
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c  &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Account__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

IF(
    {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;leaseworks__Claims__c&quot;,
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Claim__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

IF(
    {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;Litigation__c&quot;,
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Litigation__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

IF(
    {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;pro_Ticket__c&quot;,
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Ticket__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

IF(
    AND(
        {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;leaseworks__Marketing_Activity__c&quot;,
        {!Update_Type} = &quot;Weekly Commercial Summary&quot;
    ),
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Deal__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;AND pro_Update_Type__c = &apos;Weekly Commercial Summary&apos; &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

IF(
    AND(
        {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;leaseworks__Marketing_Activity__c&quot;,
        {!Update_Type} = &quot;Weekly Legal &amp; Contracts Summary&quot;
    ),
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Deal__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;AND pro_Update_Type__c = &apos;Weekly Legal &amp; Contracts Summary&apos; &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

IF(
    AND(
        {!Get_Entity_Definition_For_Triggering_Record.QualifiedApiName} = &quot;leaseworks__Marketing_Activity__c&quot;,
        {!Update_Type} = &quot;All&quot;
    ),
    &quot;SELECT pro_Status_Update__c, pro_Created_By_Name__c, pro_Date__c, pro_Update_Type__c &quot; &amp;
    &quot;FROM pro_Status_Update__c &quot; &amp;
    &quot;WHERE pro_Deal__c = &apos;&quot; &amp; {!recordId} &amp; &quot;&apos; &quot; &amp;
    &quot;AND pro_Update_Type__c IN (&apos;Weekly Commercial Summary&apos;,&apos;Weekly Legal &amp; Contracts Summary&apos;) &quot; &amp;
    &quot;ORDER BY CreatedDate DESC&quot;,

&quot;&quot;
))))))))</expression>
    </formulas>
