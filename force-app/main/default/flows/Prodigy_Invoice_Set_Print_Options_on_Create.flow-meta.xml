    <description>When an Invoice record is created, this flow retrieves the Print Options Config record associated to the Contract and uses its values to set the Print Options on the Invoice.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_ConcatenatedName</name>
        <dataType>String</dataType>
        <expression>&#39;Print Options - &#39; + {!$Record.Name}</expression>
    </formulas>
    <interviewLabel>Prodigy - Inve {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - Invoice - Set Print Options on Create</label>
