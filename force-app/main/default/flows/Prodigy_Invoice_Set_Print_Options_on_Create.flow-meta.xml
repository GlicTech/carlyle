    <decisions>
        <name>Is_Running_User_s_Email_Invalid</name>
        <label>Is Running User&#39;s Email Invalid?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Invalid</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$User.Email</leftValueReference>
                <operator>EndsWith</operator>
                <rightValue>
                    <stringValue>invalid</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Email_running_User</targetReference>
            </connector>
            <label>Yes - Invalid</label>
        </rules>
    </decisions>
