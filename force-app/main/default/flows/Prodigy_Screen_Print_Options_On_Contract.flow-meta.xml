    <formulas>
        <description>If changes were made to the Print Options Config record values in the input screen, this returns true. Otherwise, returns false. Used to conditionally display the Save Changes button.</description>
        <name>f_ChangesMadeInInputScreen</name>
        <dataType>Boolean</dataType>
        <expression>IF( {!Include_PO_Number} != {!Get_Related_Print_Options_Config_Record.pro_Include_PO_Number__c} || {!Include_Aircraft_Registration_Number} != {!Get_Related_Print_Options_Config_Record.pro_Include_Aircraft_Registration_Number__c} || {!Include_Bank_Account_Address} != {!Get_Related_Print_Options_Config_Record.pro_Include_Bank_Account_Address__c}, True, False)</expression>
    </formulas>
    <formulas>
        <name>f_ContractId</name>
        <dataType>String</dataType>
        <expression>IF({!varTriggeringContract.Id} != Null, {!varTriggeringContract.Id} , {!varTriggeringInvoice.leaseworks__Lease__c})</expression>
    </formulas>
    <formulas>
        <name>f_PlaceholderOrBankAddress</name>
        <dataType>String</dataType>
        <expression>IF({!varTriggeringContract.Id} != Null, &#39;Selected Based On Invoice Type&#39;, {!varTriggeringInvoice.leaseworks__Bank_Account__r.pro_Branch_Address_Formula__c})</expression>
    </formulas>
