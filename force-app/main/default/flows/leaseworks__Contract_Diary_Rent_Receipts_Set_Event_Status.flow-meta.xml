<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <decisions>
        <name>Is_Payment_Status_updated_to_Paid</name>
        <label>Is Payment Status updated to Paid/Credited?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>(1 AND 2) OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.leaseworks__Payment_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Paid</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Payment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Paid</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.leaseworks__Payment_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Credited</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Payment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Credited</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Event_Status_on_Contract_Diary_to_Closed</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
        <rules>
            <name>No</name>
            <conditionLogic>(1 AND 2) OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.leaseworks__Payment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Paid</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Payment_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Paid</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.leaseworks__Payment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Credited</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Payment_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Credited</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Event_Status_on_Contract_Diary_to_Open</targetReference>
            </connector>
            <label>No</label>
        </rules>
    </decisions>
    <description>On an object, if a specified field value is updated, we set the Event Status on the related Contract Diary record accordingly.</description>
    <environments>Default</environments>
    <interviewLabel>Set Event Status {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Contract Diary  -  Set Event Status - Template</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Event_Status_on_Contract_Diary_to_Closed</name>
        <label>Set Event Status on Contract Diary to Closed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Copy_1_of_Default_Contract_Diary_Error_Message</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>leaseworks__Link_URL__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Rent Receipts Due Date</stringValue>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Contract__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__Lease__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>leaseworks__Event_Status__c</field>
            <value>
                <stringValue>Closed</stringValue>
            </value>
        </inputAssignments>
        <object>leaseworks__Contract_Diary__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Set_Event_Status_on_Contract_Diary_to_Open</name>
        <label>Set Event Status on Contract Diary to Open</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Default_Contract_Diary_Error_Message</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>leaseworks__Link_URL__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Rent Receipts Due Date</stringValue>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Contract__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__Lease__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>leaseworks__Event_Status__c</field>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </inputAssignments>
        <object>leaseworks__Contract_Diary__c</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Payment_Status_updated_to_Paid</targetReference>
        </connector>
        <filterFormula>AND(
AND(ISCHANGED({!$Record.leaseworks__Payment_Status__c}),AND({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c} = FALSE, {!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c} = FALSE)),
ISPICKVAL({!$Record.leaseworks__Invoice_Type__c},&#39;Rent&#39;)
)</filterFormula>
        <object>leaseworks__Invoice__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
