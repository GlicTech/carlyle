    <decisions>
        <description>If Regional Manager = Marketing / Deal Rep =&gt; Alan B. is the LOI Approver
If Regional Manager does not equal Marketing / Deal Rep =&gt; Regional Manager is the LOI Approver and Marketing / Deal Rep signs off final documents</description>
        <name>LOI_Approver_Switch</name>
        <label>LOI Approver Switch?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Deal_Created_On_Airline_Or_Other_Account_Type</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
