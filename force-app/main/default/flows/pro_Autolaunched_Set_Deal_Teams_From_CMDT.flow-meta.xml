                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Switch_In_Fund_Based_Role</targetReference>
            </connector>
            <label>Include Investment &amp; Strategy</label>
        </rules>
        <rules>
            <name>Include_Portfolio_Management</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varCapfviiFund</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
