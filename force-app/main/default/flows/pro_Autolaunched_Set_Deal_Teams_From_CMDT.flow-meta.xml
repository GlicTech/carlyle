    <formulas>
        <name>f_AssigneeFromAccountTeam</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(
        TEXT({!Loop_Deal_Team_Roles.pro_Deal_Team_Name__c}) = &quot;Lease Management&quot;,
        CONTAINS({!Loop_Deal_Team_Roles.DeveloperName}, &quot;Lease_Mgt_Head&quot;)
    ),
    {!Get_User_For_Lease_Mgt_Head.Id},

    CASE(
        TEXT({!Loop_Deal_Team_Roles.pro_Deal_Team_Name__c}),
        &quot;Contracts&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Contracts__c},
        &quot;Credit&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Credit__c},
        &quot;Debt&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Debt__c},
        &quot;Investment &amp; Strategy&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Investment_Strategy__c},
        &quot;Insurance&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.pro_Insurance__c},
        &quot;Legal&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Legal__c},
        &quot;Marketing&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.OwnerId},
        &quot;Compliance&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Compliance__c},
        &quot;Portfolio Management&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Portfolio_Fund_Management__c},
        &quot;Powerplant&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Powerplant__c},
        &quot;Regional Marketing Manager&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Marketing__c},  
        &quot;Lease Management&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Receivables__c},
        &quot;Tax&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Tax__c},
        &quot;Technical&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Technical__c},
        &quot;Trading&quot;, {!varTriggeringDeal.leaseworks__Counter_Party__r.Trading__c},
        &quot;Invalid Role&quot;
    )
)</expression>
    </formulas>
    <formulas>
        <name>f_DealRecordType</name>
        <dataType>String</dataType>
        <expression>IF( {!varTriggeringDeal.RecordType.DeveloperName} = &#39;Engine_Lease&#39;, &#39;Lease&#39;,

IF( {!varTriggeringDeal.RecordType.DeveloperName} = &#39;Engine_Sale&#39;, &#39;Sale_Off_Lease&#39;,

{!varTriggeringDeal.RecordType.DeveloperName}))</expression>
    </formulas>
    <formulas>
        <name>f_LoiApproverFromCMDT</name>
        <dataType>Boolean</dataType>
        <expression>IF(
  TEXT({!Loop_Deal_Team_Mappings.pro_Deal_Team_Name__c}) =
    TEXT({!Get_Marketing_LOI_Switch_CMDT.pro_Deal_Team_Name__c})
  &amp;&amp;
  {!varTriggeringDeal.leaseworks__Marketing_Representative_User__r.Username} =
    {!Loop_Deal_Team_Mappings.pro_Assigned_To_Username__c},

  false,

  {!Loop_Deal_Team_Mappings.pro_Include_In_LOI_Approvals__c}
)</expression>
    </formulas>
