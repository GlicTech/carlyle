            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringDeal.leaseworks__Marketing_Representative_User__r.Username</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>currentItem_Filter_Collection_To_Regional_Marketing_Manager.pro_Assigned_To_Username__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Flag_LOI_Approver_Switch</targetReference>
            </connector>
            <label>Yes - Switch LOI Approver</label>
        </rules>
    </decisions>
    <decisions>
