    <environments>Default</environments>
    <formulas>
        <name>f_ApprovalToTicketTypeMapping</name>
        <dataType>String</dataType>
        <expression>CASE(
    TEXT({!$Record.Approval_Type__c}),
    
    &#39;Waiver / Rebate&#39;, &#39;Lease Side Letter&#39;,
    &#39;Deferral Request&#39;, &#39;Lease Side Letter&#39;,
    &#39;LPI Waiver / Discount&#39;, &#39;Lease Side Letter&#39;,
    &#39;Part Exchanges (LG / APU)&#39;, &#39;Lease Side Letter&#39;,
    &#39;Cash to LoC Conversion&#39;, &#39;Lease Side Letter&#39;,
    &#39;Redelivery Buy-outs&#39;, &#39;Lease Side Letter&#39;,
    &#39;Other Lease Amendments&#39;, &#39;Lease Side Letter&#39;,

    &#39;LoC Drawdown&#39;, &#39;Other&#39;,
    &#39;Novation Fees (Internal)&#39;, &#39;Other&#39;,
    &#39;Novation Fees (External)&#39;, &#39;Other&#39;,
    &#39;Bond Repurchase&#39;, &#39;Other&#39;,

    &#39;Credit Actions&#39;, &#39;Non-Deal Approval&#39;,

    &#39;Subleasing Request&#39;, &#39;Letter of Consent*&#39;,
    &#39;Change of Ownership&#39;, &#39;Letter of Consent*&#39;,
    &#39;Operational Requests&#39;, &#39;Letter of Consent&#39;,

    &#39;Tripartite Agreement&#39;, &#39;Maintenance / Storage /CAMO Agmt&#39;,

    &#39;Unknown&#39;
)</expression>
    </formulas>
    <formulas>
        <name>f_TodayPlusSeven</name>
        <dataType>Date</dataType>
        <expression>TODAY() + 7</expression>
    </formulas>
