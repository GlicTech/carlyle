    <description>Non Deal Approvals

Once Approval is given on a Non Deal Approval, this flow creates a corresponding Legal &amp; Contracts ticket</description>
    <environments>Default</environments>
    <formulas>
        <name>f_ApprovalToTicketTypeMapping</name>
        <dataType>String</dataType>
        <expression>CASE(
    TEXT({!$Record.Approval_Type__c}),
    
    &apos;Waiver / Rebate&apos;, &apos;Lease Side Letter&apos;,
    &apos;Deferral Request&apos;, &apos;Lease Side Letter&apos;,
    &apos;LPI Waiver / Discount&apos;, &apos;Lease Side Letter&apos;,
    &apos;Part Exchanges (LG / APU)&apos;, &apos;Lease Side Letter&apos;,
    &apos;Cash to LoC Conversion&apos;, &apos;Lease Side Letter&apos;,
    &apos;Redelivery Buy-outs&apos;, &apos;Lease Side Letter&apos;,
    &apos;Other Lease Amendments&apos;, &apos;Lease Side Letter&apos;,

    &apos;LoC Drawdown&apos;, &apos;Other&apos;,
    &apos;Novation Fees (Internal)&apos;, &apos;Other&apos;,
    &apos;Novation Fees (External)&apos;, &apos;Other&apos;,
    &apos;Bond Repurchase&apos;, &apos;Other&apos;,
    &apos;Claims - Deviation from Lease Terms&apos;, &apos;Other&apos;,

    &apos;Credit Actions&apos;, &apos;Non-Deal Approval&apos;,

    &apos;Subleasing Request&apos;, &apos;Letter of Consent*&apos;,
    &apos;Change of Ownership&apos;, &apos;Letter of Consent*&apos;,
    &apos;Operational Requests&apos;, &apos;Letter of Consent&apos;,

    &apos;Tripartite Agreement&apos;, &apos;Maintenance / Storage /CAMO Agmt&apos;,

    &apos;Unknown&apos;
)</expression>
    </formulas>
    <formulas>
        <name>f_AssetNameListFormat</name>
        <dataType>String</dataType>
        <expression>IF({!varAssetsToAttachNames} = Null,
     {!Loop_Assets_In_Deal.Name},
     &apos;, &apos; + {!Loop_Assets_In_Deal.Name}
)</expression>
    </formulas>
    <formulas>
        <name>f_AssetTransactionCodeListFormat</name>
        <dataType>String</dataType>
        <expression>IF({!varAssetTransactionCodes} = Null,
    {!Loop_Assets_In_Deal.leaseworks__Aircraft__r.leaseworks__MSN_Number__c} + &apos; - (&apos; + {!Loop_Assets_In_Deal.leaseworks__Aircraft__r.Transaction_Code__c}  + &apos;)&apos;,
     &apos;, &apos; +   {!Loop_Assets_In_Deal.leaseworks__Aircraft__r.leaseworks__MSN_Number__c} + &apos; - (&apos; + {!Loop_Assets_In_Deal.leaseworks__Aircraft__r.Transaction_Code__c}  + &apos;)&apos;
)</expression>
    </formulas>
    <formulas>
        <name>f_TodayPlusSeven</name>
        <dataType>Date</dataType>
        <expression>TODAY() + 7</expression>
    </formulas>
