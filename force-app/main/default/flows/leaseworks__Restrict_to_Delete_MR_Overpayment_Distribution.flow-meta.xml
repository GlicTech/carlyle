<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <decisions>
        <description>This decision is used to check Parent Credit Memo record Status is Submitted for Approval / Approved / Cancelled-Pending then Child should not be delete.</description>
        <name>Check_Parent_Credit_Memo_Status</name>
        <label>Check Parent Credit Memo Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_1_of_Check_Parent_Credit_Memo_list_Size</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.leaseworks__Credit_Memo__r.leaseworks__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Submitted</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Credit_Memo__r.leaseworks__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Credit_Memo__r.leaseworks__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled-Pending</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Restrict_User_to_delete_MR_Overpayment_Distribution</targetReference>
            </connector>
            <label>IF Parent Status is Approved then Child should not be delete</label>
        </rules>
    </decisions>
    <description>This flow is used to Restrict user to delete the MR Overpayment Distribution when the Parent Credit Memo is in Approved, Submitted for Approval &amp; Cancelled-Pending status.</description>
    <environments>Default</environments>
    <interviewLabel>Restrict to Delete MR Overpayment Distribution {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Restrict to Delete MR Overpayment Distribution</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Parent_Credit_Memo_Status</targetReference>
        </connector>
        <filterFormula>AND({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}==FALSE,{!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}==FALSE)</filterFormula>
        <object>leaseworks__Credit_Memo_Issuance__c</object>
        <recordTriggerType>Delete</recordTriggerType>
        <triggerType>RecordBeforeDelete</triggerType>
    </start>
    <status>Active</status>
</Flow>
