<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <description>This flow updates the Name field on the Chart of Accounts record by concatenating the GL Account Code (GL_Code__c) and GL Account Description (GL_Account_Description__c) in the format: GL_Code__c - GL_Account_Description__c.</description>
    <environments>Default</environments>
    <interviewLabel>UpdateCoaName {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>UpdateCoaName</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Concatenates GL Code and GL Description</description>
        <name>CoaNameUpdate</name>
        <label>CoaNameUpdate</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>Name</field>
            <value>
                <stringValue>{!$Record.leaseworks__GL_Code__c} - {!$Record.leaseworks__GL_Account_Description__c}</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>CoaNameUpdate</targetReference>
        </connector>
        <filterFormula>AND(NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}), (NOT {!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}))</filterFormula>
        <object>leaseworks__Chart_Of_Accounts__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
