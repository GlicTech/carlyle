    <formulas>
        <description>Returns the Deal Id between quotes and starting with a leading comma. Used to create a comma separated list of Deal Ids</description>
        <name>f_CommaSeparatedDealIds</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!varDealIdsInString}),
  &quot;&apos;&quot; &amp; {!Loop_Deal_Ids} &amp; &quot;&apos;&quot;,
  {!varDealIdsInString} &amp; &quot;,&quot; &amp; &quot;&apos;&quot; &amp; {!Loop_Deal_Ids} &amp; &quot;&apos;&quot;
)</expression>
    </formulas>
    <formulas>
        <name>f_QueryActiveDeals</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!varDealIdsInString}),
  &quot;SELECT Id, Name, leaseworks__Deal_Status__c, leaseworks__Aircraft_Type_Qty_List__c, leaseworks__Date_Of_Last_Interaction__c, leaseworks__Deal_Type__c, CreatedDate FROM leaseworks__Marketing_Activity__c WHERE Id = &apos;&apos;&quot;,
  &quot;SELECT Id, Name, leaseworks__Deal_Status__c, leaseworks__Aircraft_Type_Qty_List__c, leaseworks__Date_Of_Last_Interaction__c, leaseworks__Deal_Type__c, CreatedDate FROM leaseworks__Marketing_Activity__c WHERE leaseworks__Inactive_MA__c = False AND Id IN (&quot; &amp; {!varDealIdsInString} &amp; &quot;)&quot;
)</expression>
    </formulas>
