<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <description>This flow updates the Data Verified By field on Claim records with the current user&apos;s username and date (MM/DD/YYYY) when record is created/update.</description>
    <environments>Default</environments>
    <formulas>
        <name>dateVerifiedBy</name>
        <dataType>String</dataType>
        <expression>{!$User.FirstName} + &apos; &apos; + {!$User.LastName} +&apos;, &apos; + Text(MONTH(TODAY())) + &apos;/&apos; + Text(Day(TODAY())) + &apos;/&apos; + Text(year(TODAY()))</expression>
    </formulas>
    <interviewLabel>Claims Data Verifed By {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Claims Data Verifed By</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>ClaimSetDataVerifiedBy</name>
        <label>ClaimSetDataVerifiedBy</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>leaseworks__Data_Verified_By__c</field>
            <value>
                <elementReference>dateVerifiedBy</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>ClaimSetDataVerifiedBy</targetReference>
        </connector>
        <filterFormula>AND(NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}), (NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c})),OR ( AND (ISNEW(), {!$Record.leaseworks__Data_Verified_for_Accuracy__c}), ISCHANGED( {!$Record.leaseworks__Data_Verified_for_Accuracy__c})))</filterFormula>
        <object>leaseworks__Claims__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
