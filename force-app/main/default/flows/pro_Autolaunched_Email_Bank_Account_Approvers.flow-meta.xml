    <description>Flow called within flow approval orchestrations to send notification email to users in the Bank Account Approvers public group.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_EmailBodyIntroduction</name>
        <dataType>String</dataType>
        <expression>IF({!varBankAccountUpdated} = True, &quot;An update has been submitted on a Bank Account record&quot;, &quot;A new Bank Account record has been created &quot;)</expression>
    </formulas>
    <formulas>
        <name>f_EmailSubject</name>
        <dataType>String</dataType>
        <expression>IF({!varBankAccountUpdated} = True, 
&quot;Approval Required: Update To Bank Account [&quot; + {!varTriggeringBankAccount.pro_Bank_Account_Name_Pending__c} + &quot;]&quot;,
&quot;Approval Required: Bank Account Created [&quot; + {!varTriggeringBankAccount.Name} + &quot;]&quot;)</expression>
    </formulas>
    <formulas>
        <name>f_IbanOrRouting</name>
        <dataType>String</dataType>
        <expression>IF({!varTriggeringBankAccount.leaseworks__Country__r.Name} = &#39;United States of America&#39;, &#39;Routing/ABA&#39;, &#39;IBAN&#39;)</expression>
    </formulas>
    <formulas>
        <name>f_IbanOrRoutingUpdate</name>
        <dataType>String</dataType>
        <expression>IF({!varTriggeringBankAccount.pro_Country_Name_Pending__c} = &#39;United States of America&#39;, &#39;Routing/ABA&#39;, &#39;IBAN&#39;)</expression>
    </formulas>
    <formulas>
        <name>f_IbanOrRoutingUpdateValue</name>
        <dataType>String</dataType>
        <expression>IF({!varTriggeringBankAccount.pro_Country_Name_Pending__c} = &#39;United States of America&#39;, {!varTriggeringBankAccount.pro_Routing_ABA_Pending__c}, {!varTriggeringBankAccount.pro_IBAN_Code_Pending__c})</expression>
    </formulas>
    <formulas>
        <name>f_RoutingOrIbanValue</name>
        <dataType>String</dataType>
        <expression>IF({!varTriggeringBankAccount.leaseworks__Country__r.Name} = &#39;United States of America&#39;, {!varTriggeringBankAccount.leaseworks__Routing_ABA__c}, {!varTriggeringBankAccount.leaseworks__IBAN_Code__c})</expression>
    </formulas>
