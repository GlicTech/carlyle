    <textTemplates>
        <name>tt_EmailBodyCreation</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Dear User,&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;A new Bank Account record has been created in Salesforce and requires approval from a user in the Bank Account Approvers group.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Bank Account Details:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Name: &lt;/strong&gt;{!varTriggeringBankAccount.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Account Number: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Account_Number__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Bank Branch: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Bank_Branch__r.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Country: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Country__r.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Currency: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Account_Currency__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;{!f_IbanOrRouting}: &lt;/strong&gt;{!f_RoutingOrIbanValue}&lt;span class=&quot;ql-cursor&quot;&gt;﻿&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;You can view the full details and take action by clicking the link: &lt;/span&gt;&lt;a href=&quot;https://leaseworks-carlyle--full.sandbox.lightning.force.com/{!varTriggeringBankAccount.Id}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;View Bank Account in Salesforce.&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Kind regards,&lt;/p&gt;&lt;p&gt;Salesforce System Notification&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;em&gt;This message was generated automatically. For assistance, please contact your Salesforce administrator.&lt;/em&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_EmailBodyUpdate</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Dear User,&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;An update has been submitted for a Bank Account record in Salesforce and requires approval from a user in the Bank Account Approvers group.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Existing Bank Account Details:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Name: &lt;/strong&gt;{!varTriggeringBankAccount.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Account Number: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Account_Number__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Bank Branch: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Bank_Branch__r.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Country: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Country__r.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Currency: &lt;/strong&gt;{!varTriggeringBankAccount.leaseworks__Account_Currency__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;{!f_IbanOrRouting}: &lt;/strong&gt;{!f_RoutingOrIbanValue}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;strong&gt;Updated Bank Account Details:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Name: &lt;/strong&gt;{!varTriggeringBankAccount.pro_Bank_Account_Name_Pending__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Account Number: &lt;/strong&gt;{!varTriggeringBankAccount.pro_Bank_Account_Number_Pending__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Bank Branch:&lt;/strong&gt; {!varTriggeringBankAccount.pro_Bank_Branch_Name_Pending__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Country: &lt;/strong&gt;{!varTriggeringBankAccount.pro_Country_Name_Pending__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Currency: &lt;/strong&gt;{!varTriggeringBankAccount.pro_Account_Currency_Pending__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;{!f_IbanOrRoutingUpdate}: &lt;/strong&gt;{!f_IbanOrRoutingUpdateValue}﻿&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;You can view the full details and take action by clicking the link: &lt;/span&gt;&lt;a href=&quot;https://leaseworks-carlyle--full.sandbox.lightning.force.com/{!varTriggeringBankAccount.Id}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;View Bank Account in Salesforce.&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Kind regards,&lt;/p&gt;&lt;p&gt;Salesforce System Notification&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;em&gt;This message was generated automatically. For assistance, please contact your Salesforce administrator.&lt;/em&gt;&lt;/p&gt;</text>
    </textTemplates>
