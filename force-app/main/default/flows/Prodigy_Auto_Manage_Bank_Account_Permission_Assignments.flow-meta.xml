    <assignments>
        <name>Assign_User_Email_To_Collection</name>
        <label>Assign User Email To Collection</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varUserEmailInCollection</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>$User.Email</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Bank_Account_Full_Access_Permission_Set</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Add_or_Remove_User_From_Permission_Set</name>
        <label>Add or Remove User From Permission Set?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Add_To_Permission_Set</name>
            <conditionLogic>1 AND (2 OR 3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Back Office External</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Lease Management</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>System Administrator</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_User_Already_Assigned_To_Permission_Set</targetReference>
            </connector>
            <label>Add To Permission Set</label>
        </rules>
        <rules>
            <name>Remove_From_Permission_Set</name>
            <conditionLogic>1 OR (2 AND 3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringUser.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Back Office External</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Lease Management</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varTriggeringUser.Profile.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>System Administrator</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_User_Assigned_To_Permission_Set</targetReference>
            </connector>
            <label>Remove From Permission Set</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_running_users_email_invalid</name>
        <label>Is running users email invalid?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Error_Email_Running_User</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Email_Invalid</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$User.Email</leftValueReference>
                <operator>EndsWith</operator>
                <rightValue>
                    <stringValue>invalid</stringValue>
                </rightValue>
            </conditions>
            <label>Yes - Email Invalid</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_User_Already_Assigned_To_Permission_Set</name>
        <label>Is User Already Assigned To Permission Set?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_Permission_Set_Assignment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Already_Assigned</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Create_Collection_Of_User_Ids_Assigned_To_Permission_Set</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>varTriggeringUser.Id</elementReference>
                </rightValue>
            </conditions>
            <label>Yes - Already Assigned</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_User_Assigned_To_Permission_Set</name>
        <label>Is User Assigned To Permission Set?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Assigned</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Create_Collection_Of_User_Ids_Assigned_To_Permission_Set</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>varTriggeringUser.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Permission_Set_Assignment</targetReference>
            </connector>
            <label>Yes - Assigned</label>
        </rules>
    </decisions>
    <description>Auto Assign Permissions

This flow makes sure that active users on the profiles Back Office External, Lease Management, System Administrator get assigned to the Bank Account Full Access permission set. 

User&apos;s who are updated to fall outside of the above parameters get removed from the permission set assignments.</description>
    <environments>Default</environments>
