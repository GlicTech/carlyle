<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Call_Notification_Handler</name>
        <label>Send Completion Notification</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <actionName>pro_ChecklistNotificationHandler</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>assetInDealIds</name>
            <value>
                <elementReference>$Record.pro_Asset_in_Deal__c</elementReference>
            </value>
        </inputParameters>
        <nameSegment>pro_ChecklistNotificationHandler</nameSegment>
    </actionCalls>
    <apiVersion>62.0</apiVersion>
    <description>Orchestrator for Checklist Item record triggers. Detects completion transitions (Status → Completed or Necessary → No) and delegates to pro_ChecklistNotificationHandler invocable Apex for notification processing.</description>
    <label>Checklist Item Orchestrator</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>1 OR 2</filterLogic>
        <filters>
            <field>pro_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Completed</stringValue>
            </value>
        </filters>
        <filters>
            <field>pro_Necessary__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>No</stringValue>
            </value>
        </filters>
        <object>pro_Checklist_Item__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Call_Notification_Handler</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
