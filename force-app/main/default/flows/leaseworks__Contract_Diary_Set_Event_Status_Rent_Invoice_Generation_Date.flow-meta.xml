<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <decisions>
        <name>Is_Link_To_Invoice_Populated</name>
        <label>Is Link To Invoice populated?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.leaseworks__Link_to_Invoice__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Link_to_Invoice__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Event_Status_on_Contract_Diary_to_Closed</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
        <rules>
            <name>No</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.leaseworks__Link_to_Invoice__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Link_to_Invoice__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Event_Status_on_Contract_Diary_to_Open</targetReference>
            </connector>
            <label>No</label>
        </rules>
    </decisions>
    <description>On a Rent Slip record, if the Link To Invoice value is updated, we set the Event Status on the related Contract Diary record accordingly.</description>
    <environments>Default</environments>
    <interviewLabel>Set Event Status {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Contract Diary  -  Set Event Status - Rent Invoice Generation Date</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Event_Status_on_Contract_Diary_to_Closed</name>
        <label>Set Event Status on Contract Diary to Closed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Copy_2_of_Contract_Diary_Default_Error_Messsage</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>leaseworks__Link_URL__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Rent_Invoice_Generation_Date</stringValue>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Contract__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__RentPayments__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>leaseworks__Event_Status__c</field>
            <value>
                <stringValue>Closed</stringValue>
            </value>
        </inputAssignments>
        <object>leaseworks__Contract_Diary__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Set_Event_Status_on_Contract_Diary_to_Open</name>
        <label>Set Event Status on Contract Diary to Open</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Contract_Diary_Default_Error_Messsage</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>leaseworks__Link_URL__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Rent_Invoice_Generation_Date</stringValue>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Contract__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__RentPayments__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>leaseworks__Event_Status__c</field>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </inputAssignments>
        <object>leaseworks__Contract_Diary__c</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Link_To_Invoice_Populated</targetReference>
        </connector>
        <filterFormula>AND(ISCHANGED({!$Record.leaseworks__Link_to_Invoice__c}),AND({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}=FALSE,{!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c} = FALSE))</filterFormula>
        <object>leaseworks__Rent__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>ErrorMessage</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;An unexpected error has occurred. Please contact your System Administrator.&lt;/p&gt;</text>
    </textTemplates>
</Flow>
