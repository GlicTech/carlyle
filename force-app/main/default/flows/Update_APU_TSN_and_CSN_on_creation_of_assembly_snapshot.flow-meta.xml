<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <environments>Default</environments>
    <formulas>
        <name>AssemblyType</name>
        <dataType>String</dataType>
        <expression>{!$Record.leaseworks__Assembly_Type__c}</expression>
    </formulas>
    <interviewLabel>Update APU TSN and CSN {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update APU TSN and CSN on creation of assembly snapshot</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Copy_1_of_Enable_Triggers</name>
        <label>Enable Triggers</label>
        <locationX>440</locationX>
        <locationY>647</locationY>
        <inputAssignments>
            <field>leaseworks__Disable_All_Triggers__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Disable_All_WFs__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <object>leaseworks__LeaseWorksSettings__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Disable_Triggers</name>
        <label>Disable Triggers</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <connector>
            <targetReference>Update_APU_TSN_and_CSN</targetReference>
        </connector>
        <inputAssignments>
            <field>leaseworks__Disable_All_Triggers__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Disable_All_WFs__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <object>leaseworks__LeaseWorksSettings__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Enable_Triggers</name>
        <label>Enable Triggers</label>
        <locationX>176</locationX>
        <locationY>539</locationY>
        <inputAssignments>
            <field>leaseworks__Disable_All_Triggers__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__Disable_All_WFs__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <object>leaseworks__LeaseWorksSettings__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_APU_TSN_and_CSN</name>
        <label>Update APU TSN and CSN</label>
        <locationX>176</locationX>
        <locationY>431</locationY>
        <connector>
            <targetReference>Enable_Triggers</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Error_while_updating_APU_TSN_and_CSN</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__Assembly_Lkp__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>leaseworks__APU_CSN__c</field>
            <value>
                <elementReference>$Record.leaseworks__Assembly_Lkp__r.leaseworks__CSN__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>leaseworks__APU_TSN__c</field>
            <value>
                <elementReference>$Record.leaseworks__Assembly_Lkp__r.leaseworks__TSN__c</elementReference>
            </value>
        </inputAssignments>
        <object>leaseworks__Constituent_Assembly__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Disable_Triggers</targetReference>
        </connector>
        <filterFormula>AND(
ISPICKVAL({!$Record.leaseworks__Assembly_Lkp__r.leaseworks__Type__c} , &quot;APU&quot;),  
    NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}),
   ISPICKVAL({!$Record.leaseworks__Utilization_Snapshot__r.leaseworks__Type__c}, &quot;Utilization Validation&quot;),
    NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c})
)</filterFormula>
        <object>leaseworks__Assembly_Utilization_Snapshot_New__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
