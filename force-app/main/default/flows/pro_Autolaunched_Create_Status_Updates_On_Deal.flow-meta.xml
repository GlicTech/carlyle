        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Commercial_Field_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varTriggeringDeal.pro_Commercial_Weekly_Summary_Notes_2__c</leftValueReference>
