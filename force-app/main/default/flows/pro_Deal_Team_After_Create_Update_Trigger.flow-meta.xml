<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <decisions>
        <name>Has_Member_Role_Or_Assigned_To_Been_Updated</name>
        <label>Has Member Role Or Assigned To Been Updated?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Updated_Synced_AiD_Approvers</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.leaseworks__Assigned_To__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.pro_Member_Role__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_AiD_Approvers</targetReference>
            </connector>
            <label>Yes - Updated Synced AiD Approvers</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Deal_Team_New</name>
        <label>Is Deal Team New?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Has_Member_Role_Or_Assigned_To_Been_Updated</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Create_Corresponding_AiD_Approvers</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>f_IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_AiD_Approvers</targetReference>
            </connector>
            <label>Yes - Create Corresponding AiD Approvers</label>
        </rules>
    </decisions>
    <description>This flow is to be used as a trigger. Use decision elements as entry criteria to call subflows containing logic.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <interviewLabel>Deal Team - After Create / Update Trigger {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Deal Team - After Create / Update Trigger</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Deal_Team_New</targetReference>
        </connector>
        <filterFormula>OR(
      ISNEW(),
      ISCHANGED({!$Record.leaseworks__Assigned_To__c}),
      ISCHANGED({!$Record.pro_Member_Role__c})
)</filterFormula>
        <object>leaseworks__Deal_Team__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Create_AiD_Approvers</name>
        <label>Create AiD Approvers</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Has_Member_Role_Or_Assigned_To_Been_Updated</targetReference>
        </connector>
        <flowName>pro_Autolaunched_Sync_Deal_Teams_To_AiD_Approvers</flowName>
        <inputAssignments>
            <name>varTriggerContext</name>
            <value>
                <stringValue>Create</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varTriggeringDealTeam</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <subflows>
        <name>Update_AiD_Approvers</name>
        <label>Update AiD Approvers</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>pro_Autolaunched_Sync_Deal_Teams_To_AiD_Approvers</flowName>
        <inputAssignments>
            <name>varTriggerContext</name>
            <value>
                <stringValue>Update</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varTriggeringDealTeam</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
