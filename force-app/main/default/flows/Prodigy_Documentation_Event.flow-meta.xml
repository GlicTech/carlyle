    <decisions>
        <description>Check if the Sync Documentation Events checkbox is checked on the parent Deal</description>
        <name>Are_Documentation_Events_Synced_On_The_Deal</name>
        <label>Are Documentation Events Synced On The Deal?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Synced</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.pro_Asset_in_Deal__r.leaseworks__Marketing_Activity__r.pro_Sync_Documentation__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_All_Assets_In_Deal</targetReference>
            </connector>
            <label>Yes - Synced</label>
        </rules>
    </decisions>
    <decisions>
        <description>If running user has a valid email, send error information.</description>
        <name>Does_Running_User_Have_An_Invalid_Email</name>
        <label>Does Running User Have An Invalid Email?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Send_Error_Email</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Invalid_Email</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$User.Email</leftValueReference>
                <operator>EndsWith</operator>
                <rightValue>
                    <stringValue>invalid</stringValue>
                </rightValue>
            </conditions>
            <label>Yes - Invalid Email</label>
        </rules>
    </decisions>
    <decisions>
        <description>If LOI Date is not populated, set it to the same value as on the parent AiD to the triggering Documentation Event</description>
        <name>Is_LOI_Date_Populated</name>
        <label>Is LOI Date Populated?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_LOI_Date_on_Related_AiDs</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No - Blank</defaultConnectorLabel>
        <rules>
            <name>Yes_Populated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Related_AiDs.LOI_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Related_AiDs</targetReference>
            </connector>
            <label>Yes - Populated</label>
        </rules>
    </decisions>
    <description>Documentation Event Tracking

Flow runs on update of Documentation Event records and if Documentation Events are synced on the Deal, updates related Documentation Events to reflect the values of the triggering record.</description>
    <environments>Default</environments>
    <interviewLabel>Prodigy - Documentation Event {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - Documentation Event - Update Synced Events</label>
    <loops>
        <name>Loop_Related_AiDs</name>
        <label>Loop Related AiDs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_All_Assets_In_Deal</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Is_LOI_Date_Populated</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Set_LOI_On_AiDs</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
