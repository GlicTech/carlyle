<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <environments>Default</environments>
    <interviewLabel>Copy Interaction Logs to the Project {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Copy Interaction Logs to the Project</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Create the interaction Logs</description>
        <name>Create_Interaction_Logs_on_The_Project</name>
        <label>Create Interaction Logs on The Project</label>
        <locationX>176</locationX>
        <locationY>539</locationY>
        <inputReference>Transform_the_Interaction_Log</inputReference>
    </recordCreates>
    <recordLookups>
        <name>Get_Interaction_Logs</name>
        <label>Get Interaction Logs</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Transform_the_Interaction_Log</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>leaseworks__Related_To_Aircraft__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__Asset__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Related_To_Lease__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__Lease_Name__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>leaseworks__Discussion_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Technical</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>leaseworks__Customer_Interaction_Log__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Interaction_Logs</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>leaseworks__Asset__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>leaseworks__Technical_Project__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
