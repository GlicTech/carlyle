    </formulas>
    <formulas>
        <name>f_IsIncrementedDateWeekDay</name>
        <dataType>Boolean</dataType>
        <expression>NOT(
  OR(
    WEEKDAY({!varActualDate}) = 1, 
    WEEKDAY({!varActualDate}) = 7 
  )
)</expression>
