<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <description>This flow will update the Lease option name on the basis of Option Type and Option Notice End Date</description>
    <environments>Default</environments>
    <formulas>
        <description>This will form the name using Option type and Option / Notice End</description>
        <name>FormulatedLeaseOptionName</name>
        <dataType>String</dataType>
        <expression>IF(
 ISBLANK({!$Record.leaseworks__Option_Notice_End__c}),
 TEXT({!$Record.leaseworks__Option_Type__c}),
 TEXT({!$Record.leaseworks__Option_Type__c}) &amp; &#39; - &#39; &amp; TEXT({!$Record.leaseworks__Option_Notice_End__c})
)</expression>
    </formulas>
    <interviewLabel>Update Lease Option Name {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Update Lease Option Name</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>This will update the option name to &lt;Option Type&gt;+&lt;Option/Notice End&gt;</description>
        <name>Update_Lease_Option_Name</name>
        <label>Update Lease Option Name</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>FormulatedLeaseOptionName</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Lease_Option_Name</targetReference>
        </connector>
        <filterFormula>AND(NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_Triggers__c}),NOT({!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c}))</filterFormula>
        <object>leaseworks__Lease_Options__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
