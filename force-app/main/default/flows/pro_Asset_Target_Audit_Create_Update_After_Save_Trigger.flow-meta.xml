<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <customErrors>
        <name>Error_Updating_Outcome_Error</name>
        <label>Error Updating Outcome Error</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <customErrorMessages>
            <errorMessage>There was an error updating the Outcome of a related Asset Target Audit.

Updating Flow: Asset Target Audit - Create / Update After Save Trigger</errorMessage>
            <isFieldError>false</isFieldError>
        </customErrorMessages>
    </customErrors>
    <decisions>
        <name>Was_Outcome_Affected_By_Update</name>
        <label>Was Outcome or Target Forecast Affected By Update?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Outcome_Affected</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.pro_Progress__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.pro_Progress__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.pro_Target_Forecast__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.pro_Target_Forecast__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Target_End_Date</targetReference>
            </connector>
            <label>Yes - Outcome Affected</label>
        </rules>
    </decisions>
    <description>Flow runs after an Asset Target Audit is created or updated. Syncs the Target End Date from the related Target. The Progress Picklist sync has been moved to the Pro_ProgressSyncTrigger (Apex before-save trigger) per US-011.</description>
    <environments>Default</environments>
    <interviewLabel>Asset Target Audit - Create / Update After Save Trigger {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Asset Target Audit - Create / Update After Save Trigger</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Update the Target End Date field from the related Target record</description>
        <name>Update_Target_End_Date</name>
        <label>Update Target End Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Error_Updating_Outcome_Error</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>pro_Target_End_Date__c</field>
            <value>
                <elementReference>$Record.pro_Target_Forecast__r.pro_End_Date__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Was_Outcome_Affected_By_Update</targetReference>
        </connector>
        <object>pro_Asset_Target_Audit__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
