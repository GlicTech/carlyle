<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <assignments>
        <description>Assign the value of the screen toggle button so it can be maintained on the next flow run through.</description>
        <name>Assign_Toggle_Value</name>
        <label>Assign Toggle Value</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>Get_Triggering_Ticket.pro_Assets__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Assets</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Set_Assets_Field_On_Ticket</targetReference>
        </connector>
    </assignments>
    <description>Tickets Phase 2

Flow to be launched from an Action on the Ticket record page. Gives users the ability to add/remove Non Carlyle Assets from the Assets field</description>
    <environments>Default</environments>
    <interviewLabel>Prodigy - Screen {!$Flow.CurrentDateTime}</interviewLabel>
