        <object>pro_Ticket__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Overwrite the field to include it&#39;s previous input plus the users newest input</description>
        <name>Set_Assets_Field_On_Ticket</name>
        <label>Set Assets Field On Ticket</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
