    <decisions>
        <description>If Interaction Log Type is any of these, then no emails need to be sent.</description>
        <name>IL_Is_Type_Commercial_Technical_Or_Contracts_Legal_Weekly_Summary_Note</name>
        <label>IL Is Type Commercial, Technical, Or Contracts/Legal Weekly Summary Note</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_Base_Distribution_List</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_End_Process</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.leaseworks__Type_Of_Interaction__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Commercial Weekly Summary Note</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.leaseworks__Type_Of_Interaction__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Technical Weekly Summary Note</stringValue>
                </rightValue>
            </conditions>
            <conditions>
