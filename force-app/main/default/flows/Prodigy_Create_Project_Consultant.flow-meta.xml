    <formulas>
        <name>f_ConcatenatedName</name>
        <dataType>String</dataType>
        <expression>{!cl_ProjectConsultants.selectedChoiceLabels} + &#39; - &#39; + {!pl_Project_Role}</expression>
    </formulas>
    <formulas>
        <name>f_DaysBudgetedByRole</name>
        <dataType>Number</dataType>
        <expression>IF({!pl_Project_Role} = &quot;Project Manager&quot;, {!recordId.pro_Project_Manager_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Project Lead/Physical&quot;, {!recordId.pro_Project_Lead_Physical_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Project Lead/Records&quot;, {!recordId.pro_Project_Lead_Records_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Physical Aircraft&quot;, {!recordId.pro_Physical_Aircraft_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Aircraft Records&quot;, {!recordId.pro_Aircraft_Records_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Engine On-Wing Support&quot;, {!recordId.pro_Engine_On_Wing_Support_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Engineering Support&quot;, {!recordId.pro_Engineering_Support_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Cabin Inspection&quot;, {!recordId.pro_Cabin_Inspection_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;New A/C Support&quot;, {!recordId.pro_New_A_C_Support_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;BFE Support&quot;, {!recordId.pro_BFE_Support_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Material Support&quot;, {!recordId.pro_Material_Support_Days_Budgeted__c},
IF({!pl_Project_Role} = &quot;Non-Project Support&quot;, {!recordId.pro_Non_Project_Support_Days_Budgeted__c},
IF({!pl_Project_Role}= &quot;Other&quot;, {!recordId.pro_Other_Days_Budgeted__c},
0
)))))))))))))</expression>
        <scale>2</scale>
    </formulas>
