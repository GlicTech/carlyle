<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <assignments>
        <name>Assign_Triggering_Deal_Team_As_LOI_Approver</name>
        <label>Assign Triggering Deal Team As LOI Approver</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.pro_Include_In_LOI_Approvals__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_CMDT_For_LOI_Approvals.pro_Include_In_LOI_Approvals__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Triggering_Record</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>If no CMDT record found, end flow</description>
        <name>CMDT_Record_Found</name>
        <label>CMDT Record Found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_CMDT_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_CMDT_For_LOI_Approvals.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Triggering_Deal_Team_As_LOI_Approver</targetReference>
            </connector>
            <label>Yes - CMDT Found</label>
        </rules>
    </decisions>
    <decisions>
        <description>If Deal Type is Non Deal Approvals, end the flow as no need to set LOI Approvers for this type.</description>
        <name>Copy_1_of_Is_Deal_Type_Non_Deal_Approvals</name>
        <label>Copy 1 of Is Deal Type Non Deal Approvals</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_Deal_Team_With_Same_Member_Role</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Copy_1_of_Yes_Non_Deal_Approval</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approval</stringValue>
                </rightValue>
            </conditions>
            <label>Copy 1 of Yes - Non Deal Approval</label>
        </rules>
    </decisions>
    <decisions>
        <name>Does_Member_Role_Already_Exist_On_Deal</name>
        <label>Does Member Role Already Exist On Deal?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_CMDT_For_LOI_Approvals</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Member_Role_Already_On_Deal</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Deal_Team_With_Same_Member_Role.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Duplicate_Approver_Role_As_True</targetReference>
            </connector>
            <label>Yes - Member Role Already On Deal</label>
        </rules>
    </decisions>
    <description>LOI &amp; Documentation Approvals

Before save flow sets the default value of the Include In LOI Approvals field based on the Member Role. Thereby, only having those who are defined as LOI Approvers defaulted to Include In LOI Approvals = True</description>
    <environments>Default</environments>
    <interviewLabel>Prodigy - Deal Team - Set Value For Include In LOI Approvals {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - Deal Team - Set Value For Include In LOI Approvals</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get CMDT that defines which roles to be included in LOI Approvals</description>
        <name>Get_CMDT_For_LOI_Approvals</name>
        <label>Get CMDT For LOI Approvals</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>CMDT_Record_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>pro_Deal_Team_Name__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Name</elementReference>
            </value>
        </filters>
        <filters>
            <field>Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>LOI Approver</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Deal_Team_Mapping__mdt</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Deal_Team_With_Same_Member_Role</name>
        <label>Get Deal Team With Same Member Role</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Does_Member_Role_Already_Exist_On_Deal</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>leaseworks__Marketing_Activity__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.leaseworks__Marketing_Activity__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Id</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Name</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Name</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>leaseworks__Deal_Team__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Set_Duplicate_Approver_Role_As_True</name>
        <label>Set Duplicate Approver Role As True</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>pro_Department_Approval_Complete__c</field>
            <value>
                <elementReference>Get_Deal_Team_With_Same_Member_Role.pro_Department_Approval_Complete__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>pro_Duplicate_Approver_Role__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Triggering_Record</name>
        <label>Update Triggering Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Copy_1_of_Is_Deal_Type_Non_Deal_Approvals</targetReference>
        </connector>
        <object>leaseworks__Deal_Team__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
