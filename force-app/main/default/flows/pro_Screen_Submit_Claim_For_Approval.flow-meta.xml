    <decisions>
        <name>Does_Inner_Loop_Match_Outer_Loop</name>
        <label>Does Inner Loop Match Outer Loop?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Claim_Approval_Settings</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Inner_Loop_Matches_Outer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Claim_Approval_Settings.pro_Username__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_Default_Approvers.Username</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_The_Mapping_For_Finance_or_Technical</targetReference>
            </connector>
            <label>Yes - Inner Loop Matches Outer</label>
        </rules>
    </decisions>
