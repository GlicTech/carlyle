    <decisions>
        <description>If User is assigned to permission set, need to delete the assignment record. Otherwise, the flow can end.</description>
        <name>Is_User_Assigned_To_Permission_Set</name>
        <label>Is User Assigned To Permission Set?</label>
        <locationX>0</locationX>
