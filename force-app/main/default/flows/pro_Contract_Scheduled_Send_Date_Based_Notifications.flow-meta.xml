    <description>Runs every morning at 9am on any Contract records that have the relevant date fields populated. Decision elements used to conditionally send any notifications due based on date fields.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_ContractEndDateNotification</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.leaseworks__Lease_End_Date_New__c} - 10 = TODAY() || {!$Record.leaseworks__Lease_End_Date_New__c} - 60 = TODAY(),
      True, False)</expression>
    </formulas>
    <formulas>
        <name>f_LOCExpiryNotificationDue</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.leaseworks__Letter_of_Credit_Expiry__c} - 15 = TODAY() || {!$Record.leaseworks__Letter_of_Credit_Expiry__c} - 45 = TODAY(),
      True, False)</expression>
    </formulas>
