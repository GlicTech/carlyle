<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Runs 1 minute after a Deal is created and sets up the Deal Team. Need to be async as some roles are dynamically selected based on AiD which gets created after the Deal.</description>
    <environments>Default</environments>
    <interviewLabel>Prodigy - Deal - Deal Team Setup Async Trigger {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Prodigy - Deal - Deal Team Setup Async Trigger</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <object>leaseworks__Marketing_Activity__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <scheduledPaths>
            <name>Create_Deal_Team_1_Minute_After</name>
            <connector>
                <targetReference>Set_Up_Deal_Teams</targetReference>
            </connector>
            <label>Create Deal Team 1 Minute After</label>
            <offsetNumber>1</offsetNumber>
            <offsetUnit>Minutes</offsetUnit>
            <timeSource>RecordTriggerEvent</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Set_Up_Deal_Teams</name>
        <label>Set Up Deal Teams</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>pro_Autolaunched_Set_Deal_Teams_From_CMDT</flowName>
        <inputAssignments>
            <name>varTriggeringDeal</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
