<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign link values from update screen to ticket</description>
        <name>Assign_Link_Values_To_Ticket</name>
        <label>Assign Link Values To Ticket</label>
        <locationX>176</locationX>
        <locationY>350</locationY>
        <assignmentItems>
            <assignToReference>varTicketId.pro_Internal_Sharepoint_Link_Long__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>New_Internal_Shrepoint_Link</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTicketId.pro_Sharefile_Link_Long__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>New_Sharefile_Link</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTicketId.pro_ATS_Link_Long__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>New_ATS_Link</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Triggering_Ticket</targetReference>
        </connector>
    </assignments>
    <description>Flow allows for creation of document link of over 255 characters while insuring that the link does not get broken. Does this by creating link within a flow formula and surfacing this on a screen.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_ATSLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!varTicketId.pro_ATS_Link_Long__c}, 150) &amp; &apos;...&apos;</expression>
    </formulas>
    <formulas>
        <name>f_InternalSharepointLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!varTicketId.pro_Internal_Sharepoint_Link_Long__c}, 150) &amp; &apos;...&apos;</expression>
    </formulas>
    <formulas>
        <name>f_SharefileLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!varTicketId.pro_Sharefile_Link_Long__c}, 150) &amp; &apos;...&apos;</expression>
    </formulas>
    <interviewLabel>Prodigy - Dynamic Display Of Document Link {!$Flow.CurrentDateTime}</interviewLabel>
