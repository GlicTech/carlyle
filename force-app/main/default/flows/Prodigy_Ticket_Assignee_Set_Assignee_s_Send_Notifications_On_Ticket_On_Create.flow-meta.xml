    <textTemplates>
        <name>tt_AssigneeEmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Hi {!$Record.pro_Assigned_To__r.FirstName} {!$Record.pro_Assigned_To__r.LastName},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;A new support ticket has been created and assigned to you in Salesforce.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Ticket Details:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;MSN: &lt;/strong&gt;{!$Record.pro_Ticket__r.pro_Assets__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;External Party: &lt;/strong&gt;{!Get_Related_Ticket.pro_External_Party__r.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Requested By: &lt;/strong&gt;{!Get_Related_Ticket.pro_Requested_By__r.FirstName} &lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;{!Get_Related_Ticket.pro_Requested_By__r.LastName}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Assignee Instruction: &lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;{!$Record.pro_Assignee_Instruction__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Type:&lt;/strong&gt; {!Get_Related_Ticket.pro_Type__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Priority: &lt;/strong&gt;{!Get_Related_Ticket.pro_Priority__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Status:&lt;/strong&gt; {!Get_Related_Ticket.pro_Status__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Created Date:&lt;/strong&gt; {!Get_Related_Ticket.CreatedDate}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Expected Due Date: &lt;/strong&gt;{!Get_Related_Ticket.pro_Expected_Due_Date__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Title: &lt;/strong&gt;{!Get_Related_Ticket.pro_Title__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Description:&lt;/strong&gt; {!Get_Related_Ticket.pro_Comments__c}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;You can view the full details and take action by clicking the link: &lt;a href=&quot;https://leaseworks-carlyle.lightning.force.com/{!$Record.pro_Ticket__c}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;View Ticket in Salesforce&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Kind regards,&lt;/p&gt;&lt;p&gt;Salesforce System Notification&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;em&gt;This message was generated automatically. For assistance, please contact your Salesforce administrator.&lt;/em&gt;&lt;/p&gt;</text>
