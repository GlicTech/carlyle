    <decisions>
        <name>Is_Assignee_Id_Collection_Populated</name>
        <label>Is Assignee Id Collection Populated?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Assignee_Collection_Populated</name>
            <conditionLogic>and</conditionLogic>
