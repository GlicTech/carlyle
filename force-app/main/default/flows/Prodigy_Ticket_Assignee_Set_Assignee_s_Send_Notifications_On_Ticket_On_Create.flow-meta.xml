        </rules>
    </decisions>
    <decisions>
        <description>Requestor notifications should only be sent out for header tickets, not sub-tickets. This element checks what type of Ticket.</description>
        <name>Is_This_A_Header_Ticket</name>
        <label>Is This A Header Ticket?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Is_Assignee_Id_Collection_Populated</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Header_Ticket</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.pro_Ticket__r.pro_Is_SubTicket__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Notify_Requestor</targetReference>
            </connector>
            <label>Yes - Header Ticket</label>
        </rules>
    </decisions>
