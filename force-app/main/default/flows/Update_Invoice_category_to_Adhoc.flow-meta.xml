        <filterFormula>AND(
    ISPICKVAL({!$Record.leaseworks__Invoice_Type__c}, &quot;Rent&quot;),
    ISPICKVAL({!$Record.leaseworks__Invoice_Category__c}, &quot;Manual Rent&quot;),
    ISPICKVAL({!$Record.leaseworks__Status__c}, &quot;Pending&quot;),
    {!$Record.leaseworks__Rent__r.leaseworks__Stepped_Rent__r.Ad_hoc_Schedule_Local__c} = True,
