        <rules>
            <name>Yes_Related_Lease_is_Active</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Loop_through_Active_Party_to_Lease_Records.leaseworks__Contract__r.leaseworks__Lease_Type_Status__c</leftValueReference>
