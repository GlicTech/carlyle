)
)</expression>
    </formulas>
    <formulas>
        <name>f_QueryRelatedAssemblies</name>
        <dataType>String</dataType>
        <expression>&quot;SELECT Name, Id, leaseworks__Type__c, leaseworks__Last_CSN_Utilization__c, leaseworks__Last_TSN_Utilization__c, leaseworks__Comments__c FROM leaseworks__Constituent_Assembly__c WHERE leaseworks__Attached_Aircraft__c = &apos;&quot; &amp; {!recordId.pro_Asset__c} &amp; &quot;&apos;&quot;</expression>
    </formulas>
    <formulas>
        <name>f_QueryRelatedUtilizations</name>
        <dataType>String</dataType>
        <expression>&quot;SELECT Name, Id, leaseworks__Month_Ending__c, leaseworks__Airframe_Cycles_Landing_During_Month__c, leaseworks__Airframe_Flight_Hours_Month__c, leaseworks__Engineering_Modifications_or_Changes__c	 FROM leaseworks__Utilization_Report__c WHERE leaseworks__Aircraft__c = &apos;&quot; &amp; {!recordId.pro_Asset__c}&amp; &quot;&apos; ORDER BY leaseworks__Month_Ending__c DESC&quot;</expression>
    </formulas>
