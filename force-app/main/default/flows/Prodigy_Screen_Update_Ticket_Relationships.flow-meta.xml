        <name>f_AssetInputValid</name>
        <dataType>Boolean</dataType>
        <expression>OR(

AND(
      {!recordId.pro_Non_Carlyle_Asset_MSN__c} != Null,
      {!recordId.pro_Non_Carlyle_Asset__c} = True
)

,


AND(
