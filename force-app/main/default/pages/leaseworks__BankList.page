<apex:page controller="leaseworks.BankList_PageController"   lightningStylesheets="true">
<head>

<style>

@page{    
                /* Landscape orientation */
                  size:A4 landscape;
                  margin:0.25in;
            }     
table, th, td {
    border: 2px solid black;
     padding: 15px;
}

th {
    height: 50px;
    text-align: center;
    background-color: #6A77B4;
     color: white;
}
tr:nth-child(even) {background-color: #E8E8E8;}
tr:hover {background-color: #f5f5f5;}
h1 {
    font-size: 40px;
}

p {
    font-size: 12px;
}

</style> 

</head> 
<div style="overflow-x:auto;">
   <table align="center" cellpadding="5">
    <thead>
      <tr>
               
      </tr>
    </thead>
    <tbody>
      <apex:repeat value="{!LstBank1}" var="b1">  
          <tr>
            <td align="center" ><p><apex:image id="theImage1" value="{!b1.IMG1}" width="200" rendered="{!IF(ISBLANK(b1.IMG1) , false , true)}" height="75" alt="Description of image here"/></p>
                <apex:repeat value="{!b1.issuances1}" var="IssuanceVar">
                    <p align="left">- {!IssuanceVar.IssuanceType} : {!IssuanceVar.RelatioShip} </p> 
                </apex:repeat>
                <br/> 
            </td>
                   
            <td align="center"><p><apex:image id="theImage2" value="{!b1.IMG2}" width="200" rendered="{!IF(ISBLANK(b1.IMG2) , false , true)}" height="75" alt="Description of image here"/></p>
               <apex:repeat value="{!b1.issuances2}" var="IssuanceVar">
                    <p align="left">- {!IssuanceVar.IssuanceType} : {!IssuanceVar.RelatioShip} </p> 
                </apex:repeat>
             </td>
            <td align="center"><p><apex:image id="theImage3" value="{!b1.IMG3}" width="200" rendered="{!IF(ISBLANK(b1.IMG3) , false , true)}" height="75" alt="Description of image here"/></p>
                 <apex:repeat value="{!b1.issuances3}" var="IssuanceVar">
                    <p align="left">- {!IssuanceVar.IssuanceType} : {!IssuanceVar.RelatioShip} </p> 
                </apex:repeat> 
            </td>
          
            <td align="center"><p><apex:image id="theImage4" value="{!b1.IMG4}" width="200" rendered="{!IF(ISBLANK(b1.IMG4) , false , true)}" height="75" alt="Description of image here"/></p>
              <apex:repeat value="{!b1.issuances4}" var="IssuanceVar">
                    <p align="left">- {!IssuanceVar.IssuanceType} : {!IssuanceVar.RelatioShip} </p> 
                </apex:repeat> 
            </td>
          </tr> 
       </apex:repeat>    
    </tbody>
  </table>
 </div>
</apex:page>