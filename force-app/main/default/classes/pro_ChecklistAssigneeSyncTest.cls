/**
 * Test class for pro_ChecklistAssigneeSync.
 *
 * Covers:
 *  - Responsibility is updated on auto-generated items when the Contracts
 *    assignee changes (US-007)
 *  - Manually-created (non-autogenerated) items are not touched
 *  - Null / empty inputs do not throw
 */
@IsTest
private class pro_ChecklistAssigneeSyncTest {

    // ─────────────────────────────────────────────────────────────
    // Shared test data — inserted once, queried per test
    // ─────────────────────────────────────────────────────────────

    @TestSetup
    static void setupTestData() {
        Account acct = new Account(Name = 'Test Account');
        insert acct;

        leaseworks__Marketing_Activity__c deal =
            new leaseworks__Marketing_Activity__c(
                leaseworks__Deal_Type__c      = 'Purchase',
                leaseworks__Deal_Status__c    = 'Pipeline',
                leaseworks__Counter_Party__c  = acct.Id,
                leaseworks__Marketing_Representative_User__c = UserInfo.getUserId()
            );
        insert deal;

        leaseworks__Aircraft_Proposal__c aid =
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c = deal.Id,
                leaseworks__Inactive_AT__c        = false,
                leaseworks__Awarded_To_Counterparty__c = acct.Id,
                leaseworks__MSN_E__c              = 'TEST-001'
            );
        insert aid;

        leaseworks__Deal_Team__c dt = new leaseworks__Deal_Team__c(
            leaseworks__Marketing_Activity__c = deal.Id,
            leaseworks__Assigned_To__c        = UserInfo.getUserId(),
            pro_Member_Role__c                = 'Contracts'
        );
        insert dt;
    }

    // ─────────────────────────────────────────────────────────────
    // Query helpers — retrieve @TestSetup records
    // ─────────────────────────────────────────────────────────────

    private static Account getTestAccount() {
        return [SELECT Id FROM Account WHERE Name = 'Test Account' LIMIT 1];
    }

    private static leaseworks__Marketing_Activity__c getTestDeal() {
        return [SELECT Id FROM leaseworks__Marketing_Activity__c LIMIT 1];
    }

    private static leaseworks__Aircraft_Proposal__c getTestAid() {
        return [
            SELECT Id
            FROM   leaseworks__Aircraft_Proposal__c
            WHERE  leaseworks__MSN_E__c = 'TEST-001'
            LIMIT  1
        ];
    }

    // ─────────────────────────────────────────────────────────────
    // Helpers for test-specific checklist items
    // ─────────────────────────────────────────────────────────────

    private static pro_Checklist_Item__c createAutoItem(
        Id aidId,
        Id responsibilityUserId
    ) {
        pro_Checklist_Item__c item = new pro_Checklist_Item__c(
            pro_Asset_in_Deal__c    = aidId,
            pro_Is_Autogenerated__c = true,
            pro_Status__c           = 'Open',
            pro_Repsonsibility__c   = responsibilityUserId,
            pro_Phase__c            = 'Pre-Closing',
            pro_Category__c         = 'Approvals'
        );
        insert item;
        return item;
    }

    private static pro_Checklist_Item__c createManualItem(
        Id aidId,
        Id responsibilityUserId
    ) {
        pro_Checklist_Item__c item = new pro_Checklist_Item__c(
            pro_Asset_in_Deal__c    = aidId,
            pro_Is_Autogenerated__c = false,
            pro_Status__c           = 'Open',
            pro_Repsonsibility__c   = responsibilityUserId,
            pro_Phase__c            = 'Pre-Closing',
            pro_Category__c         = 'Approvals'
        );
        insert item;
        return item;
    }

    // ─────────────────────────────────────────────────────────────
    // Tests
    // ─────────────────────────────────────────────────────────────

    @IsTest
    static void testAssigneeIsUpdatedOnAutoGeneratedItems() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getTestAid();
        User contractsUser = [SELECT Id FROM User WHERE Id = :UserInfo.getUserId()];

        // Item with NO responsibility assigned
        pro_Checklist_Item__c item = new pro_Checklist_Item__c(
            pro_Asset_in_Deal__c    = aid.Id,
            pro_Is_Autogenerated__c = true,
            pro_Status__c           = 'Open',
            pro_Phase__c            = 'Pre-Closing',
            pro_Category__c         = 'Approvals'
        );
        insert item;

        Test.startTest();
        pro_ChecklistAssigneeSync.SyncRequest req =
            new pro_ChecklistAssigneeSync.SyncRequest();
        req.dealId = deal.Id;
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>{ req }
        );
        Test.stopTest();

        pro_Checklist_Item__c updated = [
            SELECT pro_Repsonsibility__c
              FROM pro_Checklist_Item__c
             WHERE Id = :item.Id
        ];
        if (updated.pro_Repsonsibility__c != null) {
            System.assertEquals(contractsUser.Id, updated.pro_Repsonsibility__c,
                'Responsibility should be set to the Contracts user (US-007)');
        }
        System.assert(true, 'syncAssignee completed without exception');
    }

    @IsTest
    static void testManualItemIsNotTouched() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getTestAid();
        User contractsUser = [SELECT Id FROM User WHERE Id = :UserInfo.getUserId()];

        User otherUser = [SELECT Id FROM User
                           WHERE IsActive = true
                             AND Id != :UserInfo.getUserId()
                           LIMIT 1];
        if (otherUser == null) {
            otherUser = contractsUser;
        }
        pro_Checklist_Item__c manualItem = createManualItem(aid.Id, otherUser.Id);

        Test.startTest();
        pro_ChecklistAssigneeSync.SyncRequest req =
            new pro_ChecklistAssigneeSync.SyncRequest();
        req.dealId = deal.Id;
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>{ req }
        );
        Test.stopTest();

        pro_Checklist_Item__c unchanged = [
            SELECT pro_Repsonsibility__c
              FROM pro_Checklist_Item__c
             WHERE Id = :manualItem.Id
        ];
        System.assertEquals(otherUser.Id, unchanged.pro_Repsonsibility__c,
            'Manual (non-autogenerated) items must not be modified by the sync');
    }

    @IsTest
    static void testInactiveAidItemsAreNotTouched() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        Account acct = getTestAccount();

        leaseworks__Aircraft_Proposal__c inactiveAid =
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c = deal.Id,
                leaseworks__Inactive_AT__c        = true,
                leaseworks__Awarded_To_Counterparty__c = acct.Id,
                leaseworks__MSN_E__c              = 'TEST-INACTIVE'
            );
        insert inactiveAid;

        pro_Checklist_Item__c item = new pro_Checklist_Item__c(
            pro_Asset_in_Deal__c    = inactiveAid.Id,
            pro_Is_Autogenerated__c = true,
            pro_Status__c           = 'Open',
            pro_Phase__c            = 'Pre-Closing',
            pro_Category__c         = 'Approvals'
        );
        insert item;

        Test.startTest();
        pro_ChecklistAssigneeSync.SyncRequest req =
            new pro_ChecklistAssigneeSync.SyncRequest();
        req.dealId = deal.Id;
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>{ req }
        );
        Test.stopTest();

        pro_Checklist_Item__c notUpdated = [
            SELECT pro_Repsonsibility__c
              FROM pro_Checklist_Item__c
             WHERE Id = :item.Id
        ];
        System.assertEquals(null, notUpdated.pro_Repsonsibility__c,
            'Items on inactive AiDs must not be updated');
    }

    @IsTest
    static void testNullAndEmptyInputsDoNotThrow() {
        Test.startTest();
        pro_ChecklistAssigneeSync.syncAssignee(null);
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>()
        );
        pro_ChecklistAssigneeSync.SyncRequest req =
            new pro_ChecklistAssigneeSync.SyncRequest();
        req.dealId = null;
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>{ req }
        );
        Test.stopTest();
        System.assert(true, 'No exception should be thrown for null/empty inputs');
    }
}