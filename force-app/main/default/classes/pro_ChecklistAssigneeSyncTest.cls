/**
 * Test class for pro_ChecklistAssigneeSync.
 *
 * GT-16 fix coverage:
 *  - AC-1: Open items across all active AiDs are reassigned to new Contracts user
 *  - AC-2: Completed items retain their original assignee
 *  - AC-3: Items with Necessary=No are not reassigned (count as done)
 *  - Both auto-generated and manually-created open items are reassigned
 *  - Items on inactive AiDs are not touched
 *  - Null / empty inputs do not throw
 *  - Bulk: 200 items are reassigned in a single invocation
 */
@IsTest
private class pro_ChecklistAssigneeSyncTest {

    private static final String MSN_ACTIVE   = 'TEST-001';
    private static final String MSN_ACTIVE_2 = 'TEST-002';
    private static final String MSN_INACTIVE = 'TEST-INACTIVE';

    // ─────────────────────────────────────────────────────────────
    // Shared test data
    // ─────────────────────────────────────────────────────────────

    @TestSetup
    static void setupTestData() {
        Account acct = new Account(Name = 'Test Account');
        insert acct;

        leaseworks__Marketing_Activity__c deal =
            new leaseworks__Marketing_Activity__c(
                leaseworks__Deal_Type__c      = 'Purchase',
                leaseworks__Deal_Status__c    = 'Pipeline',
                leaseworks__Counter_Party__c  = acct.Id,
                leaseworks__Marketing_Representative_User__c = UserInfo.getUserId()
            );
        insert deal;

        List<leaseworks__Aircraft_Proposal__c> aids = new List<leaseworks__Aircraft_Proposal__c>{
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c       = deal.Id,
                leaseworks__Inactive_AT__c              = false,
                leaseworks__Awarded_To_Counterparty__c  = acct.Id,
                leaseworks__MSN_E__c                    = MSN_ACTIVE
            ),
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c       = deal.Id,
                leaseworks__Inactive_AT__c              = false,
                leaseworks__Awarded_To_Counterparty__c  = acct.Id,
                leaseworks__MSN_E__c                    = MSN_ACTIVE_2
            ),
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c       = deal.Id,
                leaseworks__Inactive_AT__c              = true,
                leaseworks__Awarded_To_Counterparty__c  = acct.Id,
                leaseworks__MSN_E__c                    = MSN_INACTIVE
            )
        };
        insert aids;

        leaseworks__Deal_Team__c dt = new leaseworks__Deal_Team__c(
            leaseworks__Marketing_Activity__c = deal.Id,
            leaseworks__Assigned_To__c        = UserInfo.getUserId(),
            pro_Member_Role__c                = 'Contracts'
        );
        insert dt;
    }

    // ─────────────────────────────────────────────────────────────
    // Query helpers
    // ─────────────────────────────────────────────────────────────

    private static leaseworks__Marketing_Activity__c getTestDeal() {
        return [SELECT Id FROM leaseworks__Marketing_Activity__c LIMIT 1];
    }

    private static leaseworks__Aircraft_Proposal__c getAid(String msn) {
        return [
            SELECT Id
            FROM   leaseworks__Aircraft_Proposal__c
            WHERE  leaseworks__MSN_E__c = :msn
            LIMIT  1
        ];
    }

    // ─────────────────────────────────────────────────────────────
    // Item creation helpers
    // ─────────────────────────────────────────────────────────────

    private static pro_Checklist_Item__c buildItem(
        Id aidId, Id userId, String status, String necessary, Boolean autoGen
    ) {
        return new pro_Checklist_Item__c(
            pro_Asset_in_Deal__c    = aidId,
            pro_Responsibility__c   = userId,
            pro_Status__c           = status,
            pro_Necessary__c        = necessary,
            // Satisfy pro_Comment_Required_When_Not_Necessary VR when Necessary=No.
            pro_Comment_Notes__c    = (necessary == 'No' ? 'Test: not applicable for this asset' : null),
            pro_Is_Autogenerated__c = autoGen,
            pro_Phase__c            = 'Pre-Closing',
            pro_Category__c         = 'Approvals',
            pro_Title__c            = 'Test Item'
        );
    }

    private static void invokeSyncForDeal(Id dealId) {
        pro_ChecklistAssigneeSync.SyncRequest req =
            new pro_ChecklistAssigneeSync.SyncRequest();
        req.dealId = dealId;
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>{ req }
        );
    }

    // ─────────────────────────────────────────────────────────────
    // Tests
    // ─────────────────────────────────────────────────────────────

    /**
     * AC-1: Open items (both auto and manual) get reassigned to
     * the Contracts user.
     */
    @IsTest
    static void testOpenItemsAreReassigned() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getAid(MSN_ACTIVE);
        Id contractsUserId = UserInfo.getUserId();

        // Create items with null responsibility to simulate unassigned state
        List<pro_Checklist_Item__c> items = new List<pro_Checklist_Item__c>{
            buildItem(aid.Id, null, 'Open', 'Yes', true),
            buildItem(aid.Id, null, 'Open', 'Yes', false)
        };
        insert items;

        Test.startTest();
        invokeSyncForDeal(deal.Id);
        Test.stopTest();

        List<pro_Checklist_Item__c> updated = [
            SELECT Id, pro_Responsibility__c, pro_Is_Autogenerated__c
              FROM pro_Checklist_Item__c
             WHERE Id IN :items
             ORDER BY pro_Is_Autogenerated__c DESC
        ];
        System.assertEquals(2, updated.size(), 'Both items should exist');
        for (pro_Checklist_Item__c item : updated) {
            System.assertEquals(
                contractsUserId,
                item.pro_Responsibility__c,
                'Open item (autoGen=' + item.pro_Is_Autogenerated__c + ') should be reassigned to Contracts user'
            );
        }
    }

    /**
     * AC-2: Completed items retain their original assignee.
     */
    @IsTest
    static void testCompletedItemsAreNotReassigned() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getAid(MSN_ACTIVE);

        // Find a different user for the original assignee
        User otherUser = [
            SELECT Id FROM User
             WHERE IsActive = true AND Id != :UserInfo.getUserId()
             LIMIT 1
        ];

        pro_Checklist_Item__c completedItem =
            buildItem(aid.Id, otherUser.Id, 'Completed', 'Yes', true);
        insert completedItem;

        Test.startTest();
        invokeSyncForDeal(deal.Id);
        Test.stopTest();

        pro_Checklist_Item__c result = [
            SELECT pro_Responsibility__c
              FROM pro_Checklist_Item__c
             WHERE Id = :completedItem.Id
        ];
        System.assertEquals(
            otherUser.Id,
            result.pro_Responsibility__c,
            'Completed items must retain their original assignee (AC-2)'
        );
    }

    /**
     * Items with Necessary=No count as done and should NOT be reassigned.
     */
    @IsTest
    static void testNecessaryNoItemsAreNotReassigned() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getAid(MSN_ACTIVE);

        User otherUser = [
            SELECT Id FROM User
             WHERE IsActive = true AND Id != :UserInfo.getUserId()
             LIMIT 1
        ];

        pro_Checklist_Item__c notNecessary =
            buildItem(aid.Id, otherUser.Id, 'Open', 'No', true);
        insert notNecessary;

        Test.startTest();
        invokeSyncForDeal(deal.Id);
        Test.stopTest();

        pro_Checklist_Item__c result = [
            SELECT pro_Responsibility__c
              FROM pro_Checklist_Item__c
             WHERE Id = :notNecessary.Id
        ];
        System.assertEquals(
            otherUser.Id,
            result.pro_Responsibility__c,
            'Items with Necessary=No must not be reassigned'
        );
    }

    /**
     * AC-3: Items across ALL active AiDs under the Deal are reassigned.
     */
    @IsTest
    static void testAllActiveAidsAreProcessed() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid1 = getAid(MSN_ACTIVE);
        leaseworks__Aircraft_Proposal__c aid2 = getAid(MSN_ACTIVE_2);
        Id contractsUserId = UserInfo.getUserId();

        List<pro_Checklist_Item__c> items = new List<pro_Checklist_Item__c>{
            buildItem(aid1.Id, null, 'Open', 'Yes', true),
            buildItem(aid2.Id, null, 'Open', 'Yes', true)
        };
        insert items;

        Test.startTest();
        invokeSyncForDeal(deal.Id);
        Test.stopTest();

        List<pro_Checklist_Item__c> updated = [
            SELECT Id, pro_Responsibility__c, pro_Asset_in_Deal__c
              FROM pro_Checklist_Item__c
             WHERE Id IN :items
        ];
        System.assertEquals(2, updated.size(), 'Should have items on both AiDs');
        for (pro_Checklist_Item__c item : updated) {
            System.assertEquals(
                contractsUserId,
                item.pro_Responsibility__c,
                'Item on AiD ' + item.pro_Asset_in_Deal__c + ' should be reassigned'
            );
        }
    }

    /**
     * Items on inactive AiDs must not be touched.
     */
    @IsTest
    static void testInactiveAidItemsAreNotTouched() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c inactiveAid = getAid(MSN_INACTIVE);

        pro_Checklist_Item__c item =
            buildItem(inactiveAid.Id, null, 'Open', 'Yes', true);
        insert item;

        Test.startTest();
        invokeSyncForDeal(deal.Id);
        Test.stopTest();

        pro_Checklist_Item__c result = [
            SELECT pro_Responsibility__c
              FROM pro_Checklist_Item__c
             WHERE Id = :item.Id
        ];
        System.assertEquals(
            null,
            result.pro_Responsibility__c,
            'Items on inactive AiDs must not be updated'
        );
    }

    /**
     * Mixed scenario: only open+necessary items are updated; completed
     * and not-necessary items are left untouched.
     */
    @IsTest
    static void testMixedItemsOnlyOpenNecessaryReassigned() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getAid(MSN_ACTIVE);
        Id contractsUserId = UserInfo.getUserId();

        User otherUser = [
            SELECT Id FROM User
             WHERE IsActive = true AND Id != :UserInfo.getUserId()
             LIMIT 1
        ];

        List<pro_Checklist_Item__c> items = new List<pro_Checklist_Item__c>{
            buildItem(aid.Id, otherUser.Id, 'Open', 'Yes', true),
            buildItem(aid.Id, otherUser.Id, 'Open', 'Yes', false),
            buildItem(aid.Id, otherUser.Id, 'Completed', 'Yes', true),
            buildItem(aid.Id, otherUser.Id, 'Open', 'No', true)
        };
        insert items;

        Test.startTest();
        invokeSyncForDeal(deal.Id);
        Test.stopTest();

        // Open + Necessary items should be reassigned
        pro_Checklist_Item__c openAuto = [
            SELECT pro_Responsibility__c FROM pro_Checklist_Item__c WHERE Id = :items[0].Id
        ];
        System.assertEquals(contractsUserId, openAuto.pro_Responsibility__c,
            'Open auto-generated item should be reassigned');

        pro_Checklist_Item__c openManual = [
            SELECT pro_Responsibility__c FROM pro_Checklist_Item__c WHERE Id = :items[1].Id
        ];
        System.assertEquals(contractsUserId, openManual.pro_Responsibility__c,
            'Open manual item should be reassigned');

        // Completed item should NOT be reassigned
        pro_Checklist_Item__c completed = [
            SELECT pro_Responsibility__c FROM pro_Checklist_Item__c WHERE Id = :items[2].Id
        ];
        System.assertEquals(otherUser.Id, completed.pro_Responsibility__c,
            'Completed item must retain original assignee');

        // Necessary=No item should NOT be reassigned
        pro_Checklist_Item__c notNecessary = [
            SELECT pro_Responsibility__c FROM pro_Checklist_Item__c WHERE Id = :items[3].Id
        ];
        System.assertEquals(otherUser.Id, notNecessary.pro_Responsibility__c,
            'Necessary=No item must retain original assignee');
    }

    /**
     * Bulk test: 200 open items are reassigned in a single invocation.
     */
    @IsTest
    static void testBulkReassignment() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getAid(MSN_ACTIVE);
        Id contractsUserId = UserInfo.getUserId();

        List<pro_Checklist_Item__c> items = new List<pro_Checklist_Item__c>();
        for (Integer i = 0; i < 200; i++) {
            items.add(buildItem(aid.Id, null, 'Open', 'Yes', true));
        }
        insert items;

        Test.startTest();
        invokeSyncForDeal(deal.Id);
        Test.stopTest();

        List<pro_Checklist_Item__c> updated = [
            SELECT Id, pro_Responsibility__c
              FROM pro_Checklist_Item__c
             WHERE Id IN :items
               AND pro_Responsibility__c = :contractsUserId
        ];
        System.assertEquals(200, updated.size(),
            'All 200 open items should be reassigned to the Contracts user');
    }

    /**
     * Null and empty inputs must not throw exceptions.
     */
    @IsTest
    static void testNullAndEmptyInputsDoNotThrow() {
        Test.startTest();
        pro_ChecklistAssigneeSync.syncAssignee(null);
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>()
        );
        pro_ChecklistAssigneeSync.SyncRequest req =
            new pro_ChecklistAssigneeSync.SyncRequest();
        req.dealId = null;
        pro_ChecklistAssigneeSync.syncAssignee(
            new List<pro_ChecklistAssigneeSync.SyncRequest>{ req }
        );
        Test.stopTest();
        System.assert(true, 'No exception should be thrown for null/empty inputs');
    }
}