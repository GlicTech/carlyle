    @AuraEnabled(cacheable=true)
    public static AssetInDealInfo getAssetInDealInfo(Id assetInDealId) {
        try {
            leaseworks__Aircraft_Proposal__c aid = [
                SELECT Name, leaseworks__Asset_Owner__c, leaseworks__Delivery_Date_N__c,
                       LOI_Date__c, pro_First_Draft_Lease_Date__c, Outside_Counsel_engaged__c,
                       First_draft_from_counsel__c, BAC_Approval_Date__c,
                       pro_Company_Board_Approval_Date__c, CAP_first_review_complete__c,
                       Transaction_document_executed__c,
                       leaseworks__Marketing_Activity__c,
                       leaseworks__Marketing_Activity__r.Name,
                       leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c
                FROM leaseworks__Aircraft_Proposal__c
                WHERE Id = :assetInDealId
                LIMIT 1
            ];
            AssetInDealInfo info = new AssetInDealInfo();
            info.assetInDealId = aid.Id;
            info.assetName = aid.Name;
            info.dealId = aid.leaseworks__Marketing_Activity__c;
            info.dealName = aid.leaseworks__Marketing_Activity__r.Name;
            info.dealType = aid.leaseworks__Marketing_Activity__r.leaseworks__Deal_Type__c;
            info.assetOwner = aid.leaseworks__Asset_Owner__c;
            info.deliveryDate = aid.leaseworks__Delivery_Date_N__c;
            info.loiDate = aid.LOI_Date__c;
            info.draftToCounterparty = aid.pro_First_Draft_Lease_Date__c;
            info.outsideCounselEngaged = aid.Outside_Counsel_engaged__c;
            info.firstDraftFromCounsel = aid.First_draft_from_counsel__c;
            info.bacApprovalDate = aid.BAC_Approval_Date__c;
            info.companyBoardApprovalDate = aid.pro_Company_Board_Approval_Date__c;
            info.capFirstReviewComplete = aid.CAP_first_review_complete__c;
            info.transactionDocExecuted = aid.Transaction_document_executed__c;
            return info;
        } catch (Exception e) {
            throw toAuraHandled('Unable to load Asset in Deal info. Please contact your administrator.');
        }
    }

    @AuraEnabled(cacheable=true)
    public static List<pro_Checklist_Item__c> getChecklistItems(Id assetInDealId) {
        return [
            SELECT Id, Name, pro_Title__c, pro_Phase__c, pro_Category__c,
                   pro_Status__c, pro_Responsibility__c, pro_Responsibility__r.Name,
                   pro_Necessary__c, pro_Comment_Notes__c, pro_Key_Date__c,
                   pro_Completed_Date__c, pro_Sort_Order__c, pro_Is_Autogenerated__c,
                   pro_Moveable_to_Post_Closing__c, pro_Document_Action_Required__c,
                   pro_Documentation_Tab_Field__c,
                   pro_Completion_Fields__c,
                   pro_Source_Template__c,
                   pro_Yes_No__c, pro_Provided_By__c, pro_LoC_Action_Required__c
            FROM pro_Checklist_Item__c
            WHERE pro_Asset_in_Deal__c = :assetInDealId
            ORDER BY pro_Phase__c, pro_Sort_Order__c, pro_Title__c
        ];
    }

    @AuraEnabled(cacheable=true)
    public static Map<String, String> getTemplateHierarchy() {
        Map<String, String> hierarchy = new Map<String, String>();
        for (pro_Checklist_Item_Template__mdt tmpl : [
            SELECT DeveloperName, pro_Parent_Template__c
              FROM pro_Checklist_Item_Template__mdt
             WHERE pro_Parent_Template__c != null
        ]) {
            hierarchy.put(tmpl.DeveloperName, tmpl.pro_Parent_Template__c);
        }
        return hierarchy;
    }

    @AuraEnabled
    public static void saveChecklistItems(List<pro_Checklist_Item__c> items) {
        Set<Id> itemIds = new Set<Id>();
        for (pro_Checklist_Item__c item : items) {
            if (item.Id != null) {
                itemIds.add(item.Id);
            }
        }
        Map<Id, pro_Checklist_Item__c> existingMap = new Map<Id, pro_Checklist_Item__c>();
        if (!itemIds.isEmpty()) {
            existingMap = new Map<Id, pro_Checklist_Item__c>([
                SELECT Id, pro_Status__c
                FROM pro_Checklist_Item__c
                WHERE Id IN :itemIds
            ]);
        }
        for (pro_Checklist_Item__c item : items) {
            if (item.pro_Necessary__c == 'No' && String.isBlank(item.pro_Comment_Notes__c)) {
                throw toAuraHandled('A comment is required when marking an item as Not Necessary.');
            }
            if (item.pro_Status__c == 'Completed' && item.pro_Completed_Date__c == null) {
                item.pro_Completed_Date__c = Date.today();
            }
            pro_Checklist_Item__c existing = existingMap.get(item.Id);
            if (existing != null
                    && existing.pro_Status__c == 'Completed'
                    && item.pro_Status__c != 'Completed') {
                item.pro_Completed_Date__c = null;
                item.pro_Yes_No__c = null;
                item.pro_Key_Date__c = null;
                item.pro_Provided_By__c = null;
                item.pro_LoC_Action_Required__c = null;
            }
        }
        try {
            update items;
        } catch (AuraHandledException e) {
            throw e;
        } catch (Exception e) {
            throw toAuraHandled('Unable to complete this action. Please contact your administrator.');
        }
    }

    @AuraEnabled
    public static pro_Checklist_Item__c movePhase(Id checklistItemId, String targetPhase, String comment) {
        pro_Checklist_Item__c original = [
            SELECT Id, pro_Title__c, pro_Asset_in_Deal__c, pro_Category__c,
                   pro_Sort_Order__c, pro_Responsibility__c, pro_Document_Action_Required__c,
                   pro_Documentation_Tab_Field__c, pro_Necessary__c, pro_Comment_Notes__c,
                   pro_Moveable_to_Post_Closing__c, pro_Phase__c,
                   pro_Completion_Fields__c
            FROM pro_Checklist_Item__c
            WHERE Id = :checklistItemId
            LIMIT 1
        ];
        if (original == null) {
            throw toAuraHandled('Checklist item not found.');
        }
        if (targetPhase != 'Pre-Closing' && targetPhase != 'Post-Closing') {
            throw toAuraHandled('Invalid target phase. Must be Pre-Closing or Post-Closing.');
        }
        if (original.pro_Phase__c == targetPhase) {
            throw toAuraHandled('Item is already in the ' + targetPhase + ' phase.');
        }
        if (original.pro_Phase__c == 'Post-Closing' && targetPhase == 'Pre-Closing') {
            throw toAuraHandled('Items cannot be moved from Post-Closing back to Pre-Closing.');
        }
        if (original.pro_Phase__c == 'Pre-Closing' && targetPhase == 'Post-Closing') {
            if (!original.pro_Moveable_to_Post_Closing__c) {
                throw toAuraHandled('This item is not eligible to be moved to post-closing.');
            }
        }
        if (String.isBlank(comment)) {
            throw toAuraHandled('A comment is required when moving an item between phases.');
        }
        original.pro_Status__c = 'Moved';
        original.pro_Completed_Date__c = null;
        original.pro_Comment_Notes__c = String.isBlank(original.pro_Comment_Notes__c)
            ? comment
            : original.pro_Comment_Notes__c + '\n' + comment;
        try {
            update original;
        } catch (AuraHandledException e) {
            throw e;
        } catch (Exception e) {
            throw toAuraHandled('Unable to complete this action. Please contact your administrator.');
        }
        pro_Checklist_Item__c newItem = new pro_Checklist_Item__c(
            pro_Asset_in_Deal__c = original.pro_Asset_in_Deal__c,
            pro_Title__c = original.pro_Title__c,
            pro_Phase__c = targetPhase,
            pro_Category__c = original.pro_Category__c,
            pro_Sort_Order__c = original.pro_Sort_Order__c,
            pro_Responsibility__c = original.pro_Responsibility__c,
            pro_Document_Action_Required__c = original.pro_Document_Action_Required__c,
            pro_Documentation_Tab_Field__c = original.pro_Documentation_Tab_Field__c,
            pro_Necessary__c = original.pro_Necessary__c,
            pro_Completion_Fields__c = original.pro_Completion_Fields__c,
            pro_Status__c = 'Open',
            pro_Is_Autogenerated__c = false,
            pro_Moveable_to_Post_Closing__c = (targetPhase == 'Pre-Closing')
        );
        try {
            insert newItem;
        } catch (AuraHandledException e) {
            throw e;
        } catch (Exception e) {
            throw toAuraHandled('Unable to complete this action. Please contact your administrator.');
        }
        return newItem;
    }

    @AuraEnabled
    public static pro_Checklist_Item__c moveToPostClosing(Id checklistItemId) {
        return movePhase(checklistItemId, 'Post-Closing', 'Moved to Post-Closing');
    }

    @AuraEnabled
    public static void bulkReassignResponsibility(List<Id> checklistItemIds, Id newUserId) {
        if (checklistItemIds == null || checklistItemIds.isEmpty()) {
            throw toAuraHandled('No items selected for reassignment.');
        }
        List<pro_Checklist_Item__c> items = [
            SELECT Id, pro_Responsibility__c
            FROM pro_Checklist_Item__c
            WHERE Id IN :checklistItemIds
        ];
        for (pro_Checklist_Item__c item : items) {
            item.pro_Responsibility__c = newUserId;
        }
        try {
            update items;
        } catch (AuraHandledException e) {
            throw e;
        } catch (Exception e) {
            throw toAuraHandled('Unable to complete this action. Please contact your administrator.');
        }
    }

    public class BulkUpdateResult {
        @AuraEnabled public Integer successCount;
        @AuraEnabled public Integer failureCount;
        @AuraEnabled public List<String> errors;
        public BulkUpdateResult() {
            this.successCount = 0;
            this.failureCount = 0;
            this.errors = new List<String>();
        }
    }

    private static final Set<String> BULK_UPDATABLE_FIELDS = new Set<String>{
        'pro_Necessary__c',
        'pro_Responsibility__c',
        'pro_Status__c',
        'pro_Yes_No__c',
        'pro_Key_Date__c',
        'pro_Provided_By__c',
        'pro_LoC_Action_Required__c',
        'pro_Comment_Notes__c'
    };

    private static final Set<String> COMPLETION_FIELD_NAMES = new Set<String>{
        'pro_Yes_No__c',
        'pro_Key_Date__c',
        'pro_Provided_By__c',
        'pro_LoC_Action_Required__c',
        'pro_Comment_Notes__c'
    };

    @AuraEnabled
    public static BulkUpdateResult bulkUpdateItems(List<Id> checklistItemIds, Map<String, Object> updates) {
        BulkUpdateResult result = new BulkUpdateResult();
        if (checklistItemIds == null || checklistItemIds.isEmpty()) {
            throw toAuraHandled('No items selected for bulk update.');
        }
        if (updates == null || updates.isEmpty()) {
            throw toAuraHandled('No field updates provided.');
        }
        Map<String, Object> safeUpdates = new Map<String, Object>();
        for (String fieldName : updates.keySet()) {
            if (!BULK_UPDATABLE_FIELDS.contains(fieldName)) {
                continue;
            }
            Object val = updates.get(fieldName);
            if (val == null) {
                continue;
            }
            if (val instanceof String && String.isBlank((String) val)) {
                continue;
            }
            safeUpdates.put(fieldName, val);
        }
        if (safeUpdates.isEmpty()) {
            throw toAuraHandled('No valid field updates provided.');
        }
        if (safeUpdates.containsKey('pro_Status__c')) {
            String s = String.valueOf(safeUpdates.get('pro_Status__c'));
            if (s != 'Completed') {
                throw toAuraHandled('Bulk Status updates may only set Completed.');
            }
        }
        List<pro_Checklist_Item__c> items = [
            SELECT Id, pro_Status__c, pro_Completion_Fields__c, pro_Completed_Date__c,
                   pro_Necessary__c, pro_Responsibility__c, pro_Comment_Notes__c,
                   pro_Yes_No__c, pro_Key_Date__c,
                   pro_Provided_By__c, pro_LoC_Action_Required__c
            FROM pro_Checklist_Item__c
            WHERE Id IN :checklistItemIds
        ];
        List<pro_Checklist_Item__c> toUpdate = new List<pro_Checklist_Item__c>();
        for (pro_Checklist_Item__c item : items) {
            Set<String> configuredCompletionFields = parseCompletionFields(item.pro_Completion_Fields__c);
            Boolean changed = false;
            for (String fieldName : safeUpdates.keySet()) {
                Object val = safeUpdates.get(fieldName);
                if (fieldName == 'pro_Status__c') {
                    if (item.pro_Status__c != 'Open') {
                        continue;
                    }
                    item.pro_Status__c = 'Completed';
                    if (item.pro_Completed_Date__c == null) {
                        item.pro_Completed_Date__c = Date.today();
                    }
                    changed = true;
                    continue;
                }
                if (COMPLETION_FIELD_NAMES.contains(fieldName)
                        && fieldName != 'pro_Comment_Notes__c') {
                    if (!configuredCompletionFields.contains(fieldName)) {
                        continue;
                    }
                }
                if (fieldName == 'pro_Key_Date__c') {
                    if (val instanceof Date) {
                        item.put(fieldName, (Date) val);
                    } else {
                        item.put(fieldName, Date.valueOf(String.valueOf(val)));
                    }
                } else {
                    item.put(fieldName, String.valueOf(val));
                }
                changed = true;
            }
            if (changed) {
                toUpdate.add(item);
            }
        }
        if (toUpdate.isEmpty()) {
            return result;
        }
        Database.SaveResult[] saveResults = Database.update(toUpdate, false);
        for (Integer i = 0; i < saveResults.size(); i++) {
            Database.SaveResult sr = saveResults[i];
            if (sr.isSuccess()) {
                result.successCount++;
            } else {
                result.failureCount++;
                String title = toUpdate[i].Id;
                List<String> msgs = new List<String>();
                for (Database.Error err : sr.getErrors()) {
                    msgs.add(err.getMessage());
                }
                result.errors.add(title + ': ' + String.join(msgs, '; '));
            }
        }
        return result;
    }

    private static Set<String> parseCompletionFields(String csv) {
        Set<String> out = new Set<String>();
        if (String.isBlank(csv)) {
            return out;
        }
        for (String part : csv.split(',')) {
            String trimmed = part.trim();
            if (String.isNotBlank(trimmed)) {
                out.add(trimmed);
            }
        }
        return out;
    }

    @AuraEnabled
    public static pro_Checklist_Item__c addAdHocItem(Id assetInDealId, String title, String phase, String category, Id responsibilityId, String completionFields) {
        Decimal maxSort = 0;
        List<AggregateResult> agg = [
            SELECT MAX(pro_Sort_Order__c) maxVal
            FROM pro_Checklist_Item__c
            WHERE pro_Asset_in_Deal__c = :assetInDealId
            AND pro_Phase__c = :phase
        ];
        if (!agg.isEmpty() && agg[0].get('maxVal') != null) {
            maxSort = (Decimal) agg[0].get('maxVal');
        }
        pro_Checklist_Item__c newItem = new pro_Checklist_Item__c(
            pro_Asset_in_Deal__c = assetInDealId,
            pro_Title__c = title,
            pro_Phase__c = phase,
            pro_Category__c = category,
            pro_Responsibility__c = responsibilityId,
            pro_Completion_Fields__c = completionFields,
            pro_Sort_Order__c = maxSort + 10,
            pro_Status__c = 'Open',
            pro_Necessary__c = 'Yes',
            pro_Is_Autogenerated__c = false,
            pro_Moveable_to_Post_Closing__c = (phase == 'Pre-Closing')
        );
        try {
            insert newItem;
        } catch (AuraHandledException e) {
            throw e;
        } catch (Exception e) {
            throw toAuraHandled('Unable to complete this action. Please contact your administrator.');
        }
        return newItem;
    }

    @AuraEnabled(cacheable=true)
    public static List<Map<String, String>> getContractsProfileUsers() {
        List<Map<String, String>> users = new List<Map<String, String>>();
        for (User u : [
            SELECT Id, Name
            FROM User
            WHERE Profile.Name = 'Contracts'
            AND IsActive = true
            ORDER BY Name
        ]) {
            users.add(new Map<String, String>{
                'label' => u.Name,
                'value' => u.Id
            });
        }
        return users;
    }

    @AuraEnabled(cacheable=true)
    public static Map<String, List<Map<String, String>>> getPicklistValues() {
        Map<String, List<Map<String, String>>> result = new Map<String, List<Map<String, String>>>();
        result.put('Status', getPicklistEntries(pro_Checklist_Item__c.pro_Status__c.getDescribe()));
        result.put('Necessary', getPicklistEntries(pro_Checklist_Item__c.pro_Necessary__c.getDescribe()));
        result.put('Phase', getPicklistEntries(pro_Checklist_Item__c.pro_Phase__c.getDescribe()));
        result.put('Category', getPicklistEntries(pro_Checklist_Item__c.pro_Category__c.getDescribe()));
        return result;
    }

    @AuraEnabled(cacheable=true)
    public static Map<String, Object> getDocumentationFields(Id assetInDealId) {
        try {
            leaseworks__Aircraft_Proposal__c aid = [
                SELECT
                    pro_BAC_Approval_Required__c,
                    BAC_Approval_Date__c,
                    BAC_Approval_Complete__c,
                    pro_Company_Board_Approval__c,
                    pro_Company_Board_Approval_Date__c,
                    pro_KYC_Final_Approval_Required__c,
                    pro_Entity_Name__c,
                    pro_Lease_Guarantor_Required__c,
                    pro_Guarantor_Company__c,
                    pro_Guarantor_Company__r.Name,
                    pro_Guarantor_Company_Approval_Date__c,
                    pro_First_Draft_Lease_Sent__c,
                    pro_Lease_Signed_Date__c,
                    pro_Outside_Counsel_Firm__c,
                    pro_Outside_Counsel_Firm__r.Name,
                    pro_Local_Counsel_Firm__c,
                    pro_Local_Counsel_Firm__r.Name,
                    pro_Financing__c,
                    pro_Cash_LC_Amount__c,
                    pro_Security_Deposit__c,
                    pro_Delivery_Security_Deposit__c,
                    pro_Lease_Execution_Security_Deposit__c,
                    pro_X1st_Month_Rent__c,
                    pro_Deposit_Type__c,
                    pro_Deposit_Date__c,
                    pro_Payments_Received__c,
                    pro_Title_Transfer_of_Asset_Required__c,
                    pro_Title_Transfer_of_Asset_Notes__c,
                    pro_Pre_Closing_Complete__c,
                    pro_Pre_Closing_Items_Total__c,
                    pro_Pre_Closing_Items_Completed__c,
                    pro_Data_Plates_Required__c,
                    pro_Installed_Photos_Provided__c,
                    pro_Original_IDERA_Required__c,
                    pro_Date_Of_Receipt_IDERA__c,
                    pro_Location_Of_Original_IDERA__c,
                    pro_Original_DPOA_Required__c,
                    pro_Date_Of_Receipt_DPOA__c,
                    pro_Location_Of_Original_DPOA__c,
                    pro_CSs_List_Attached__c,
                    pro_CSs_List__c,
                    pro_CP_List__c,
                    pro_Other_Originals_Location__c,
                    pro_Summary_Notes__c,
                    pro_Post_Closing_Complete__c,
                    pro_Post_Closing_Items_Total__c,
                    pro_Post_Closing_Items_Completed__c
                FROM leaseworks__Aircraft_Proposal__c
                WHERE Id = :assetInDealId
                LIMIT 1
            ];
            Map<String, Object> result = new Map<String, Object>();
            Map<String, Object> fieldsMap = aid.getPopulatedFieldsAsMap();
            for (String fieldName : fieldsMap.keySet()) {
                if (fieldName == 'Id') {
                    continue;
                }
                result.put(fieldName, fieldsMap.get(fieldName));
            }
            if (aid.pro_Guarantor_Company__c != null && aid.pro_Guarantor_Company__r != null) {
                result.put('pro_Guarantor_Company__rName', aid.pro_Guarantor_Company__r.Name);
            }
            if (aid.pro_Outside_Counsel_Firm__c != null && aid.pro_Outside_Counsel_Firm__r != null) {
                result.put('pro_Outside_Counsel_Firm__rName', aid.pro_Outside_Counsel_Firm__r.Name);
            }
            if (aid.pro_Local_Counsel_Firm__c != null && aid.pro_Local_Counsel_Firm__r != null) {
                result.put('pro_Local_Counsel_Firm__rName', aid.pro_Local_Counsel_Firm__r.Name);
            }
            return result;
        } catch (Exception e) {
            throw toAuraHandled('Unable to load documentation fields. Please contact your administrator.');
        }
    }

    private static List<Map<String, String>> getPicklistEntries(Schema.DescribeFieldResult fieldDescribe) {
        List<Map<String, String>> entries = new List<Map<String, String>>();
        for (Schema.PicklistEntry entry : fieldDescribe.getPicklistValues()) {
            if (entry.isActive()) {
                entries.add(new Map<String, String>{
                    'label' => entry.getLabel(),
                    'value' => entry.getValue()
                });
            }
        }
        return entries;
    }
