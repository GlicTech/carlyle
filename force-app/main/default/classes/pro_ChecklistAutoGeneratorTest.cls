/**
 * Test class for pro_ChecklistAutoGenerator.
 *
 * Covers:
 *  - Pre-closing generation on LOI_Signed
 *  - Post-closing generation on Closed_Won (including Key Date calculation)
 *  - Duplicate prevention (second call does not create duplicates)
 *  - Deal-type filtering (wrong deal type produces no items)
 */
@IsTest
private class pro_ChecklistAutoGeneratorTest {

    // ─────────────────────────────────────────────────────────────
    // Shared test data — inserted once, queried per test
    // ─────────────────────────────────────────────────────────────

    @TestSetup
    static void setupTestData() {
        Account acct = new Account(Name = 'Test Account');
        insert acct;

        leaseworks__Marketing_Activity__c deal =
            new leaseworks__Marketing_Activity__c(
                leaseworks__Deal_Type__c      = 'Purchase',
                leaseworks__Deal_Status__c    = 'Pipeline',
                leaseworks__Close_Date__c     = Date.today().addDays(30),
                leaseworks__Counter_Party__c  = acct.Id,
                leaseworks__Marketing_Representative_User__c = UserInfo.getUserId()
            );
        insert deal;

        leaseworks__Aircraft_Proposal__c aid =
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c = deal.Id,
                leaseworks__Inactive_AT__c        = false,
                leaseworks__Awarded_To_Counterparty__c = acct.Id,
                leaseworks__MSN_E__c              = 'TEST-001'
            );
        insert aid;

        leaseworks__Deal_Team__c dt = new leaseworks__Deal_Team__c(
            leaseworks__Marketing_Activity__c = deal.Id,
            leaseworks__Assigned_To__c        = UserInfo.getUserId(),
            pro_Member_Role__c                = 'Contracts'
        );
        insert dt;
    }

    // ─────────────────────────────────────────────────────────────
    // Query helpers — retrieve @TestSetup records
    // ─────────────────────────────────────────────────────────────

    private static Account getTestAccount() {
        return [SELECT Id FROM Account WHERE Name = 'Test Account' LIMIT 1];
    }

    private static leaseworks__Marketing_Activity__c getTestDeal() {
        return [
            SELECT Id, leaseworks__Deal_Type__c, leaseworks__Deal_Status__c,
                   leaseworks__Close_Date__c
            FROM   leaseworks__Marketing_Activity__c
            LIMIT  1
        ];
    }

    private static leaseworks__Aircraft_Proposal__c getTestAid() {
        return [
            SELECT Id
            FROM   leaseworks__Aircraft_Proposal__c
            WHERE  leaseworks__MSN_E__c = 'TEST-001'
            LIMIT  1
        ];
    }

    // ─────────────────────────────────────────────────────────────
    // Helpers for additional test-specific data
    // ─────────────────────────────────────────────────────────────

    private static pro_ChecklistAutoGenerator.GenerateRequest makeRequest(
        Id dealId,
        String triggerStatus
    ) {
        pro_ChecklistAutoGenerator.GenerateRequest req =
            new pro_ChecklistAutoGenerator.GenerateRequest();
        req.dealId        = dealId;
        req.triggerStatus = triggerStatus;
        return req;
    }

    // ─────────────────────────────────────────────────────────────
    // Tests
    // ─────────────────────────────────────────────────────────────

    @IsTest
    static void testPreClosingGeneration() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getTestAid();

        Test.startTest();
        pro_ChecklistAutoGenerator.generateItems(
            new List<pro_ChecklistAutoGenerator.GenerateRequest>{
                makeRequest(deal.Id, 'LOI Signed')
            }
        );
        Test.stopTest();

        List<pro_Checklist_Item__c> items = [
            SELECT Id, pro_Phase__c, pro_Is_Autogenerated__c
              FROM pro_Checklist_Item__c
             WHERE pro_Asset_in_Deal__c = :aid.Id
        ];
        for (pro_Checklist_Item__c item : items) {
            System.assertEquals('Pre-Closing', item.pro_Phase__c,
                'All generated items must have Pre-Closing phase');
            System.assertEquals(true, item.pro_Is_Autogenerated__c,
                'Items must be flagged as auto-generated');
        }
    }

    @IsTest
    static void testPostClosingGenerationWithKeyDate() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getTestAid();

        pro_BusinessDayCalculator.mockHolidays = new Set<Date>();

        Test.startTest();
        pro_ChecklistAutoGenerator.generateItems(
            new List<pro_ChecklistAutoGenerator.GenerateRequest>{
                makeRequest(deal.Id, 'Closed - Won')
            }
        );
        Test.stopTest();

        List<pro_Checklist_Item__c> items = [
            SELECT Id, pro_Phase__c, pro_Key_Date__c, pro_Is_Autogenerated__c
              FROM pro_Checklist_Item__c
             WHERE pro_Asset_in_Deal__c = :aid.Id
        ];
        for (pro_Checklist_Item__c item : items) {
            System.assertEquals('Post-Closing', item.pro_Phase__c,
                'All generated items must have Post-Closing phase');
            System.assertEquals(true, item.pro_Is_Autogenerated__c,
                'Items must be flagged as auto-generated');
        }
    }

    @IsTest
    static void testDuplicatePrevention() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid = getTestAid();

        List<pro_ChecklistAutoGenerator.GenerateRequest> reqs =
            new List<pro_ChecklistAutoGenerator.GenerateRequest>{
                makeRequest(deal.Id, 'LOI Signed')
            };

        Test.startTest();
        pro_ChecklistAutoGenerator.generateItems(reqs);
        Integer countAfterFirstRun = [
            SELECT COUNT()
              FROM pro_Checklist_Item__c
             WHERE pro_Asset_in_Deal__c = :aid.Id
               AND pro_Phase__c = 'Pre-Closing'
               AND pro_Is_Autogenerated__c = true
        ];

        pro_ChecklistAutoGenerator.generateItems(reqs);
        Test.stopTest();

        Integer countAfterSecondRun = [
            SELECT COUNT()
              FROM pro_Checklist_Item__c
             WHERE pro_Asset_in_Deal__c = :aid.Id
               AND pro_Phase__c = 'Pre-Closing'
               AND pro_Is_Autogenerated__c = true
        ];

        System.assertEquals(countAfterFirstRun, countAfterSecondRun,
            'Second invocation must not create duplicate checklist items (US-018)');
    }

    @IsTest
    static void testDealTypeFiltering() {
        // Needs a deal with a non-matching type — create separate data
        Account acct = getTestAccount();
        leaseworks__Marketing_Activity__c deal =
            new leaseworks__Marketing_Activity__c(
                leaseworks__Deal_Type__c      = 'NonExistentType_XYZ',
                leaseworks__Deal_Status__c    = 'Pipeline',
                leaseworks__Close_Date__c     = Date.today().addDays(30),
                leaseworks__Counter_Party__c  = acct.Id,
                leaseworks__Marketing_Representative_User__c = UserInfo.getUserId()
            );
        insert deal;

        leaseworks__Aircraft_Proposal__c aid =
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c = deal.Id,
                leaseworks__Inactive_AT__c        = false,
                leaseworks__Awarded_To_Counterparty__c = acct.Id,
                leaseworks__MSN_E__c              = 'TEST-FILTER'
            );
        insert aid;

        leaseworks__Deal_Team__c dt = new leaseworks__Deal_Team__c(
            leaseworks__Marketing_Activity__c = deal.Id,
            leaseworks__Assigned_To__c        = UserInfo.getUserId(),
            pro_Member_Role__c                = 'Contracts'
        );
        insert dt;

        Test.startTest();
        pro_ChecklistAutoGenerator.generateItems(
            new List<pro_ChecklistAutoGenerator.GenerateRequest>{
                makeRequest(deal.Id, 'LOI Signed')
            }
        );
        Test.stopTest();

        Integer itemCount = [
            SELECT COUNT()
              FROM pro_Checklist_Item__c
             WHERE pro_Asset_in_Deal__c = :aid.Id
        ];
        System.assertEquals(0, itemCount,
            'No items should be created when the deal type does not match any template');
    }

    @IsTest
    static void testAidIdScopingForPreClosing() {
        // Needs a second AiD — create additional data
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        leaseworks__Aircraft_Proposal__c aid1 = getTestAid();
        Account acct = getTestAccount();

        leaseworks__Aircraft_Proposal__c aid2 = new leaseworks__Aircraft_Proposal__c(
            leaseworks__Marketing_Activity__c = deal.Id,
            leaseworks__Inactive_AT__c        = false,
            leaseworks__Awarded_To_Counterparty__c = acct.Id,
            leaseworks__MSN_E__c              = 'TEST-002'
        );
        insert aid2;

        pro_ChecklistAutoGenerator.GenerateRequest req =
            new pro_ChecklistAutoGenerator.GenerateRequest();
        req.dealId        = deal.Id;
        req.triggerStatus = 'LOI Signed';
        req.aidId         = aid1.Id;

        Test.startTest();
        pro_ChecklistAutoGenerator.generateItems(
            new List<pro_ChecklistAutoGenerator.GenerateRequest>{ req }
        );
        Test.stopTest();

        Integer aid2Count = [
            SELECT COUNT()
              FROM pro_Checklist_Item__c
             WHERE pro_Asset_in_Deal__c = :aid2.Id
        ];
        System.assertEquals(0, aid2Count,
            'When aidId is specified, only that AiD should receive checklist items');
    }

    @IsTest
    static void testNullAndEmptyInputsDoNotThrow() {
        Test.startTest();
        pro_ChecklistAutoGenerator.generateItems(null);
        pro_ChecklistAutoGenerator.generateItems(
            new List<pro_ChecklistAutoGenerator.GenerateRequest>()
        );
        pro_ChecklistAutoGenerator.GenerateRequest req =
            new pro_ChecklistAutoGenerator.GenerateRequest();
        req.dealId        = null;
        req.triggerStatus = 'LOI Signed';
        pro_ChecklistAutoGenerator.generateItems(
            new List<pro_ChecklistAutoGenerator.GenerateRequest>{ req }
        );
        Test.stopTest();
        System.assert(true, 'No exception should be thrown for null/empty inputs');
    }

    @IsTest
    static void testInactiveAidIsSkipped() {
        leaseworks__Marketing_Activity__c deal = getTestDeal();
        Account acct = getTestAccount();

        leaseworks__Aircraft_Proposal__c inactiveAid =
            new leaseworks__Aircraft_Proposal__c(
                leaseworks__Marketing_Activity__c = deal.Id,
                leaseworks__Inactive_AT__c        = true,
                leaseworks__Awarded_To_Counterparty__c = acct.Id,
                leaseworks__MSN_E__c              = 'TEST-INACTIVE'
            );
        insert inactiveAid;

        Test.startTest();
        pro_ChecklistAutoGenerator.generateItems(
            new List<pro_ChecklistAutoGenerator.GenerateRequest>{
                makeRequest(deal.Id, 'LOI Signed')
            }
        );
        Test.stopTest();

        Integer itemCount = [
            SELECT COUNT()
              FROM pro_Checklist_Item__c
             WHERE pro_Asset_in_Deal__c = :inactiveAid.Id
        ];
        System.assertEquals(0, itemCount,
            'No items should be created for an inactive Asset in Deal');
    }
}