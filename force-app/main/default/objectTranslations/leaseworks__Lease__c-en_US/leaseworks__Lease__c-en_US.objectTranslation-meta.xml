        <errorMessage><!-- Lease Contracts with Lease Status = On Lease should have the Habitual Base populated. Please select the Country where the Habitual Base is located before saving. --></errorMessage>
        <name>Habitual_Base_not_blank</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- This asset has already been assigned to another lease. Please choose another asset or contact the lease owner --></errorMessage>
        <name>leaseworks__AC_Already_Assigned_Validation</name>
