    <validationRules>
        <errorMessage><!-- This asset is not available to be assigned. Please choose another asset or contact the lease owner --></errorMessage>
        <name>leaseworks__AC_Unavailable_Validation</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Number of days cannot be negative. Please enter a number greater than or equal to 0 --></errorMessage>
        <name>leaseworks__ClaimDueCannotBeNegative</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Contractual Re-delivery Date is required when Re-delivery Term is marked to Redelivery Date Driven --></errorMessage>
        <name>leaseworks__Contractual_Redelivery_Date_Empty</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- &apos;Custom Days&apos; is required when &apos;Custom&apos; is chosen for Compounding Frequency --></errorMessage>
        <name>leaseworks__Custom_Compounding_Base_Days_Check</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Please enter a number between 1 and 365 for custom days --></errorMessage>
        <name>leaseworks__Custom_Compounding_Days_Check</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Delivery Date is required when Redelivery Terms is marked to Lease Term Driven --></errorMessage>
        <name>leaseworks__DeliveryDateCannotBeBlank</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- LLP MR allocation percentages must add up to 100%. --></errorMessage>
        <name>leaseworks__Engine_Allocation_Pct_Must_Add_Up_to_100</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- The value must be between 1 and 365. --></errorMessage>
        <name>leaseworks__GracePeriodVal_NoDecimalWithinRange</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Interest, MR and SD Accounting Methods are required to proceed. --></errorMessage>
        <name>leaseworks__Interest_Accounting_Method_Mandatory</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- &apos;Compounding Frequency&apos; is required if compounding is enabled for interest calculation --></errorMessage>
        <name>leaseworks__Interest_Compounding_Frequency_Check</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- No.of days cannot be greater than 365 days --></errorMessage>
        <name>leaseworks__InvoiceRequired_Date_Setting_validation1</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- No.of days should be greater than 0 --></errorMessage>
        <name>leaseworks__InvoiceRequired_Date_Setting_validation2</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Lessor and Head Lessors must be unique --></errorMessage>
        <name>leaseworks__Lessor_HL_HL2_NoDuplicate</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Future Dates Not Allowed for Redelivery Date. Use &apos;Estimated Redelivery&apos; for future date entries. --></errorMessage>
        <name>leaseworks__NoFutureDateOnRedeliveryDate</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Future Dates Not Allowed for Delivery Date. Use &apos;Estimated Delivery&apos; for future date entries. --></errorMessage>
        <name>leaseworks__NoFuturedateOnDeliveryDate</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Lease Name already exists! Please enter a new name. --></errorMessage>
        <name>leaseworks__No_Duplicate_Name</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Cannot assign an operator that has not been approved by the finance organization. Please get this operator approved and try again. --></errorMessage>
        <name>leaseworks__Operator_Approval_Validation</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Cannot change associated Asset because Supplemental Rent is configured and associated with Assemblies. Please delete Supplemental Rent first. --></errorMessage>
        <name>leaseworks__Prevent_Asset_Value_Change</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Redelivery Period in Months is required when Redelivery Terms is marked to Lease Term Driven --></errorMessage>
        <name>leaseworks__RedeliveryPeriodCannotBeBlank</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Lease end date cannot be earlier than lease start date --></errorMessage>
        <name>leaseworks__Start_Date_End_Date</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Redelivery Date cannot be earlier than Lease Start Date --></errorMessage>
        <name>leaseworks__Start_Date_Redelivery_Date</name>
    </validationRules>
    <validationRules>
        <errorMessage><!-- Please select a tax record here if Tax Applicable is checked. --></errorMessage>
        <name>leaseworks__Tax_Type_Is_Required_If_Tax_Applicable</name>
    </validationRules>
