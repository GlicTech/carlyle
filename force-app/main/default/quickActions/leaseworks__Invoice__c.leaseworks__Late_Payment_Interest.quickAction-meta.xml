        <field>leaseworks__Interest_End_Date__c</field>
        <formula>Today()</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>leaseworks__Interest_Start_Date__c</field>
        <formula>(leaseworks__Invoice__c.leaseworks__Date_of_MR_Payment_Due__c)+1</formula>
