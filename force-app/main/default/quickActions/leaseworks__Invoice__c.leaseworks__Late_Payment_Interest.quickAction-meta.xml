<?xml version="1.0" encoding="UTF-8"?>
<QuickAction xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Creates Late payment interest for an unpaid invoice</description>
    <fieldOverrides>
        <field>leaseworks__Accounting_Method__c</field>
        <literalValue>Accrual</literalValue>
    </fieldOverrides>
    <fieldOverrides>
        <field>leaseworks__Days_in_year__c</field>
