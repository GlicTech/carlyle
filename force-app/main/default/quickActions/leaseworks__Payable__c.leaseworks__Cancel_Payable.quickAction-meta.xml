    <fieldOverrides>
        <field>leaseworks__JE_Cancellation_Method__c</field>
        <formula>IF(leaseworks__Global_Accounting_Setting__r.leaseworks__Accounting_ON__c,
IF(
ISPICKVAL(leaseworks__Payable__c.leaseworks__Accounting_Method__c, &apos;Cash&apos;),
        &apos;None&apos;,
        IF(
            AND(
               leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Reversals__c,
                leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Unposting__c
            ),
            &apos;None&apos;,
            IF(
                leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Unposting__c,
                &apos;Reverse JEs&apos;,
                IF(
                    leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Reversals__c,
                    &apos;Unpost JEs&apos;,
                    &apos;Reverse JEs&apos;
                )
            )
        )
    ),&apos;None&apos;)</formula>
