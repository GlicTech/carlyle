<?xml version="1.0" encoding="UTF-8"?>
<QuickAction xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>To cancel the approved Invoice</description>
    <fieldOverrides>
        <field>leaseworks__Cancellation_Date__c</field>
        <formula>TODAY()</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>leaseworks__JE_Cancellation_Method__c</field>
        <formula>IF( leaseworks__Invoice__c.leaseworks__Global_Accounting_Setting__r.leaseworks__Accounting_ON__c,
If ( OR( ISPICKVAL( leaseworks__Invoice__c.leaseworks__MR_Accounting_Method__c , &apos;Cash&apos;) ,
ISPICKVAL( leaseworks__Invoice__c.leaseworks__SD_Accounting_Method__c , &apos;Cash&apos;) ,
ISPICKVAL( leaseworks__Invoice__c.leaseworks__Accounting_Method__c , &apos;Cash&apos;) ), &apos;None&apos;,IF(
AND(leaseworks__Invoice__c.leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Reversals__c,
leaseworks__Invoice__c.leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Unposting__c) ,&apos;None&apos;,IF(
leaseworks__Invoice__c.leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Unposting__c,&apos;Reverse JEs&apos;,
IF( leaseworks__Invoice__c.leaseworks__Global_Accounting_Setting__r.leaseworks__Block_Journal_Reversals__c,
&apos;Unpost JEs&apos;, &apos;Reverse JEs&apos; )))), &apos;None&apos; )</formula>
    </fieldOverrides>
    <label>Cancel Invoice</label>
    <optionsCreateFeedItem>false</optionsCreateFeedItem>
    <quickActionLayout>
        <layoutSectionStyle>TwoColumnsLeftToRight</layoutSectionStyle>
        <quickActionLayoutColumns>
            <quickActionLayoutItems>
                <emptySpace>false</emptySpace>
                <field>Name</field>
                <uiBehavior>Required</uiBehavior>
            </quickActionLayoutItems>
            <quickActionLayoutItems>
                <emptySpace>false</emptySpace>
                <field>leaseworks__Cancellation_Date__c</field>
                <uiBehavior>Required</uiBehavior>
            </quickActionLayoutItems>
            <quickActionLayoutItems>
                <emptySpace>false</emptySpace>
                <field>leaseworks__Reversal_Accounting_Period__c</field>
                <uiBehavior>Edit</uiBehavior>
            </quickActionLayoutItems>
            <quickActionLayoutItems>
                <emptySpace>false</emptySpace>
                <field>leaseworks__Transaction_Currency__c</field>
                <uiBehavior>Edit</uiBehavior>
            </quickActionLayoutItems>
        </quickActionLayoutColumns>
        <quickActionLayoutColumns>
            <quickActionLayoutItems>
                <emptySpace>false</emptySpace>
                <field>leaseworks__Lease__c</field>
                <uiBehavior>Required</uiBehavior>
            </quickActionLayoutItems>
            <quickActionLayoutItems>
                <emptySpace>false</emptySpace>
                <field>leaseworks__Total_Invoiced_Amnt__c</field>
