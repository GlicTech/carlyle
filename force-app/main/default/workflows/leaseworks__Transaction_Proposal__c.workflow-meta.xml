<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>leaseworks__TxnProspectSetName</fullName>
        <description>Set name of Txn Prospect on save.</description>
        <field>Name</field>
        <formula>leaseworks__Transaction__r.Name + &#39; - &#39; + IF(TEXT(leaseworks__Prospect_Type__c)==&#39;Lessor&#39;,  LEFT(leaseworks__Lessor__r.Name,65), LEFT(leaseworks__Other_Party__c,65))</formula>
        <name>TxnProspectSetName</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__TxnProspectSetName</fullName>
        <actions>
            <name>leaseworks__TxnProspectSetName</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Set name of the transaction prospect.</description>
        <formula>!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
