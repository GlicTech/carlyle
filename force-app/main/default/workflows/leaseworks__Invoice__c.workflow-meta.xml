    </rules>
    <rules>
        <fullName>leaseworks__Invoice Status to Partially Paid</fullName>
        <actions>
            <name>leaseworks__Update_Status_Partially_Paid</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Update Invoice status to Partially Paid</description>
        <formula>/*AND(!$Setup.LeaseWorksSettings__c.Disable_All_WFs__c, or(Amount_Paid_Remaining__c!=0, Availed_Credit_Amount_Cm__c !=0),	Balance_Due__c != 0, 				or(Amount_Paid_Remaining__c &lt; Total_Amount_Due__c,Availed_Credit_Amount_Cm__c&lt;Total_Amount_Due__c))*/false</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__InvoiceMarkedApproved</fullName>
        <actions>
            <name>leaseworks__Update_status_Approved</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Update status after Cancellation</description>
        <formula>/*AND(!$Setup.LeaseWorksSettings__c.Disable_All_WFs__c, NOT(ISNEW()),  NOT(ISPICKVAL(PRIORVALUE(Status__c),&quot;Pending&quot;)), NOT( OR(ISPICKVAL(Status__c,&quot;Declined&quot;),ISPICKVAL(Status__c,&quot;Cancelled-Pending&quot;),ISPICKVAL(Status__c,&quot;Cancelled&quot;))), Availed_Credit_Amount_Cm__c = 0, Amount_Paid_Remaining__c =0, 	Total_Amount_Due__c = Balance_Due__c)*/false</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
