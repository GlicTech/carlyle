    <rules>
        <fullName>leaseworks__InvioceCreatedUpdated</fullName>
        <actions>
            <name>leaseworks__Invoice_Set_Name</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Used for setting name.</description>
        <formula>NOT(CONTAINS(TEXT(leaseworks__Invoice_Type__c), &apos;Deferred&apos;))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Mark Credited</fullName>
        <actions>
            <name>leaseworks__Invoice_Mark_Credited</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>/*AND(!$Setup.LeaseWorksSettings__c.Disable_All_WFs__c,  			 Balance_Due__c = 0, Amount_Paid_Remaining__c =0,Total_Amount_Due__c!=0, 			Total_Amount_Due__c = Availed_Credit_Amount_Cm__c 			)*/false</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Mark Paid</fullName>
        <actions>
            <name>leaseworks__Invoice_Update_Date_Paid</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>leaseworks__Invoice_Update_Status_to_Paid</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>/*AND(!$Setup.LeaseWorksSettings__c.Disable_All_WFs__c,  				Total_Amount_Due__c != 0, Balance_Due__c = 0, 			Total_Amount_Due__c != Availed_Credit_Amount_Cm__c )*/false</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Payment Status To Credited</fullName>
        <actions>
            <name>leaseworks__Payment_Status_To_Credited</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>When condition is true , the payment status is set to Credited</description>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c,leaseworks__Balance_Due__c = 0, leaseworks__Amount_Paid_Remaining__c =0,leaseworks__Total_Amount_Due__c!=0,leaseworks__Total_Amount_Due__c = leaseworks__Availed_Credit_Amount_Cm__c)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Payment Status To Open</fullName>
        <actions>
            <name>leaseworks__Payment_Status_To_Open</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Update payment status after Cancellation</description>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c,  				NOT(ISNEW()),  				 				NOT( OR(ISPICKVAL(leaseworks__Status__c,&quot;Declined&quot;), 												ISPICKVAL(leaseworks__Status__c,&quot;Cancelled-Pending&quot;), 												ISPICKVAL(leaseworks__Status__c,&quot;Cancelled&quot;))),  				leaseworks__Availed_Credit_Amount_Cm__c = 0, 				leaseworks__Amount_Paid_Remaining__c =0, 	 				leaseworks__Total_Amount_Due__c = leaseworks__Balance_Due__c 			 )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Payment Status To Paid</fullName>
        <actions>
            <name>leaseworks__Payment_Status_To_Paid</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Sets Payment Status to Paid</description>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c, leaseworks__Total_Amount_Due__c != 0, leaseworks__Balance_Due__c = 0,leaseworks__Total_Amount_Due__c != leaseworks__Availed_Credit_Amount_Cm__c, leaseworks__Total_Amount_Due__c = leaseworks__Amount_Paid_Remaining__c + leaseworks__Availed_Credit_Amount_Cm__c)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Payment Status To Partially Paid</fullName>
        <actions>
            <name>leaseworks__Payment_Status_To_Partially_Paid</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Update payment status to Partially Paid</description>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c, (((leaseworks__Availed_Credit_Amount_Cm__c ==0) &amp;&amp;          (leaseworks__Amount_Paid_Remaining__c !=0)) || ((leaseworks__Availed_Credit_Amount_Cm__c !=0) &amp;&amp;(leaseworks__Amount_Paid_Remaining__c !=0) &amp;&amp; (leaseworks__Balance_Due__c != 0))), 				         or(leaseworks__Amount_Paid_Remaining__c &lt; leaseworks__Total_Amount_Due__c))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Payment status to Partially Credited</fullName>
        <actions>
            <name>leaseworks__Payment_Status_To_Partially_Credited</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Update payment status to Partially Credited</description>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c, AND(leaseworks__Amount_Paid_Remaining__c==0, leaseworks__Availed_Credit_Amount_Cm__c &gt;0), leaseworks__Balance_Due__c != 0, leaseworks__Availed_Credit_Amount_Cm__c&lt;leaseworks__Total_Amount_Due__c)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Invoice Set Invoice Name</fullName>
