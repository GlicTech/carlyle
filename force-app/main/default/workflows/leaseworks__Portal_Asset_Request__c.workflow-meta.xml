<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>leaseworks__AssetReqNameUpdate</fullName>
        <field>Name</field>
        <formula>IF( LEN(leaseworks__Y_Hidden_Asset_Type__c + &quot;-&quot; +  leaseworks__Y_Hidden_Asset_Variant__c ) &gt; 70, 
LEFT(leaseworks__Y_Hidden_Asset_Type__c + &quot;-&quot; +  leaseworks__Y_Hidden_Asset_Variant__c,70) + &quot;...&quot; + &quot;-&quot; , 
leaseworks__Y_Hidden_Asset_Type__c + &quot;-&quot; +  leaseworks__Y_Hidden_Asset_Variant__c + &quot;-&quot;) +   
CASE(MONTH( leaseworks__Date_Start__c ),1, &quot;JAN&quot;, 2, &quot;FEB&quot;, 3, &quot;MAR&quot;, 4, &quot;APR&quot;, 5,&quot;MAY&quot;, 6, &quot;JUN&quot;, 7, &quot;JUL&quot;, 8, &quot;AUG&quot;, 9, &quot;SEP&quot;, 10, &quot;OCT&quot;, 11, &quot;NOV&quot;,12, &quot;DEC&quot;,&quot;NONE&quot; ) + &quot;&apos;&quot; + RIGHT(TEXT(YEAR(leaseworks__Date_Start__c)),2)</formula>
        <name>AssetReqNameUpdate</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Set_Request_Name</fullName>
        <description>Sets the name for the asset request</description>
        <field>Name</field>
        <formula>TEXT(leaseworks__Asset_Type__c)+&apos;_&apos;+  
CASE(MONTH(leaseworks__Date_Start__c),
1, &apos;JAN&apos;,
2, &apos;FEB&apos;,
3, &apos;MAR&apos;,
4, &apos;APR&apos;,
5, &apos;MAY&apos;,
6, &apos;JUN&apos;,
7, &apos;JUL&apos;,
8, &apos;AUG&apos;,
9, &apos;SEP&apos;,
10, &apos;OCT&apos;,
11, &apos;NOV&apos;,
12, &apos;DEC&apos;,
&apos;NONE&apos;)
+ &quot;&apos;&quot; + RIGHT(TEXT(YEAR(leaseworks__Date_Start__c)), 2)</formula>
        <name>Set Request Name</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__AssetRequestNameFieldUpdate</fullName>
        <actions>
            <name>leaseworks__AssetReqNameUpdate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>WF to update Asset Request object name field</description>
        <formula>AND(   !ISBLANK(leaseworks__Y_Hidden_Asset_Type__c), !ISBLANK( leaseworks__Y_Hidden_Asset_Variant__c )  )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Set Name for Asset Request</fullName>
        <actions>
            <name>leaseworks__Set_Request_Name</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Sets the name for the asset request</description>
        <formula>!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
