    <fieldUpdates>
        <fullName>leaseworks__Update_Rent_Name</fullName>
        <description>Updates the Rent name using specific format: RENT_MONTH_YEAR</description>
        <field>Name</field>
        <formula>TEXT(YEAR(leaseworks__For_Month_Ending__c )) 
&amp; &apos;-&apos; &amp; 
RIGHT(&apos;0&apos; &amp; TEXT(Month(leaseworks__For_Month_Ending__c )), 2) 
&amp; &apos;-&apos; &amp;
if( NOT(ISNULL(leaseworks__Sequence__c)) , RIGHT(&apos;00&apos; &amp; TEXT(leaseworks__Sequence__c),3) + if(leaseworks__Y_Hidden_Utilization__c!=null,if(ISPICKVAL(leaseworks__Y_Hidden_Utilization__r.leaseworks__Type__c,&apos;Actual&apos;),&apos;&apos;,&apos;(&apos; + MID(leaseworks__Y_Hidden_Utilization__r.Name,13,3)+&apos;)&apos;),&apos;&apos;) , 
RIGHT(&apos;00&apos; &amp; TEXT(leaseworks__Period_Since_Lease_Start__c), 3) 
+ if(leaseworks__Y_Hidden_Utilization__c!=null,if(ISPICKVAL(leaseworks__Y_Hidden_Utilization__r.leaseworks__Type__c,&apos;Actual&apos;),&apos;&apos;,&apos;(&apos; + MID(leaseworks__Y_Hidden_Utilization__r.Name,13,3)+&apos;)&apos;),&apos;&apos;) )</formula>
        <name>Update Rent Name</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
