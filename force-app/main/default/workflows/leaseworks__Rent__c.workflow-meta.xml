    <fieldUpdates>
        <fullName>leaseworks__SetRentAmountFromLease</fullName>
        <description>Get the Rent Amount From Parent Lease and Set it to the Rent record.</description>
        <field>leaseworks__Rent_Due_Amount__c</field>
        <formula>leaseworks__Rent_Rate__c * 
leaseworks__Escalation_Factor__c *
IF( TEXT(leaseworks__Stepped_Rent__r.leaseworks__Rent_Period__c)  == &apos;Daily&apos;,  leaseworks__Period_Days__c , 1) * IF(TEXT(leaseworks__Stepped_Rent__r.leaseworks__Rent_Period__c)  == &apos;Daily&apos;, 1, BLANKVALUE(leaseworks__Prorate__c , 1 )) 
+ BLANKVALUE(leaseworks__Rental_Adjustment_Amount__c, 0)
+ BLANKVALUE(leaseworks__Rental_Credit_Debit__c, 0)</formula>
        <name>SetRentAmountFromLease</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
