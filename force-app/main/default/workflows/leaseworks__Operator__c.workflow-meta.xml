    <fieldUpdates>
        <fullName>leaseworks__Update_Operator_Status_Open</fullName>
        <field>leaseworks__Status__c</field>
        <literalValue>Pending Approval</literalValue>
        <name>Update Operator Status Open</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Update_Operator_status_Approved</fullName>
        <field>leaseworks__Status__c</field>
        <literalValue>Approved</literalValue>
        <name>Update Operator status Approved</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
