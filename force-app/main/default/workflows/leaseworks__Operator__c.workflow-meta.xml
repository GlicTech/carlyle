    <rules>
        <fullName>leaseworks__Operator Approval</fullName>
        <active>false</active>
        <description>To send a notification when a new operator is created</description>
        <formula>TRUE</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Operator Set Alias</fullName>
        <actions>
            <name>leaseworks__Operator_Set_Alias</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Set Alias by copying Name if Alias is empty</description>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c,  ISBLANK(leaseworks__Alias__c),  PRIORVALUE( Name ) != Name)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__OperatorSendMailToResp</fullName>
        <actions>
            <name>leaseworks__Operator_Send_Email_To_Rep_On_Assignment</name>
            <type>Alert</type>
        </actions>
        <actions>
            <name>leaseworks__Operator_Set_Resp_Email</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Send an email alert to the Marketing Officer when a new operator is assigned to them</description>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c,!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_Assignment_Notification__c,ISCHANGED( leaseworks__Marketing_Representative_Contact__c ))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Revenue Status</fullName>
        <actions>
            <name>leaseworks__Revenue_SC</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>True</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
</Workflow>
