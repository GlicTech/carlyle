<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>leaseworks__Update_LoC_Status</fullName>
        <description>Set loc status to Inactive</description>
        <field>leaseworks__Status__c</field>
        <literalValue>Inactive</literalValue>
        <name>Update LoC Status</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__Loc Expiry</fullName>
        <active>false</active>
        <description>Set Loc to Inactive if Today &gt; Loc Expiry Date</description>
        <formula>AND(isPickVal(leaseworks__Status__c,&apos;Active&apos;), isPickVal( leaseworks__LC_Coverage_Type__c ,&apos;Security Deposit&apos;), NOT( OR(ISBLANK(leaseworks__Expiry_Date__c),ISNULL(leaseworks__Expiry_Date__c) )))</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
</Workflow>
