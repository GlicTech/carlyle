    <fieldUpdates>
        <fullName>leaseworks__AssemblyEventSetDataVerifiedBy</fullName>
        <field>leaseworks__Data_Verified_By__c</field>
        <formula>$User.FirstName + &apos; &apos; + $User.LastName +&apos;, &apos; +

Text(MONTH(TODAY())) + &apos;/&apos; + Text(Day(TODAY())) + &apos;/&apos; + Text(year(TODAY()))</formula>
        <name>AssemblyEventSetDataVerifiedBy</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__CAEventSetCorrectionDate</fullName>
        <field>leaseworks__Effective_Date__c</field>
        <formula>if(isBlank(leaseworks__Effective_Date__c), if(isBlank(leaseworks__End_Date__c), leaseworks__Start_Date__c ,leaseworks__End_Date__c) , leaseworks__Effective_Date__c)</formula>
        <name>CAEventSetCorrectionDate</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Set_CA_CSLV</fullName>
        <description>CSLV is set to 0 when a new Assembly Eligible Event is created</description>
        <field>leaseworks__CSLV__c</field>
        <formula>IF( !isBlank(leaseworks__End_Date__c) &amp;&amp; ISCHANGED(leaseworks__End_Date__c) ,0,  leaseworks__Constituent_Assembly__r.leaseworks__CSLSV__c )</formula>
        <name>Set CA CSLV</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
        <targetObject>leaseworks__Constituent_Assembly__c</targetObject>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Set_CA_TSLV</fullName>
        <description>TSLV is set to 0 when a new Assembly Eligible Event is created</description>
        <field>leaseworks__TSLV__c</field>
        <formula>IF( !isBlank(leaseworks__End_Date__c) &amp;&amp; ISCHANGED(leaseworks__End_Date__c)  ,0, leaseworks__Constituent_Assembly__r.leaseworks__TSLSV__c )</formula>
        <name>Set CA TSLV</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
        <targetObject>leaseworks__Constituent_Assembly__c</targetObject>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Update_CAEE_Name</fullName>
        <description>Updates the CA EE name</description>
        <field>Name</field>
        <formula>IF(AND(OR(ISNULL(leaseworks__Projected_Event__c),ISBLANK(leaseworks__Projected_Event__c)),OR(ISNULL(leaseworks__Custom_PE_Record_Number__c),ISBLANK(leaseworks__Custom_PE_Record_Number__c))), 
IF(CONTAINS(Name,&apos;&lt;System Generated&gt;&apos;),TEXT(leaseworks__Event_Type__c),Name) ,
IF( AND(OR(ISNULL(leaseworks__Projected_Event__c),ISBLANK(leaseworks__Projected_Event__c)), OR(ISNULL(leaseworks__Y_Hidden_Maintenance_Program_Event__c),ISBLANK(leaseworks__Y_Hidden_Maintenance_Program_Event__c))),
IF( OR(ISNULL(leaseworks__Custom_PE_Record_Number__c),ISBLANK(leaseworks__Custom_PE_Record_Number__c)) , &apos;&apos; , &apos;Custom Event(&apos; &amp; TEXT(leaseworks__Custom_PE_Record_Number__c) &amp; &apos;)&apos; ),
IF( OR(ISNULL(leaseworks__Custom_PE_Record_Number__c),ISBLANK(leaseworks__Custom_PE_Record_Number__c)) , leaseworks__Projected_Event__r.leaseworks__Event_Type__c , &apos;Custom Event(&apos; &amp; TEXT(leaseworks__Custom_PE_Record_Number__c) &amp; &apos;)&apos; )
)
&amp; &apos;-&apos; &amp; TEXT(leaseworks__End_Date__c)&amp;&quot;-&quot;&amp;leaseworks__Constituent_Assembly__r.leaseworks__Serial_Number__c
)</formula>
        <name>Update CAEE Name</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Update_Certified_By</fullName>
        <field>leaseworks__Certified_By__c</field>
        <formula>IF( !isBlank(leaseworks__End_Date__c) &amp;&amp; ISCHANGED(leaseworks__End_Date__c) , $User.FirstName + &apos; &apos; + $User.LastName, &apos;&apos;)</formula>
        <name>Update Certified By</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__Assembly Event Data Verifed By</fullName>
        <actions>
            <name>leaseworks__AssemblyEventSetDataVerifiedBy</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>OR ( AND (ISNEW(), leaseworks__Data_Verified_For_Accuracy__c ), ISCHANGED(leaseworks__Data_Verified_For_Accuracy__c))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Constt Assembly Eligible Event Created Updated</fullName>
        <actions>
            <name>leaseworks__CAEventSetCorrectionDate</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>leaseworks__Update_CAEE_Name</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Workflow for when Assembly Eligible event is created or updated</description>
        <formula>TRUE</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__EligibleEventTSLVSCLVVerifiedBy</fullName>
        <actions>
            <name>leaseworks__Update_Certified_By</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Record the person who clicked TSLV/CSLV Certify Check Box</description>
        <formula>TRUE</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
