    </fieldUpdates>
    <rules>
        <fullName>leaseworks__Contractual Redelivery date based on Redelivery Terms</fullName>
        <actions>
            <name>leaseworks__Update_Contractual_Redelivery_date</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>leaseworks__Lease__c.leaseworks__Redelivery_Terms__c</field>
            <operation>equals</operation>
            <value>Lease Term Driven</value>
        </criteriaItems>
        <criteriaItems>
            <field>leaseworks__Lease__c.leaseworks__Delivery_Date__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Lease Aircraft  Changed</fullName>
        <active>false</active>
        <description>Workflow actions when aircraft has changed</description>
        <formula>ISCHANGED( leaseworks__Aircraft__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Lease Data Verifed By</fullName>
        <actions>
            <name>leaseworks__LeaseSetDataVerifiedBy</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>OR ( AND (ISNEW(), leaseworks__Data_Verified_For_Accuracy__c ), ISCHANGED(leaseworks__Data_Verified_For_Accuracy__c))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Lease Rent Schedule</fullName>
        <active>false</active>
        <booleanFilter>1</booleanFilter>
        <criteriaItems>
            <field>leaseworks__Lease__c.leaseworks__Lease_Term__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Lease Start and End Date Fields Update</fullName>
        <actions>
            <name>leaseworks__Lease_End_Date_Update</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>leaseworks__Lease_Set_Placement_By</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>leaseworks__Lease_Start_Date_Update</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>To copy over the Lease Start Date and Lease End Date from the new Lease date fields to the old existing lease Date and Time fields</description>
        <formula>OR(ISNEW(), AND(ISBLANK(PRIORVALUE(leaseworks__Lease_Start_Date_New__c)), !ISBLANK(leaseworks__Lease_Start_Date_New__c)), PRIORVALUE(leaseworks__Lease_Start_Date_New__c) != leaseworks__Lease_Start_Date_New__c,  AND(ISBLANK(PRIORVALUE(leaseworks__Lease_End_Date_New__c)), !ISBLANK(leaseworks__Lease_End_Date_New__c)),  PRIORVALUE(leaseworks__Lease_End_Date_New__c) != leaseworks__Lease_End_Date_New__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__LeaseSetName</fullName>
        <actions>
            <name>leaseworks__Lease_Set_Name</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>leaseworks__Lease__c.RecordTypeId</field>
            <operation>notEqual</operation>
            <value>Non-Lease Agreement</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Lease_onCreate_SetCurRent</fullName>
        <actions>
            <name>leaseworks__Lease_Set_CurrentRent</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>going forward we&apos;ll not use this.</description>
        <formula>false</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__RedeliveryTerms</fullName>
        <active>false</active>
        <criteriaItems>
            <field>leaseworks__Lease__c.leaseworks__Redelivery_Terms__c</field>
            <operation>equals</operation>
            <value>Lease Term Driven</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Rent Update Start %26 End Date If Null</fullName>
        <actions>
            <name>leaseworks__Rent_Update_End_Date</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>leaseworks__Rent_Update_Start_Date</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <booleanFilter>1 OR 2</booleanFilter>
        <criteriaItems>
            <field>leaseworks__Lease__c.leaseworks__Rent_Date__c</field>
            <operation>equals</operation>
        </criteriaItems>
        <criteriaItems>
            <field>leaseworks__Lease__c.leaseworks__Rent_End_Date__c</field>
            <operation>equals</operation>
        </criteriaItems>
        <description>Always ensure that the rent start date end date is set.</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
