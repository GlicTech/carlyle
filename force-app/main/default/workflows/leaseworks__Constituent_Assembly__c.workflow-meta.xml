<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>leaseworks__AssemblySetDataVerifiedBy</fullName>
        <field>leaseworks__Data_Verified_By__c</field>
        <formula>$User.FirstName + &apos; &apos; + $User.LastName +&apos;, &apos; +

Text(MONTH(TODAY())) + &apos;/&apos; + Text(Day(TODAY())) + &apos;/&apos; + Text(year(TODAY()))</formula>
        <name>AssemblySetDataVerifiedBy</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Update_CA_Name</fullName>
        <field>Name</field>
        <formula>leaseworks__Serial_Number__c</formula>
        <name>Update CA Name</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__Assembly Data Verifed By</fullName>
        <actions>
            <name>leaseworks__AssemblySetDataVerifiedBy</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>OR ( AND (ISNEW(), leaseworks__Data_Verified_For_Accuracy__c ), ISCHANGED(leaseworks__Data_Verified_For_Accuracy__c))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Constt Assembly Changed</fullName>
        <actions>
            <name>leaseworks__Update_CA_Name</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Deprecated this workflow and migrated to Constt Assembly Name Update flow in 48 release.</description>
        <formula>true</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
