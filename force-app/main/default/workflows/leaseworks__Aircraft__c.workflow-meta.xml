    <rules>
        <fullName>leaseworks__Aircraft Changed_CCheck_Compare</fullName>
        <actions>
            <name>leaseworks__Aircraft_C_Check_Threshold_Warning</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <description>Rule to kick off when aircraft has changed</description>
        <formula>leaseworks__Time_Remaining_To_Check__c &lt;=    leaseworks__Alert_Threshold__c *leaseworks__Threshold_for_C_Check__c</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Aircraft Data Verifed By</fullName>
        <actions>
            <name>leaseworks__AircraftSetDataVerifiedBy</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>OR ( AND (ISNEW(),  leaseworks__Data_Verified_For_Accuracy__c  ), ISCHANGED(leaseworks__Data_Verified_For_Accuracy__c))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
