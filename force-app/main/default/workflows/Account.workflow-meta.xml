<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Account_Rejected</fullName>
        <description>Account Rejected</description>
        <protected>false</protected>
        <recipients>
            <type>creator</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>leaseworks__LeaseWorksTemplates/Account_Rejected</template>
    </alerts>
    <alerts>
        <fullName>Account_approval_submission</fullName>
        <description>Account approval submission</description>
        <protected>false</protected>
        <recipients>
            <recipient>jonathanh@carlyle.aero</recipient>
            <type>user</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>leaseworks__LeaseWorksTemplates/Accounts_approval</template>
    </alerts>
    <alerts>
        <fullName>Account_approved</fullName>
        <description>Account approved</description>
        <protected>false</protected>
        <recipients>
            <type>creator</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>leaseworks__LeaseWorksTemplates/Account_Approved</template>
    </alerts>
    <fieldUpdates>
        <fullName>Account_Status</fullName>
        <description>Update Account Status to Pending Approval</description>
        <field>leaseworks__Status__c</field>
        <literalValue>Pending Approval</literalValue>
        <name>Account Status</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Account_Status_Approve</fullName>
        <field>leaseworks__Status__c</field>
        <literalValue>Approved</literalValue>
        <name>Account Status_Approve</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Account_Status_Reject</fullName>
        <field>leaseworks__Status__c</field>
        <literalValue>Declined</literalValue>
        <name>Account Status_Reject</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
</Workflow>
