    <fieldUpdates>
        <fullName>leaseworks__Update_TSLV</fullName>
        <description>Checks to see if the date of UR is &gt; date on last C-Check. If so, increment TSLV. Also if new AC and no C-Check date is available, then we need to update as well.
BM 24-Oct-12 : Don&#39;t use this. Logic moved to trigger URHandleAfterInsert.</description>
        <field>leaseworks__Time_Since_Last_C_Check__c</field>
        <formula>IF(OR(leaseworks__Month_Ending__c &gt;leaseworks__Aircraft__r.leaseworks__Last_C_Check__c, ISBLANK(leaseworks__Aircraft__r.leaseworks__Last_C_Check__c)) , 
IF(ISNEW(), 
leaseworks__Aircraft__r.leaseworks__Time_Since_Last_C_Check__c + leaseworks__Airframe_Flight_Hours_Month__c, leaseworks__Aircraft__r.leaseworks__Time_Since_Last_C_Check__c-PRIORVALUE(leaseworks__Airframe_Flight_Hours_Month__c) + leaseworks__Airframe_Flight_Hours_Month__c), leaseworks__Aircraft__r.leaseworks__Time_Since_Last_C_Check__c)</formula>
        <name>Update TSLV</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
        <targetObject>leaseworks__Aircraft__c</targetObject>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Update_TSN</fullName>
        <description>Update TSN. BM 24-Oct-12: This is obsolete and should not be used. Logic moved to trigger URHandleAfterInsert.</description>
        <field>leaseworks__TSN__c</field>
        <formula>if (ISNEW(), leaseworks__Aircraft__r.leaseworks__TSN__c + leaseworks__Airframe_Flight_Hours_Month__c, leaseworks__Aircraft__r.leaseworks__TSN__c - PRIORVALUE(leaseworks__Airframe_Flight_Hours_Month__c) + leaseworks__Airframe_Flight_Hours_Month__c)</formula>
        <name>Update TSN</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
        <targetObject>leaseworks__Aircraft__c</targetObject>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>leaseworks__Update_Total_LG</fullName>
        <description>Set the Total LG MR adding up all the individual LG MRs.</description>
        <field>leaseworks__Maintenance_Reserve_Landing_Gear__c</field>
        <formula>BLANKVALUE( leaseworks__Maintenance_Reserve_LG_Center_Main__c , 0) +
BLANKVALUE( leaseworks__Maintenance_Reserve_LG_Left_Main__c , 0) +
BLANKVALUE( leaseworks__Maintenance_Reserve_LG_Right_Main__c , 0) +
BLANKVALUE( leaseworks__Maintenance_Reserve_LG_Nose__c , 0) +
BLANKVALUE( leaseworks__Maintenance_Reserve_LG_Left_Wing__c , 0) +
BLANKVALUE( leaseworks__Maintenance_Reserve_LG_Right_Wing__c , 0)</formula>
        <name>Update Total LG</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
