<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>leaseworks__updateInvoiceDelinquencyName</fullName>
        <field>Name</field>
        <formula>LEFT(leaseworks__Aircraft_Delinquency__r.leaseworks__Delinquency_History__r.leaseworks__Delinquency__r.leaseworks__Operator__r.Name  ,50) + &quot; &quot; +  leaseworks__Aircraft_Delinquency__r.leaseworks__MSN__c  + &quot; &quot; + TEXT(leaseworks__Due_Date__c)</formula>
        <name>updateInvoiceDelinquencyName</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__SetInvoiceDelinquencyName</fullName>
        <actions>
            <name>leaseworks__updateInvoiceDelinquencyName</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>set Name of an Invoice_Delinquency__c  as  combination of :
Operator Name(50 charachters) + MSN__c Due_Date__c</description>
        <formula>!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
