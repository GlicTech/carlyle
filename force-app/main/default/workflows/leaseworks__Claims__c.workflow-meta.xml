    <fieldUpdates>
        <fullName>leaseworks__ClaimSetDataVerifiedBy</fullName>
        <field>leaseworks__Data_Verified_By__c</field>
        <formula>$User.FirstName + &#39; &#39; + $User.LastName +&#39;, &#39; +

Text(MONTH(TODAY())) + &#39;/&#39; + Text(Day(TODAY())) + &#39;/&#39; + Text(year(TODAY()))</formula>
        <name>ClaimSetDataVerifiedBy</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__Claims Data Verifed By</fullName>
        <actions>
            <name>leaseworks__ClaimSetDataVerifiedBy</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>AND(!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c,OR ( AND (ISNEW(),  leaseworks__Data_Verified_for_Accuracy__c  ), ISCHANGED( leaseworks__Data_Verified_for_Accuracy__c )))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
