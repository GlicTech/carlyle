<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>leaseworks__Email_Alert_for_Task_Follow_Up_Related_to_IL</fullName>
        <description>Email Alert for Task Follow Up Related to IL</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>leaseworks__LeaseWorksTemplates/leaseworks__Calendar_ICS_Entry_Task_IL</template>
    </alerts>
    <fieldUpdates>
        <fullName>leaseworks__UpdateSequenceforTask</fullName>
        <field>leaseworks__Y_Hidden_Sequence__c</field>
        <formula>leaseworks__Y_Hidden_Sequence__c  + 1</formula>
        <name>UpdateSequenceforTask</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__SendICSEntryForILTask</fullName>
        <actions>
            <name>leaseworks__Email_Alert_for_Task_Follow_Up_Related_to_IL</name>
            <type>Alert</type>
        </actions>
        <actions>
            <name>leaseworks__UpdateSequenceforTask</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Email Task Reminder Based on Task Object</description>
        <formula>AND(!ISBLANK(ActivityDate),!ISBLANK( OwnerId ), OR(ISCHANGED(ActivityDate),   ISCHANGED(OwnerId), ISNEW(), (!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c )))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
