            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Record the person who clicked TSLV/CSLV Certify Check Box</description>
        <formula>true</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>leaseworks__Eligible Event Created</fullName>
        <actions>
            <name>leaseworks__Set_CSLV</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>leaseworks__Set_TSLV</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Workflows to perform when eligible event is created.
BM 24-Oct-12: Do not use this. Logic changed to trigger.</description>
        <formula>False /*  Never use this, see comment */</formula>
        <triggerType>onCreateOnly</triggerType>
    </rules>
