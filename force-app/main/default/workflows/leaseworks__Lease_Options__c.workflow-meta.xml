<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>leaseworks__UpdateLeaseOptionName</fullName>
        <description>Update Lease Option Name to &lt;Option Type&gt;+&lt;Option/Notice End&gt;</description>
        <field>Name</field>
        <formula>if ( ISBLANK(leaseworks__Option_Notice_End__c), Text(leaseworks__Option_Type__c),Text(leaseworks__Option_Type__c)+ &#39; - &#39;+ Text(year(leaseworks__Option_Notice_End__c))+&#39;-&#39;
+ IF( LEN(TEXT(MONTH(leaseworks__Option_Notice_End__c))) &gt; 1 , TEXT(MONTH(leaseworks__Option_Notice_End__c)), &quot;0&quot; + TEXT(MONTH(leaseworks__Option_Notice_End__c))) + &#39;-&#39; + 
IF( LEN(TEXT(Day(leaseworks__Option_Notice_End__c))) &gt; 1 , TEXT(Day(leaseworks__Option_Notice_End__c)), &quot;0&quot; + TEXT(Day(leaseworks__Option_Notice_End__c))))</formula>
        <name>UpdateLeaseOptionName</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>leaseworks__LeaseOptionSetName</fullName>
        <actions>
            <name>leaseworks__UpdateLeaseOptionName</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Rule to set name field when Lease Option record is created</description>
        <formula>!$Setup.leaseworks__LeaseWorksSettings__c.leaseworks__Disable_All_WFs__c</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
